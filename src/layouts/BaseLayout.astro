---
// Self-hosted brand type, bundled by Astro from npm. Replaces the
// previous Google Fonts <link> in <head> (drops the two third-party
// preconnects (fonts.googleapis.com, fonts.gstatic.com) so no visitor
// request reaches Google; the WOFF2 files ship from the site origin
// alongside the page. Variable axes preserve the 300-700 weight range
// the design system uses (Newsreader display, Source Serif 4 body).
// IBM Plex Mono ships as static weights; only 400 and 500 are imported
// (the only two weights the system uses; matches the original Google
// Fonts request).
import "@fontsource-variable/newsreader";
import "@fontsource-variable/source-serif-4";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "../styles/tokens.css";
// The shared book typesetting (prose voice, numbered section, link, CTA).
// Global so every surface — Playbook, Enginebook, CVI, Privacy — reaches for
// the same `.book-*` classes instead of re-inlining its own copy.
import "../styles/book.css";
import "../styles/voices.css";
import { urlsFor } from "../lib/urls";

interface Props {
  title: string;
  description?: string;
  // Absolute URL of this page's canonical. Usually omitted: the layout
  // derives it from the surface's PRODUCTION base (see below). Pass it only
  // to override the derivation, or on the one page it can't cover (the bare
  // apex placeholder, surface "root", which has no SurfaceUrls entry).
  canonical?: string;
  // Absolute URL to a social preview image. Presence upgrades twitter:card
  // from "summary" to "summary_large_image" (the large-image card Twitter/X
  // expects once an image is supplied).
  ogImage?: string;
}

const {
  title,
  description = "kaihacks. An experimental writing system.",
  canonical,
  ogImage,
} = Astro.props;

// Depth-aware path to the surface root. Each surface (architecture, main)
// is rsynced to its own doc root, so absolute `/foo` would resolve to the
// apex (kaihacks.ai/foo) and miss assets that live at /main/foo or
// /architecture/foo. Compute the prefix needed to climb back to the
// surface root from the current page.
//
//   /main/         → ["main"]         → 0 hops up → "./"
//   /main/cvi/     → ["main", "cvi"]  → 1 hop up  → "../"
//   /architecture/ → ["architecture"] → 0 hops up → "./"
//   /architecture/plot/ → 1 hop up → "../"
const segments = Astro.url.pathname.split("/").filter(Boolean);
const toSurfaceRoot = "../".repeat(Math.max(0, segments.length - 1)) || "./";

// Surface self-identification. Each page is built under its surface folder
// (dist/architecture|main|cultures/...), so the first path segment IS the
// surface; the bare apex placeholder (dist/index.html) has none -> "root".
// Live smoke checks (smoke/) and the CF monitor assert host -> surface using
// this stamp, which is how a future routing leak (a subdomain serving the
// wrong surface) gets caught instead of silently 200ing. See issue 149.
const surface = segments[0] ?? "root";

// Canonical: an explicit prop wins; otherwise derive from the surface's
// production base. Deliberately urlsFor() (production), NOT the DEPLOY_ENV-
// switched URLS: a canonical is a statement of authority, not navigation.
// The same page is served from several doc roots (production subdomain,
// staging path prefix), and all copies must declare the production URL as
// canonical - that is what keeps the duplicates from competing in search.
// The mapping is sound for every surface in SurfaceUrls: each build folder
// deploys as its base's doc root, so production URL = base + the path below
// the surface folder (for main's nested cvi/privacy/contact pages this
// reproduces URLS.cvi/privacy/contact exactly). The bare apex placeholder
// (surface "root") has no entry and gets no canonical unless passed.
const productionBase = (urlsFor() as unknown as Record<string, string>)[surface];
const rest = segments.slice(1).join("/");
const canonicalUrl =
  canonical ?? (productionBase ? productionBase + (rest ? `${rest}/` : "") : undefined);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="x-surface" content={surface} />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph + Twitter. og:url mirrors the canonical (derived or
         explicit; absent only on the bare apex placeholder). og:image / the
         large-image twitter:card are opt-in via `ogImage`. -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="kaihacks" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <link rel="icon" href={`${toSurfaceRoot}favicon.ico`} sizes="any" />
    <link rel="icon" href={`${toSurfaceRoot}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href={`${toSurfaceRoot}favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${toSurfaceRoot}favicon-16.png`} />
    <link rel="apple-touch-icon" href={`${toSurfaceRoot}apple-touch-icon.png`} />
    <link rel="manifest" href={`${toSurfaceRoot}site.webmanifest`} />
    <slot name="head" />
  </head>
  <body>
    <a href="#content" class="visually-hidden skip-link">Skip to content</a>
    <main id="content">
      <slot />
    </main>
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      /* Visually hidden but present for assistive tech: for text that
       * carries information for a screen reader but has no visible
       * on-page counterpart (e.g. a label prefix, the skip link at rest). */
      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      /* Skip-to-content link: the first thing a keyboard/screen-reader user
       * meets. Starts `.visually-hidden`; on focus it becomes a normal,
       * visible, styled link pinned to the top of the viewport. */
      .skip-link:focus {
        position: fixed;
        top: var(--space-3);
        left: var(--space-3);
        z-index: 100;
        width: auto;
        height: auto;
        margin: 0;
        padding: var(--space-2) var(--space-4);
        overflow: visible;
        clip: auto;
        white-space: normal;
        background: var(--color-bg);
        color: var(--color-fg);
        font-family: var(--font-mono);
        font-size: var(--font-size-sm);
        text-decoration: none;
        border: 1px solid var(--color-fg);
        border-radius: var(--radius-sm);
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
      }
      html {
        font-family: var(--font-prose);
        color: var(--color-fg);
        background: var(--color-bg);
        line-height: var(--line-height-base);
      }
      body {
        margin: 0;
        padding: var(--space-6) var(--space-4);
      }
      main {
        max-width: var(--width-prose);
        margin: 0 auto;
      }

      /* Architecture surface pages (home, spec, canon) own their own
       * width container via .arch-home or .arch-page wrappers. Neutralize
       * BaseLayout's prose-width main for those pages so the wrapper
       * controls the layout. */
      body:has(.arch-home),
      body:has(.arch-page) {
        padding: 0;
      }
      body:has(.arch-home) main,
      body:has(.arch-page) main {
        max-width: none;
        margin: 0;
      }
      .arch-page {
        max-width: var(--width-page);
        margin: 0 auto;
        padding: 0 1.25rem;
        background: var(--color-paper);
        color: var(--color-ink);
        font-family: var(--font-prose);
      }
      @media (min-width: 641px) {
        .arch-page {
          padding: 0 3.5rem;
        }
      }

      h1 {
        font-size: var(--font-size-3xl);
        line-height: var(--line-height-tight);
        margin: 0 0 var(--space-4);
      }
      p {
        font-size: var(--font-size-base);
        margin: 0 0 var(--space-4);
        color: var(--color-fg);
      }
    </style>
    {
      /* Keep big display titles (book cover, spread, shelf masthead) on one
        line by shrinking them to the page column. MUST be is:inline: the
        per-surface deploy ships only dist/<surface>/, not dist/_assets/, so a
        bundled module script 404s in production (the same reason CSS is
        inlined in astro.config). Self-contained, no imports. */
    }
    <script is:inline>
      (function () {
        function columnWidth() {
          var root = getComputedStyle(document.documentElement);
          var page = parseFloat(root.getPropertyValue("--width-page")) || Infinity;
          var body = getComputedStyle(document.body);
          var gutter = (parseFloat(body.paddingLeft) || 0) + (parseFloat(body.paddingRight) || 0);
          return Math.min(page, document.documentElement.clientWidth - gutter);
        }
        function fit() {
          var avail = columnWidth();
          document
            .querySelectorAll(".pb-cover-title, .pb-spread-title, .masthead-title")
            .forEach(function (el) {
              el.style.whiteSpace = "nowrap";
              el.style.fontSize = "";
              var size = parseFloat(getComputedStyle(el).fontSize);
              while (el.scrollWidth > avail && size > 28) {
                size -= 1;
                el.style.fontSize = size + "px";
              }
            });
        }
        var kick = function () {
          requestAnimationFrame(fit);
        };
        if (document.readyState === "loading") addEventListener("DOMContentLoaded", kick);
        else kick();
        addEventListener("resize", fit);
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(fit);
      })();
    </script>
  </body>
</html>
