---
// Self-hosted brand type, bundled by Astro from npm. Replaces the
// previous Google Fonts <link> in <head> (drops the two third-party
// preconnects (fonts.googleapis.com, fonts.gstatic.com) so no visitor
// request reaches Google; the WOFF2 files ship from the site origin
// alongside the page. Variable axes preserve the 300-700 weight range
// the design system uses (Newsreader display, Source Serif 4 body).
// IBM Plex Mono ships as static weights; only 400 and 500 are imported
// (the only two weights the system uses; matches the original Google
// Fonts request).
import "@fontsource-variable/newsreader";
import "@fontsource-variable/source-serif-4";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "../styles/tokens.css";
// The shared book typesetting (prose voice, numbered section, link, CTA).
// Global so every surface — Playbook, Enginebook, CVI, Privacy — reaches for
// the same `.book-*` classes instead of re-inlining its own copy.
import "../styles/book.css";
import "../styles/voices.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "kaihacks. An experimental writing system." } = Astro.props;

// Depth-aware path to the surface root. Each surface (architecture, main)
// is rsynced to its own doc root, so absolute `/foo` would resolve to the
// apex (kaihacks.ai/foo) and miss assets that live at /main/foo or
// /architecture/foo. Compute the prefix needed to climb back to the
// surface root from the current page.
//
//   /main/         → ["main"]         → 0 hops up → "./"
//   /main/cvi/     → ["main", "cvi"]  → 1 hop up  → "../"
//   /architecture/ → ["architecture"] → 0 hops up → "./"
//   /architecture/plot/ → 1 hop up → "../"
const segments = Astro.url.pathname.split("/").filter(Boolean);
const toSurfaceRoot = "../".repeat(Math.max(0, segments.length - 1)) || "./";

// Surface self-identification. Each page is built under its surface folder
// (dist/architecture|main|cultures/...), so the first path segment IS the
// surface; the bare apex placeholder (dist/index.html) has none -> "root".
// Live smoke checks (smoke/) and the CF monitor assert host -> surface using
// this stamp, which is how a future routing leak (a subdomain serving the
// wrong surface) gets caught instead of silently 200ing. See issue 149.
const surface = segments[0] ?? "root";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="x-surface" content={surface} />
    <title>{title}</title>
    <link rel="icon" href={`${toSurfaceRoot}favicon.ico`} sizes="any" />
    <link rel="icon" href={`${toSurfaceRoot}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href={`${toSurfaceRoot}favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${toSurfaceRoot}favicon-16.png`} />
    <link rel="apple-touch-icon" href={`${toSurfaceRoot}apple-touch-icon.png`} />
    <link rel="manifest" href={`${toSurfaceRoot}site.webmanifest`} />
  </head>
  <body>
    <main>
      <slot />
    </main>
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        font-family: var(--font-prose);
        color: var(--color-fg);
        background: var(--color-bg);
        line-height: var(--line-height-base);
      }
      body {
        margin: 0;
        padding: var(--space-6) var(--space-4);
      }
      main {
        max-width: var(--width-prose);
        margin: 0 auto;
      }

      /* Architecture surface pages (home, spec, canon) own their own
       * width container via .arch-home or .arch-page wrappers. Neutralize
       * BaseLayout's prose-width main for those pages so the wrapper
       * controls the layout. */
      body:has(.arch-home),
      body:has(.arch-page) {
        padding: 0;
      }
      body:has(.arch-home) main,
      body:has(.arch-page) main {
        max-width: none;
        margin: 0;
      }
      .arch-page {
        max-width: var(--width-page);
        margin: 0 auto;
        padding: 0 1.25rem;
        background: var(--color-paper);
        color: var(--color-ink);
        font-family: var(--font-prose);
      }
      @media (min-width: 641px) {
        .arch-page {
          padding: 0 3.5rem;
        }
      }

      h1 {
        font-size: var(--font-size-3xl);
        line-height: var(--line-height-tight);
        margin: 0 0 var(--space-4);
      }
      p {
        font-size: var(--font-size-base);
        margin: 0 0 var(--space-4);
        color: var(--color-fg);
      }
    </style>
  </body>
</html>
