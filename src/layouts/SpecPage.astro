---
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ClassPill from "../components/ClassPill.astro";
import MnemonicStrip from "../components/MnemonicStrip.astro";
import ChapterGrid from "../components/ChapterGrid.astro";
import { autoLink, rewriteMdLinks } from "../lib/auto-link";
import { playbook } from "@chbrain/khai-arch";
import MarkdownIt from "markdown-it";
import type { ParsedSpec } from "../lib/parse-spec";

interface Props {
  spec: ParsedSpec;
}

// Prev/next walks the content spine -- the production and cast groups from the
// canon's playbook. The substrate (rests on / enriched by) gets no nav, as
// before; a new content spec joins the walk automatically, no list to edit.
const NAV_GROUPS = new Set(["production", "cast"]);
const TYPE_ORDER = playbook.filter((g) => NAV_GROUPS.has(g.id)).flatMap((g) => g.members);

const { spec } = Astro.props;
const { frontmatter, lede, chapters, coda } = spec;
const md = new MarkdownIt({ html: false, breaks: false, linkify: false });

const ledeHtml = autoLink(
  rewriteMdLinks(md.renderInline(lede)),
  frontmatter.id,
  frontmatter.chapters,
);
const codaHtml = autoLink(
  rewriteMdLinks(md.renderInline(coda)),
  frontmatter.id,
  frontmatter.chapters,
);
const title = frontmatter.id.charAt(0).toUpperCase() + frontmatter.id.slice(1);

const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const currentIdx = TYPE_ORDER.indexOf(frontmatter.id);
const prevId = currentIdx > 0 ? TYPE_ORDER[currentIdx - 1] : null;
const nextId =
  currentIdx >= 0 && currentIdx < TYPE_ORDER.length - 1 ? TYPE_ORDER[currentIdx + 1] : null;
---

<BaseLayout title={`${title} - kaihacks architecture`} description={frontmatter.subtitle}>
  <div class="arch-page">
    <SiteHeader domain="architecture" tld=".kaihacks.ai" basePath="../" location={frontmatter.id} />

    <header class="spec-header">
      <div class="spec-meta">
        <ClassPill class={frontmatter.class} />
        <MnemonicStrip mnemonic={frontmatter.mnemonic} />
      </div>
      <h1 class="spec-title">{title}</h1>
      <p class="spec-subtitle">{frontmatter.subtitle}</p>
    </header>

    <section class="spec-lede" set:html={ledeHtml} />

    <ChapterGrid
      chapters={chapters}
      ownTypeId={frontmatter.id}
      ownChapterNames={frontmatter.chapters}
    />

    <section class="spec-coda" set:html={codaHtml} />

    {
      (prevId || nextId) && (
        <nav class="spec-nav" aria-label="Spec navigation">
          {prevId ? (
            <a href={`../${prevId}/`} class="spec-nav-link spec-nav-prev">
              <span class="spec-nav-arrow" aria-hidden="true">
                ←
              </span>
              <span class="spec-nav-label">{cap(prevId)}</span>
            </a>
          ) : (
            <span />
          )}
          {nextId ? (
            <a href={`../${nextId}/`} class="spec-nav-link spec-nav-next">
              <span class="spec-nav-label">{cap(nextId)}</span>
              <span class="spec-nav-arrow" aria-hidden="true">
                →
              </span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }

    <SiteFooter />
  </div>

  <style>
    .spec-header {
      margin-bottom: var(--space-6);
    }
    .spec-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      margin-bottom: var(--space-4);
    }
    .spec-title {
      margin: 0 0 var(--space-2);
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
    }
    .spec-subtitle {
      margin: 0;
      font-size: var(--font-size-lg);
      color: var(--color-fg-muted);
      font-style: italic;
    }
    .spec-lede {
      font-size: var(--font-size-lg);
      line-height: var(--line-height-loose);
      margin-bottom: var(--space-6);
    }
    .spec-lede :global(a),
    .spec-coda :global(a) {
      color: var(--color-accent);
      text-decoration: underline;
    }
    .spec-coda {
      margin-top: var(--space-6);
      padding-top: var(--space-5);
      border-top: var(--border-thin);
      font-size: var(--font-size-base);
      line-height: var(--line-height-loose);
    }

    /* Prev / next slider through the typed specs. Edges (Plot, Persona)
     * leave one side empty so the surviving link stays on its side via
     * flex space-between. */
    .spec-nav {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: var(--space-4);
      margin-top: var(--space-7);
      padding-top: var(--space-5);
      border-top: 1px solid var(--color-ink);
    }
    .spec-nav-link {
      display: inline-flex;
      align-items: baseline;
      gap: 14px;
      text-decoration: none;
      color: var(--color-ink);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .spec-nav-arrow {
      color: var(--color-brick);
      font-family: var(--font-mono);
      font-size: 14px;
    }
    .spec-nav-label {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.01em;
      line-height: 1;
      text-transform: none;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .spec-nav-label {
        font-size: 26px;
      }
    }
    .spec-nav-link:hover .spec-nav-label {
      color: var(--color-brick);
    }
  </style>
</BaseLayout>
