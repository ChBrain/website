---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

// The Misfits production house, running on the architecture. Served
// "for now" at /misfits (a path, not yet its own subdomain like
// cultures.kaihacks.ai). Content is lifted from the house's own
// registry (chbrain/khai-misfits · registry.json + README): each
// misfit is a khai play staged as a misfit, a failure mode of an
// organisation made watchable. The two productions below are the
// current run; the minor version of the house IS the misfit count,
// so the library grows one production at a time.
const productions = [
  {
    id: "the_decision_travels",
    title: "The Decision Travels",
    logline:
      "A correct decision crosses the whole chain while the Body who must live with it never follows it.",
  },
  {
    id: "watermelon_reporting",
    title: "Watermelon Reporting",
    logline:
      "Green on the skin, red in the flesh: the red never reaches a seat that can act, because every rung is paid to move on.",
  },
];

const REPO = "https://github.com/ChBrain/khai-misfits";
---

<BaseLayout
  title="Misfits · KAI HACKS AI"
  description="The Misfits production house: khai plays staged as misfits, each a failure mode of an organisation made watchable."
>
  <div class="arch-page misfits misfits-home">
    <SiteHeader domain="kaihacks" tld=".ai" location="misfits" />

    <header class="mf-mast">
      <div class="mf-overline">an application · running on the architecture</div>
      <h1 class="mf-h1">
        Misfits<em>.</em>
      </h1>
      <p class="mf-lede">The failure is already in the room.</p>
      <p class="mf-sub">
        A production house of khai plays staged as misfits. Each one takes a way an organisation
        quietly breaks — a decision that travels without its Body, a status that stays green while
        the work runs red — and stages it so you can watch it happen.
      </p>
    </header>

    <section id="productions" class="mf-section">
      <div class="mf-seclabel">
        <span class="mf-n">§01</span>
        <div class="mf-seclabel-body">
          <h2 class="mf-h2">The productions</h2>
          <p class="mf-secnote">the current run — the house grows one misfit at a time</p>
        </div>
      </div>

      <div class="mf-plays">
        {
          productions.map((p) => (
            <a href={`${REPO}/tree/main/misfits/${p.id}`} class="mf-play">
              <span class="mf-play-label">misfit</span>
              <h3 class="mf-play-title">{p.title}</h3>
              <p class="mf-play-logline">{p.logline}</p>
              <span class="mf-play-cta">Read the staging →</span>
            </a>
          ))
        }
      </div>
    </section>

    <section id="library" class="mf-section">
      <div class="mf-seclabel">
        <span class="mf-n">§02</span>
        <div class="mf-seclabel-body">
          <h2 class="mf-h2">The house</h2>
          <p class="mf-secnote">how it is written, gated, and licensed</p>
        </div>
      </div>

      <p class="mf-prose">
        The misfits are written in khai-playwright mode, raised by khai-stage and wired to the khai
        canon. Content is CC-BY-NC-SA; the code is MIT. The source is credited where it is in the
        public domain, never claimed.
      </p>

      <div class="mf-library-links">
        <a href={REPO} class="mf-library-link">House on GitHub ↗</a>
        <a href={`${REPO}/releases`} class="mf-library-link">Releases ↗</a>
      </div>
    </section>

    <SiteFooter />
  </div>

  <style is:global>
    /* Scroll-snap on the document, matching the site standard (main, CVI,
     * cultures): the masthead and each section snap to the top, with
     * scroll-padding leaving room for the sticky header + footer. Scoped
     * to .misfits-home. Disabled on phones, where the page reads better
     * as one continuous scroll. */
    html:has(.misfits-home) {
      scroll-snap-type: y mandatory;
      scroll-padding-top: 4rem;
      scroll-padding-bottom: 4rem;
      scroll-behavior: smooth;
    }
    @media (max-width: 640px) {
      html:has(.misfits-home) {
        scroll-snap-type: none;
      }
    }
  </style>

  <style>
    /* Misfits landing: brand-book aligned, lifting the editorial grammar
     * from the cultures surface (paper ground, ink voice, brick dot
     * accents, mono labels in caps) so the two applications read as
     * siblings on the same architecture. */

    /* ── snap panels ─────────────────────────────────────────────────── */
    .misfits-home > .mf-mast,
    .misfits-home > .mf-section {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    @media (min-width: 641px) {
      .misfits-home > .mf-mast,
      .misfits-home > .mf-section {
        min-height: calc(100vh - 8rem);
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
    }
    @media (max-width: 640px) {
      .misfits-home > .mf-mast,
      .misfits-home > .mf-section {
        scroll-snap-align: none;
        scroll-snap-stop: normal;
      }
    }

    /* ── masthead ────────────────────────────────────────────────────── */
    .mf-mast {
      padding: 56px 0 38px;
      border-bottom: 1px solid var(--color-rule);
    }
    @media (min-width: 641px) {
      .mf-mast {
        padding: 80px 0 48px;
      }
    }
    .mf-overline {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.26em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    @media (min-width: 641px) {
      .mf-overline {
        font-size: 11px;
      }
    }
    .mf-h1 {
      margin: 16px 0 0;
      font-family: var(--font-display);
      font-weight: 380;
      font-size: 64px;
      line-height: 0.96;
      letter-spacing: -0.025em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .mf-h1 {
        font-size: 124px;
      }
    }
    .mf-h1 em {
      color: var(--color-brick);
      font-style: normal;
    }
    .mf-lede {
      margin: 26px 0 0;
      max-width: 760px;
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 26px;
      line-height: 1.18;
      letter-spacing: -0.01em;
      color: var(--color-ink);
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .mf-lede {
        font-size: 36px;
      }
    }
    .mf-sub {
      margin: 14px 0 0;
      max-width: 720px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 17px;
      line-height: 1.45;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .mf-sub {
        font-size: 19px;
      }
    }

    /* ── sections shared ─────────────────────────────────────────────── */
    .mf-section {
      padding: 56px 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .mf-section:last-of-type {
      border-bottom: none;
    }
    .mf-seclabel {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 28px;
      flex-wrap: wrap;
    }
    .mf-n {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-brick);
      text-transform: uppercase;
      flex: 0 0 auto;
    }
    .mf-seclabel-body {
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex: 1;
      min-width: 280px;
    }
    .mf-h2 {
      margin: 0;
      font-family: var(--font-display);
      font-weight: 420;
      font-size: 27px;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .mf-h2 {
        font-size: 31px;
      }
    }
    .mf-secnote {
      margin: 0;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 15px;
      color: var(--color-ink-soft);
    }

    /* ── §01 productions ─────────────────────────────────────────────── */
    .mf-plays {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }
    @media (min-width: 641px) {
      .mf-plays {
        grid-template-columns: 1fr 1fr;
        gap: 22px;
      }
    }
    .mf-play {
      background: var(--color-paper-warm);
      border: 1px solid var(--color-rule);
      border-top: 4px solid var(--color-brick);
      padding: 24px 26px 26px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      text-decoration: none;
      color: var(--color-ink);
      transition:
        transform 0.16s,
        box-shadow 0.16s;
    }
    .mf-play:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px -16px var(--color-ink);
    }
    .mf-play-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }
    .mf-play-title {
      margin: 0;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 26px;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    .mf-play-logline {
      margin: 0;
      font-family: var(--font-prose);
      font-size: 15px;
      line-height: 1.5;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    .mf-play-cta {
      align-self: flex-start;
      margin-top: 6px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      color: var(--color-ink);
      text-transform: uppercase;
      border-bottom: 1px solid var(--color-brick);
      padding-bottom: 3px;
    }
    .mf-play:hover .mf-play-cta {
      color: var(--color-brick);
    }

    /* ── §02 house ───────────────────────────────────────────────────── */
    .mf-prose {
      margin: 0;
      max-width: 680px;
      font-family: var(--font-prose);
      font-size: 16px;
      line-height: 1.55;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    .mf-library-links {
      margin-top: 28px;
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .mf-library-link {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
      text-decoration: none;
      border-bottom: 1px solid var(--color-rule);
      padding-bottom: 2px;
    }
    .mf-library-link:hover {
      color: var(--color-brick);
      border-bottom-color: var(--color-brick);
    }
  </style>
</BaseLayout>
