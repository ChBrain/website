---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const apexNav = [
  { label: "company", href: "https://kaihacks.ai/main/" },
  { label: "architecture", href: "https://architecture.kaihacks.ai/" },
  { label: "cultures", href: "#" },
];

// Sub-processors. Each row has its own privacy-policy link.
const processors = [
  {
    who: "GoDaddy",
    what: "Domain registrar, DNS, and host. Holds domain-registration records and serves the site's pages from a cPanel server; logs visitor requests for security and abuse.",
    policy: "https://www.godaddy.com/legal/agreements/privacy-policy",
  },
  {
    who: "Cloudflare",
    what: "Content delivery and security in front of the site (proxying mode). Processes every visitor's IP address and may set strictly-necessary security cookies.",
    policy: "https://www.cloudflare.com/privacypolicy/",
  },
  {
    who: "GitHub",
    what: "Hosts the source repositories and downloadable artifacts referenced from this site. When you browse, clone, fork, or download from a GitHub link, your request goes to GitHub and is logged there.",
    policy: "https://docs.github.com/site-policy/privacy-policies/github-privacy-statement",
  },
  {
    who: "Substack",
    what: "Hosts and delivers the newsletter; stores subscriber emails and engagement.",
    policy: "https://substack.com/privacy",
  },
];
---

<BaseLayout
  title="KAI HACKS AI · Privacy Statement"
  description="How KAI HACKS AI handles the small amount of data that passes through this site and its newsletter - who processes it, why, and what you can ask us to do about it."
>
  <div class="arch-page privacy">
    <SiteHeader domain="kaihacks" tld=".ai" basePath="https://kaihacks.ai/main/" nav={apexNav} />

    <header class="p-mast">
      <div class="p-mono">privacy</div>
      <h1 class="p-h1">Privacy <em>Statement</em></h1>
      <p class="p-lede">
        How KAI HACKS AI handles the small amount of data that passes through this site and its
        newsletter - who processes it, why, and what you can ask us to do about it.
      </p>
      <div class="p-meta">
        <div>
          <span class="p-k">Document</span><span class="p-v"
            >Privacy statement · <span class="p-fillme">DRAFT v0.1</span></span
          >
        </div>
        <div>
          <span class="p-k">Effective</span><span class="p-v"
            ><span class="p-todo">TODO · date</span></span
          >
        </div>
        <div>
          <span class="p-k">Controller</span><span class="p-v"
            >Kai Schlüter, trading as KAI HACKS AI (Denmark, CVR&nbsp;41768274)</span
          >
        </div>
        <div>
          <span class="p-k">Contact</span><span class="p-v">privacy@kaihacks.ai</span>
        </div>
      </div>
    </header>

    <section class="p-section">
      <div class="p-seclabel">
        <span class="p-n">01</span><h2 class="p-h2">The short version</h2>
      </div>
      <p>
        This is a small site with a newsletter. We don't sell data, we don't run advertising
        trackers, and we collect the minimum needed to serve pages, keep them secure, and send you
        the newsletter if you ask for it. The few companies that help us run it are listed in
        <a href="#vendors">section&nbsp;04</a>.
      </p>
    </section>

    <section class="p-section">
      <div class="p-seclabel"><span class="p-n">02</span><h2 class="p-h2">What we collect</h2></div>
      <h3 class="p-h3">Automatically, when you visit</h3>
      <p>
        Like every website, our hosting and security providers process basic technical data so pages
        load and stay protected:
      </p>
      <ul class="p-list">
        <li>Your <strong>IP address</strong> and approximate region</li>
        <li>Browser and device type, and the pages you request</li>
        <li>Date, time, and referring page</li>
      </ul>
      <p>
        This is handled in server logs by GoDaddy (our host) and in security logs by Cloudflare. We
        don't tie it to your identity.
      </p>

      <h3 class="p-h3">Only when you give it to us</h3>
      <p>
        If you subscribe to the newsletter, you provide your <strong>email address</strong>
        (and optionally a name). That's the only personal information we deliberately collect, and it's
        handled by Substack - see <a href="#newsletter">section&nbsp;03</a>.
      </p>
    </section>

    <section id="newsletter" class="p-section">
      <div class="p-seclabel"><span class="p-n">03</span><h2 class="p-h2">The newsletter</h2></div>
      <p>
        Our newsletter is published on <strong>Substack</strong> at
        <a href="https://combinedcultures.substack.com">combinedcultures.substack.com</a>.
        Subscriptions are handled entirely on Substack's own site. When you click through to
        subscribe, your email address is collected and stored by Substack as part of its own
        service, under <a href="https://substack.com/privacy">Substack's privacy policy</a>. We can
        see your subscriber email and engagement (whether messages were opened or links clicked)
        within the Substack dashboard, and we use it only to send the newsletter.
      </p>
      <p>
        You can unsubscribe at any time using the link in the footer of every email, or by emailing
        us.
      </p>
    </section>

    <section id="vendors" class="p-section">
      <div class="p-seclabel">
        <span class="p-n">04</span><h2 class="p-h2">Who helps us run this</h2>
      </div>
      <p>
        These are our service providers (sub-processors). Each has its own privacy policy governing
        the data it handles:
      </p>
      <div class="p-proc">
        {
          processors.map((p) => (
            <div class="p-proc-row">
              <div class="p-proc-who">{p.who}</div>
              <div class="p-proc-what">
                {p.what} <a href={p.policy}>Policy ↗</a>
              </div>
            </div>
          ))
        }
      </div>
      <p>
        We don't share your data with anyone beyond what's needed for these services to function,
        and we never sell it.
      </p>
    </section>

    <section class="p-section">
      <div class="p-seclabel"><span class="p-n">05</span><h2 class="p-h2">Cookies</h2></div>
      <p>We don't use advertising or analytics-tracking cookies.</p>
      <ul class="p-list">
        <li>
          <strong>Essential security cookies</strong> may be set by Cloudflare (e.g.
          <em>__cf_bm</em>) to tell humans from bots. These are strictly necessary and don't track
          you across sites.
        </li>
        <li>
          No Substack cookies are set on this domain. Subscribing happens entirely on substack.com;
          cookies that Substack sets only apply there.
        </li>
      </ul>
    </section>

    <section class="p-section">
      <div class="p-seclabel">
        <span class="p-n">06</span><h2 class="p-h2">How long we keep it</h2>
      </div>
      <p>
        Technical logs are retained by our host and Cloudflare for short periods under their own
        policies. Your newsletter email is kept by Substack until you unsubscribe, after which
        Substack removes you from the active list.
      </p>
    </section>

    <section class="p-section">
      <div class="p-seclabel">
        <span class="p-n">07</span><h2 class="p-h2">Your choices & rights</h2>
      </div>
      <p>You can:</p>
      <ul class="p-list">
        <li><strong>Unsubscribe</strong> instantly via the link in any newsletter email.</li>
        <li>
          <strong>Ask what we hold</strong> about you, and ask us to correct or delete it, by emailing
          <a href="mailto:privacy@kaihacks.ai">privacy@kaihacks.ai</a>.
        </li>
      </ul>
      <p>
        KAI HACKS AI operates from the EU (Denmark), so the GDPR applies to how we process your
        data. Under the GDPR you may ask us to access, correct, delete, restrict, or port your data,
        and you may lodge a complaint with your local data-protection authority - in Denmark that's
        <a href="https://www.datatilsynet.dk/">Datatilsynet</a>. Visitors from the UK or California
        may have additional or analogous rights (UK GDPR, CCPA); contact us at the address above to
        exercise any of them.
      </p>
    </section>

    <section class="p-section p-section--last">
      <div class="p-seclabel"><span class="p-n">08</span><h2 class="p-h2">Changes</h2></div>
      <p>
        If we change how we handle data, we'll update this page and move the effective date at the
        top. Material changes to the newsletter will be noted in the newsletter itself.
      </p>
    </section>

    <footer class="p-foot">
      <p class="p-mono p-foot-line">
        KAI HACKS AI · Privacy statement · <span class="p-fillme">DRAFT - not yet published</span>
      </p>
      <p class="p-mono p-foot-line">
        Controller: Kai Schlüter, KAI HACKS AI (Denmark, CVR 41768274) · Effective <span
          class="p-todo">TODO</span
        > · privacy@kaihacks.ai
      </p>
    </footer>

    <SiteFooter siteLabel="kaihacks.ai · legal" />
  </div>

  <style>
    /* Legal-doc inner column. The .arch-page wrapper gives us the
     * 1080px chrome-aligned container; this narrower column keeps the
     * reading text comfortable. */
    .privacy {
      max-width: 820px;
    }

    .p-mono {
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 11px;
      color: var(--color-ink-mute);
    }

    /* ── masthead ───────────────────────────────────────────────────────── */
    .p-mast {
      padding: 56px 0 38px;
      border-bottom: 1px solid var(--color-rule);
    }
    .p-h1 {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 46px;
      line-height: 1.05;
      letter-spacing: -0.018em;
      margin: 14px 0 18px;
      color: var(--color-ink);
    }
    .p-h1 em {
      font-style: italic;
      color: var(--color-ink-soft);
    }
    .p-lede {
      font-size: 18px;
      color: var(--color-ink);
      line-height: 1.55;
      margin: 0 0 16px;
    }
    .p-meta {
      display: flex;
      gap: 34px;
      flex-wrap: wrap;
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid var(--color-rule-soft);
    }
    .p-meta div span {
      display: block;
    }
    .p-k {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--color-ink-mute);
      margin-bottom: 5px;
    }
    .p-v {
      font-size: 15px;
      color: var(--color-ink);
    }

    /* ── sections ───────────────────────────────────────────────────────── */
    .p-section {
      padding: 38px 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .p-section--last {
      border-bottom: none;
    }
    .p-seclabel {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 18px;
    }
    .p-n {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--color-brick);
      flex: 0 0 auto;
    }
    .p-h2 {
      font-family: var(--font-display);
      font-weight: 420;
      font-size: 27px;
      letter-spacing: -0.01em;
      margin: 0;
      color: var(--color-ink);
    }
    .p-h3 {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin: 22px 0 9px;
      color: var(--color-ink);
    }

    .privacy p {
      margin: 0 0 16px;
      text-wrap: pretty;
      color: var(--color-ink-soft);
    }
    .privacy strong {
      font-weight: 600;
      color: var(--color-ink);
    }
    .privacy em {
      font-style: italic;
    }
    .privacy a {
      color: var(--color-brick);
      text-decoration: none;
      border-bottom: 1px solid var(--color-rule);
    }

    .p-list {
      margin: 0 0 16px;
      padding-left: 0;
      list-style: none;
    }
    .p-list li {
      color: var(--color-ink-soft);
      line-height: 1.5;
      margin-bottom: 9px;
      padding-left: 20px;
      position: relative;
    }
    .p-list li::before {
      content: "-";
      position: absolute;
      left: 0;
      color: var(--color-rule);
      font-family: var(--font-mono);
    }

    /* ── sub-processor table ────────────────────────────────────────────── */
    .p-proc {
      border: 1px solid var(--color-rule-soft);
      border-radius: 3px;
      overflow: hidden;
      margin: 6px 0 16px;
    }
    .p-proc-row {
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .p-proc-row:last-child {
      border-bottom: none;
    }
    .p-proc-row:nth-child(even) {
      background: var(--color-paper-warm);
    }
    .p-proc-row > div {
      padding: 13px 16px;
    }
    .p-proc-who {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--color-ink);
      border-right: 1px solid var(--color-rule-soft);
      display: flex;
      align-items: center;
    }
    .p-proc-what {
      font-size: 14.5px;
      color: var(--color-ink-soft);
      line-height: 1.45;
    }
    .p-proc-what a {
      font-size: 12px;
    }

    /* ── draft markers (amber = draft per CVI) ──────────────────────────── */
    .p-todo {
      background: rgba(201, 142, 54, 0.12);
      border: 1px solid rgba(201, 142, 54, 0.4);
      color: #7a5212;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.02em;
      border-radius: 2px;
      padding: 1px 6px;
      white-space: nowrap;
    }
    .p-fillme {
      color: var(--color-amber);
      font-style: normal;
      font-weight: 600;
      background: rgba(201, 142, 54, 0.1);
      padding: 0 4px;
      border-radius: 2px;
    }

    /* ── footer ─────────────────────────────────────────────────────────── */
    .p-foot {
      padding: 32px 0 28px;
    }
    .p-foot-line {
      line-height: 1.9;
    }

    @media (max-width: 600px) {
      .p-proc-row {
        grid-template-columns: 1fr;
      }
      .p-proc-who {
        border-right: none;
        border-bottom: 1px solid var(--color-rule-soft);
      }
    }
  </style>
</BaseLayout>
