---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Shelf, { type ShelfCard } from "../../components/Shelf.astro";
import { loadRegistry } from "@chbrain/khai-plays";
import { loadAllPlays } from "../../lib/load-plays";
// MOCK -- REMOVE WHEN THE FIRST HOUSE REGISTERS (see ./_mock).
import { MOCK_HOUSES } from "./_mock";
import { URLS } from "../../lib/urls";

const houses = loadRegistry();
const plays = loadAllPlays();

// Fallback to mock houses only if the registry is completely empty (should not happen since buechner is registered)
const bill = houses.length ? houses : MOCK_HOUSES;

const cards: ShelfCard[] = bill.map((h: (typeof bill)[number]) => {
  const isInstalled = plays.some((p) => p.houseId === h.id);

  return {
    href: isInstalled ? `/plays/${h.id}/` : h.repo,
    external: !isInstalled,
    eyebrow: h.package,
    state: isInstalled ? "active · a khai-plays collection" : "work in progress",
    title: h.title,
    note: isInstalled ? h.blurb : `${h.blurb} Grimm is still in progress.`,
    cta: isInstalled ? "Enter the house →" : "Visit repository →",
    downloadHref: isInstalled ? `${URLS.plays}downloads/plays/${h.id}.zip` : undefined,
    downloadCta: isInstalled ? "Download plays →" : undefined,
  };
});
---

<BaseLayout
  title="Plays · kaihacks"
  description="The bill of houses: each a khai-plays collection the website reads, its plays inside."
>
  {
    /* Search the bill, the plays, and everything inside them (personas, places,
      pieces, positions, processes, plots, references). The index is a static
      JSON the build emits next to this page; the overlay below fetches it and
      matches client-side. The trigger is fixed-position so it floats above the
      snap-scrolling shelf rather than living inside a snap panel. */
  }
  <button
    type="button"
    class="ps-trigger"
    id="ps-open"
    aria-haspopup="dialog"
    aria-expanded="false"
  >
    <span class="ps-trigger-icon" aria-hidden="true">⌕</span>
    <span class="ps-trigger-label">Search</span>
    <kbd class="ps-trigger-kbd" aria-hidden="true">/</kbd>
  </button>

  <div class="ps-overlay" id="ps-overlay" hidden>
    <div class="ps-backdrop" id="ps-backdrop"></div>
    <div class="ps-dialog" role="dialog" aria-modal="true" aria-label="Search the plays">
      <div class="ps-field">
        <span class="ps-field-icon" aria-hidden="true">⌕</span>
        <input
          id="ps-input"
          class="ps-input"
          type="search"
          autocomplete="off"
          spellcheck="false"
          placeholder="Search houses, plays, personas, places…"
          aria-label="Search query"
          aria-controls="ps-results"
          aria-expanded="false"
          role="combobox"
        />
        <button type="button" class="ps-close" id="ps-close" aria-label="Close search">Esc</button>
      </div>
      <ul class="ps-results" id="ps-results" role="listbox" aria-label="Search results"></ul>
      <p class="ps-hint" id="ps-hint">Type to search the bill and everything inside it.</p>
    </div>
  </div>

  <Shelf
    domain="plays"
    location="the bill"
    sectionLabel="§ · the productions"
    title="KHAI Plays"
    accent="Plays"
    sectionNo="§1"
    sectionTitle="The houses"
    sectionNote="the bill"
    cards={cards}
    empty="No houses registered yet."
  >
    <Fragment slot="subline">
      The bill of houses. khai holds the index, not the productions: each house is a
      <code>khai-plays-&lt;source&gt;</code> collection, and the website reads its programme. The bill
      is the list; the plays live in the houses.
    </Fragment>
  </Shelf>

  {
    /* Global (not scoped): the result rows are built in JS, so they never carry
      Astro's scoped data-attribute. A `ps-` prefix keeps the global rules from
      leaking into the rest of the surface. */
  }
  <style is:global>
    .ps-trigger {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 50;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.85rem;
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.04em;
      color: var(--color-ink);
      background: var(--color-paper);
      border: 1px solid var(--color-ink);
      cursor: pointer;
      transition:
        transform 0.16s,
        box-shadow 0.16s;
    }
    .ps-trigger:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 24px -16px var(--color-ink);
    }
    .ps-trigger-icon {
      font-size: 14px;
      color: var(--color-brick);
    }
    .ps-trigger-kbd {
      font-family: var(--font-mono);
      font-size: 10px;
      line-height: 1;
      padding: 2px 5px;
      color: var(--color-ink-soft);
      border: 1px solid var(--color-rule);
    }
    @media (max-width: 640px) {
      .ps-trigger-label,
      .ps-trigger-kbd {
        display: none;
      }
    }

    .ps-overlay[hidden] {
      display: none;
    }
    .ps-overlay {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: max(8vh, 2rem) 1rem 2rem;
    }
    .ps-backdrop {
      position: absolute;
      inset: 0;
      background: color-mix(in srgb, var(--color-ink) 38%, transparent);
      backdrop-filter: blur(2px);
    }
    .ps-dialog {
      position: relative;
      width: 100%;
      max-width: 640px;
      max-height: 80vh;
      display: flex;
      flex-direction: column;
      background: var(--color-paper);
      border: 1px solid var(--color-ink);
      box-shadow: 0 24px 64px -24px var(--color-ink);
    }
    .ps-field {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--color-rule);
    }
    .ps-field-icon {
      font-size: 18px;
      color: var(--color-brick);
    }
    .ps-input {
      flex: 1;
      min-width: 0;
      border: none;
      outline: none;
      background: transparent;
      font-family: var(--font-prose);
      font-size: 17px;
      color: var(--color-ink);
    }
    .ps-input::placeholder {
      color: var(--color-ink-mute);
    }
    .ps-close {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      color: var(--color-ink-soft);
      background: transparent;
      border: 1px solid var(--color-rule);
      padding: 3px 6px;
      cursor: pointer;
    }
    .ps-results {
      list-style: none;
      margin: 0;
      padding: 0;
      overflow-y: auto;
      flex: 1;
    }
    .ps-result {
      display: block;
      text-decoration: none;
      color: var(--color-ink);
      padding: 0.7rem 1rem;
      border-bottom: 1px solid var(--color-rule);
      cursor: pointer;
    }
    .ps-result:last-child {
      border-bottom: none;
    }
    .ps-result.is-active,
    .ps-result:hover {
      background: var(--color-paper-warm);
    }
    .ps-result-head {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      flex-wrap: wrap;
    }
    .ps-result-kind {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--color-brick);
    }
    .ps-result-title {
      font-family: var(--font-display);
      font-size: 19px;
      line-height: 1.1;
      letter-spacing: -0.01em;
    }
    .ps-result-crumb {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.04em;
      color: var(--color-ink-mute);
      margin-left: auto;
    }
    .ps-result-text {
      margin: 0.3rem 0 0;
      font-family: var(--font-prose);
      font-size: 13px;
      line-height: 1.45;
      color: var(--color-ink-soft);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .ps-result-text mark {
      background: color-mix(in srgb, var(--color-brick) 24%, transparent);
      color: inherit;
    }
    .ps-hint {
      margin: 0;
      padding: 0.7rem 1rem;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.06em;
      color: var(--color-ink-mute);
      border-top: 1px solid var(--color-rule);
    }
  </style>

  {
    /* is:inline and self-contained: the per-surface deploy ships only
      dist/plays/, not dist/_assets/, so a bundled module script would 404 (same
      reason BaseLayout inlines its fit script). No imports, fetches its own
      index relative to /plays/. */
  }
  <script is:inline>
    (function () {
      var overlay = document.getElementById("ps-overlay");
      var trigger = document.getElementById("ps-open");
      var input = document.getElementById("ps-input");
      var results = document.getElementById("ps-results");
      var hint = document.getElementById("ps-hint");
      var closeBtn = document.getElementById("ps-close");
      var backdrop = document.getElementById("ps-backdrop");
      if (!overlay || !trigger || !input || !results) return;

      var KIND_LABEL = {
        house: "House",
        play: "Play",
        persona: "Persona",
        place: "Place",
        piece: "Piece",
        position: "Position",
        process: "Process",
        plot: "Plot",
        plan: "Plan",
        reference: "Reference",
      };

      var index = null;
      var loading = false;
      var active = -1;
      var current = [];

      function load() {
        if (index || loading) return;
        loading = true;
        fetch("./search-index.json")
          .then(function (r) {
            return r.ok ? r.json() : { entries: [] };
          })
          .then(function (data) {
            index = (data && data.entries) || [];
            if (input.value) run(input.value);
          })
          .catch(function () {
            index = [];
            hint.textContent = "Search index unavailable.";
          });
      }

      function norm(s) {
        return (s || "").toLowerCase();
      }

      // AND over tokens: every token must appear somewhere in the entry. Title
      // hits weigh far more than body hits, and houses/plays sit above the
      // elements nested under them so the broadest match leads.
      function score(entry, tokens) {
        var title = norm(entry.title);
        var hay = norm(
          entry.title + " " + (entry.house || "") + " " + (entry.play || "") + " " + entry.text,
        );
        var total = 0;
        for (var i = 0; i < tokens.length; i++) {
          var t = tokens[i];
          if (hay.indexOf(t) === -1) return 0;
          if (title.indexOf(t) !== -1) {
            total += title === t ? 30 : title.indexOf(t) === 0 ? 14 : 9;
          } else {
            total += 2;
          }
        }
        if (entry.kind === "house") total += 4;
        else if (entry.kind === "play") total += 3;
        return total;
      }

      function escapeHtml(s) {
        return s.replace(/[&<>"]/g, function (c) {
          return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c];
        });
      }

      function highlight(text, tokens) {
        var out = escapeHtml(text);
        // Longest tokens first so a shorter token can't split a longer mark.
        tokens
          .slice()
          .sort(function (a, b) {
            return b.length - a.length;
          })
          .forEach(function (t) {
            if (!t) return;
            var re = new RegExp("(" + t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&") + ")", "ig");
            out = out.replace(re, "<mark>$1</mark>");
          });
        return out;
      }

      function run(q) {
        var query = q.trim();
        active = -1;
        if (!query) {
          current = [];
          results.innerHTML = "";
          input.setAttribute("aria-expanded", "false");
          hint.hidden = false;
          hint.textContent = "Type to search the bill and everything inside it.";
          return;
        }
        if (!index) {
          hint.hidden = false;
          hint.textContent = "Loading index…";
          return;
        }
        var tokens = norm(query).split(/\s+/).filter(Boolean);
        current = index
          .map(function (e) {
            return { e: e, s: score(e, tokens) };
          })
          .filter(function (r) {
            return r.s > 0;
          })
          .sort(function (a, b) {
            return b.s - a.s;
          })
          .slice(0, 24)
          .map(function (r) {
            return r.e;
          });

        results.innerHTML = "";
        if (current.length === 0) {
          input.setAttribute("aria-expanded", "false");
          hint.hidden = false;
          hint.textContent = "No matches for “" + query + "”.";
          return;
        }
        hint.hidden = true;
        input.setAttribute("aria-expanded", "true");
        current.forEach(function (e, i) {
          var li = document.createElement("li");
          var a = document.createElement("a");
          a.className = "ps-result";
          a.href = e.url;
          a.setAttribute("role", "option");
          a.id = "ps-result-" + i;
          var crumb = e.kind === "house" ? "" : e.play ? e.house + " · " + e.play : e.house || "";
          a.innerHTML =
            '<span class="ps-result-head">' +
            '<span class="ps-result-kind">' +
            (KIND_LABEL[e.kind] || e.kind) +
            "</span>" +
            '<span class="ps-result-title">' +
            highlight(e.title, tokens) +
            "</span>" +
            (crumb ? '<span class="ps-result-crumb">' + escapeHtml(crumb) + "</span>" : "") +
            "</span>" +
            (e.text ? '<p class="ps-result-text">' + highlight(e.text, tokens) + "</p>" : "");
          li.appendChild(a);
          results.appendChild(li);
        });
      }

      function setActive(next) {
        var items = results.querySelectorAll(".ps-result");
        if (!items.length) return;
        if (active >= 0 && items[active]) items[active].classList.remove("is-active");
        active = (next + items.length) % items.length;
        var el = items[active];
        el.classList.add("is-active");
        el.scrollIntoView({ block: "nearest" });
        input.setAttribute("aria-activedescendant", el.id);
      }

      function open() {
        load();
        overlay.hidden = false;
        trigger.setAttribute("aria-expanded", "true");
        document.documentElement.style.overflow = "hidden";
        input.focus();
        input.select();
      }

      function close() {
        overlay.hidden = true;
        trigger.setAttribute("aria-expanded", "false");
        input.removeAttribute("aria-activedescendant");
        document.documentElement.style.overflow = "";
        trigger.focus();
      }

      var debounce;
      input.addEventListener("input", function () {
        clearTimeout(debounce);
        debounce = setTimeout(function () {
          run(input.value);
        }, 90);
      });

      input.addEventListener("keydown", function (ev) {
        if (ev.key === "ArrowDown") {
          ev.preventDefault();
          setActive(active + 1);
        } else if (ev.key === "ArrowUp") {
          ev.preventDefault();
          setActive(active - 1);
        } else if (ev.key === "Enter") {
          var items = results.querySelectorAll(".ps-result");
          if (active >= 0 && items[active]) {
            ev.preventDefault();
            window.location.href = items[active].href;
          }
        } else if (ev.key === "Escape") {
          ev.preventDefault();
          close();
        }
      });

      trigger.addEventListener("click", open);
      if (closeBtn) closeBtn.addEventListener("click", close);
      if (backdrop) backdrop.addEventListener("click", close);

      // "/" opens search from anywhere on the bill (unless typing in a field).
      document.addEventListener("keydown", function (ev) {
        if (ev.key === "/" && overlay.hidden) {
          var tag = (document.activeElement && document.activeElement.tagName) || "";
          if (tag === "INPUT" || tag === "TEXTAREA") return;
          ev.preventDefault();
          open();
        }
      });
    })();
  </script>
</BaseLayout>
