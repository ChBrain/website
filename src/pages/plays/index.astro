---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Shelf, { type ShelfCard } from "../../components/Shelf.astro";
import { loadRegistry } from "@chbrain/khai-plays";
import { loadAllPlays } from "../../lib/load-plays";
// MOCK -- REMOVE WHEN THE FIRST HOUSE REGISTERS (see ./_mock).
import { MOCK_HOUSES } from "./_mock";
import { URLS } from "../../lib/urls";

const houses = loadRegistry();
const plays = loadAllPlays();

// Fallback to mock houses only if the registry is completely empty (should not happen since buechner is registered)
const bill = houses.length ? houses : MOCK_HOUSES;

const cards: ShelfCard[] = bill.map((h: (typeof bill)[number]) => {
  const isInstalled = plays.some((p) => p.houseId === h.id);

  return {
    href: isInstalled ? `/plays/${h.id}/` : h.repo,
    external: !isInstalled,
    eyebrow: h.package,
    state: isInstalled ? "active · a khai-plays collection" : "work in progress",
    title: h.title,
    note: isInstalled ? h.blurb : `${h.blurb} Grimm is still in progress.`,
    cta: isInstalled ? "Enter the house →" : "Visit repository →",
    downloadHref: isInstalled ? `${URLS.plays}downloads/` : undefined,
    downloadCta: isInstalled ? "Download plays →" : undefined,
  };
});
---

<BaseLayout
  title="Plays · kaihacks"
  description="The bill of houses: each a khai-plays collection the website reads, its plays inside."
>
  <Shelf
    domain="plays"
    location="the bill"
    sectionLabel="§ · the productions"
    title="KHAI Plays"
    accent="Plays"
    sectionNo="§1"
    sectionTitle="The houses"
    sectionNote="the bill"
    cards={cards}
    empty="No houses registered yet."
  >
    <Fragment slot="subline">
      The bill of houses. khai holds the index, not the productions: each house is a
      <code>khai-plays-&lt;source&gt;</code> collection, and the website reads its programme. The bill
      is the list; the plays live in the houses.
    </Fragment>
  </Shelf>
</BaseLayout>
