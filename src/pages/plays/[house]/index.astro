---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Shelf, { type ShelfCard } from "../../../components/Shelf.astro";
import { loadRegistry } from "@chbrain/khai-plays";
import { loadAllPlays } from "../../../lib/load-plays";
// MOCK -- REMOVE WHEN THE FIRST HOUSE REGISTERS (see ../_mock).
import { MOCK_HOUSES } from "../_mock";
import { URLS } from "../../../lib/urls";

export function getStaticPaths() {
  const realHouses = loadRegistry();
  const realPaths = realHouses.map((house) => ({
    params: { house: house.id },
    props: { house },
  }));

  const realHouseIds = new Set(realHouses.map((h) => h.id));
  const mockPaths = MOCK_HOUSES.filter((mh) => !realHouseIds.has(mh.id)).map((house) => ({
    params: { house: house.id },
    props: { house },
  }));

  return [...realPaths, ...mockPaths];
}

const { house } = Astro.props;
const repoLabel = house.repo.replace(/^https?:\/\//, "");

// Determine if we load real plays or fall back to mock
const allRealPlays = loadAllPlays();
const realPlays = allRealPlays.filter((p) => p.houseId === house.id);
const isInstalled = realPlays.length > 0;

// Fallback to mock plays only if this house is not installed
const mockHouse = MOCK_HOUSES.find((mh) => mh.id === house.id);
const playsToRender = isInstalled ? realPlays : (mockHouse?.plays ?? []);

const stripHtml = (html: string) => html.replace(/<[^>]+>/g, "").trim();

const cards: ShelfCard[] = playsToRender.map((p) => {
  let note = "";
  const mockPlay = mockHouse?.plays.find((mp) => mp.id === p.id);

  if (mockPlay) {
    note = mockPlay.blurb;
  } else if (isInstalled) {
    const realPlay = p as (typeof realPlays)[number];
    const rawNote = realPlay.description || realPlay.sections.arc || realPlay.sections.name || "";
    note = stripHtml(rawNote);
    if (note.length > 160) {
      note = note.slice(0, 160) + "...";
    }
  } else {
    note = (p as any).blurb || "";
  }

  return {
    href: `/plays/${house.id}/${p.id}/`,
    eyebrow: house.package,
    state: "play",
    title: p.title,
    note,
    cta: "Open the playbook →",
    downloadHref: isInstalled ? `${URLS.plays}downloads/plays/${house.id}/${p.id}.zip` : undefined,
    downloadCta: "Download playbook →",
  };
});
---

<BaseLayout title={`${house.title} · Plays · kaihacks`} description={house.blurb}>
  <Shelf
    domain="plays"
    location={house.id}
    sectionLabel="§ · a house"
    title={`KHAI plays ${house.title}`}
    accent="plays"
    sectionNo="§1"
    sectionTitle="The plays"
    sectionNote={house.package}
    cards={cards}
    empty="No plays in this house yet."
  >
    <Fragment slot="subline">
      {house.blurb} The house lives at <a href={house.repo} rel="external">{repoLabel}</a>.
    </Fragment>
  </Shelf>
</BaseLayout>
