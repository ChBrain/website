---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Book from "../../../../components/Book.astro";
import type { BookSpread, BookFacet } from "../../../../lib/book";
import { loadRegistry } from "@chbrain/khai-plays";
import { loadAllPlays } from "../../../../lib/load-plays";
import { URLS } from "../../../../lib/urls";
// MOCK -- REMOVE WHEN THE FIRST HOUSE REGISTERS (see ../../_mock). A real
// playbook's spreads come from the house's programme package; these placeholders
// render the shared Book chassis while the khai-plays registry is empty.
import { MOCK_HOUSES } from "../../_mock";
import { existsSync, readFileSync } from "node:fs";
import { join } from "node:path";

function extractCompanyCategory(companyHtml: string, categoryName: string): string {
  if (!companyHtml) return "";
  const regex = new RegExp(
    `<p>(?:<strong>)?\\s*${categoryName}\\s*:?\\s*(?:</strong>)?</p>\\s*<ul>([\\s\\S]*?)</ul>`,
    "i",
  );
  const match = companyHtml.match(regex);
  if (match) {
    return `<ul>${match[1]}</ul>`;
  }
  return "";
}

export function getStaticPaths() {
  const realPlays = loadAllPlays();
  const houses = loadRegistry();

  const realPaths = realPlays.map((play) => {
    const house = houses.find((h) => h.id === play.houseId)!;
    return {
      params: { house: play.houseId, play: play.id },
      props: { house, play, isReal: true },
    };
  });

  const installedHouseIds = new Set(realPlays.map((play) => play.houseId));
  const mockPaths = MOCK_HOUSES.filter((mh) => !installedHouseIds.has(mh.id)).flatMap((house) =>
    house.plays.map((play) => ({
      params: { house: house.id, play: play.id },
      props: { house, play, isReal: false },
    })),
  );

  return [...realPaths, ...mockPaths];
}

const { house, play, isReal } = Astro.props;

let spreads: BookSpread[] = [];
let voiceRegister = "editorial"; // default voice
let overline = "khai plays · a playbook";
let title = "";
let subtitle = "";
let ctaHref = "";
let ctaLabel = "Open the playbook →";

if (isReal) {
  const realPlay = play as any;
  voiceRegister = realPlay.voiceRegister;
  // The book is the production in its declared (original) language; the shelf
  // carries the English title, the book reads the declared name.
  title = realPlay.declared;
  ctaHref = `#synopsis`;

  // 1. Consolidated Synopsis spread (Name, Arc, Stakes, Estate). The book is in
  // the production's declared language, so it does NOT lead with the registry
  // `description` (that logline is the English shelf copy); the German `## Arc`
  // is the synopsis the book reads.
  let synopsisHtml = "";
  if (realPlay.sections.name) {
    synopsisHtml += `<h3>Name</h3>${realPlay.sections.name}`;
  }
  if (realPlay.sections.arc) {
    synopsisHtml += `<h3>Arc</h3>${realPlay.sections.arc}`;
  }
  if (realPlay.sections.stakes) {
    synopsisHtml += `<h3>Stakes</h3>${realPlay.sections.stakes}`;
  }
  if (realPlay.sections.estate) {
    synopsisHtml += `<h3>Estate</h3>${realPlay.sections.estate}`;
  }
  if (!synopsisHtml) {
    synopsisHtml = `<p>No synopsis provided.</p>`;
  }

  spreads.push({
    slug: "synopsis",
    n: "00",
    groupLabel: "the play",
    status: "synopsis",
    title: "Synopsis",
    facets: [],
    bodyHtml: synopsisHtml,
    coda: null,
  });

  let counter = 1;
  const nextN = () => String(counter++).padStart(2, "0");

  // 2. Company spreads grouped by type
  const TYPE_SPECS = [
    { type: "plot", slug: "plots", title: "Plots" },
    { type: "persona", slug: "personas", title: "Personas" },
    { type: "place", slug: "places", title: "Places" },
    { type: "piece", slug: "pieces", title: "Pieces" },
    { type: "position", slug: "positions", title: "Positions" },
    { type: "process", slug: "processes", title: "Processes" },
    { type: "plan", slug: "plans", title: "Plans" },
  ];

  const COMPANY_MAP: Record<string, string> = {
    persona: "Personen",
    place: "Orte",
    piece: "Dinge",
    position: "Positionen",
    process: "Prozesse",
    plan: "Pläne",
  };

  if (realPlay.elements && realPlay.elements.length > 0) {
    for (const spec of TYPE_SPECS) {
      const groupElements = realPlay.elements.filter((el: any) => el.type === spec.type);
      if (groupElements.length === 0) continue;

      // Chapter Intro Spread
      let introBodyHtml = "";
      if (spec.type === "plot") {
        introBodyHtml = realPlay.sections.triggers || "";
      } else {
        introBodyHtml = extractCompanyCategory(
          realPlay.sections.company || "",
          COMPANY_MAP[spec.type],
        );
      }

      spreads.push({
        slug: spec.slug,
        n: nextN(),
        groupLabel: spec.title.toLowerCase(),
        groupHref: `/architecture/${spec.type}/`,
        status: realPlay.voiceRegister,
        title: spec.title,
        facets: [],
        bodyHtml: introBodyHtml,
        classModifier: `voice-${realPlay.voiceRegister}`,
      });

      // Individual Element Spreads (2x2 facet grids)
      for (const el of groupElements) {
        const facets: BookFacet[] = Object.entries(el.sections)
          .filter(([heading]) => heading !== "taxonomy" && heading !== "owner")
          .map(([heading, html]) => {
            const titleCap = heading.charAt(0).toUpperCase() + heading.slice(1);
            return {
              letter: titleCap.charAt(0),
              name: titleCap,
              body: "",
              bodyHtml: html as string,
            };
          });

        spreads.push({
          slug: `el-${el.id}`,
          n: nextN(),
          groupLabel: el.type,
          groupHref: `/architecture/${el.type}/`,
          status: el.voiceRegister,
          title: el.declared,
          subtitle: el.voice ? `voice: "${el.voice}"` : null,
          facets,
          classModifier: `voice-${el.voiceRegister}`,
        });
      }
    }
  }

  // 3. Reference Warrant spreads (snap split by chapter (##))
  if (realPlay.reference) {
    const keys = Object.keys(realPlay.reference.sections);
    keys.forEach((heading, i) => {
      const html = realPlay.reference.sections[heading];
      const titleCap = heading
        .split(" ")
        .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
        .join(" ");
      const isLast = i === keys.length - 1;

      spreads.push({
        slug: `ref-${heading
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/-+/g, "-")
          .replace(/^-|-$/g, "")}`,
        n: nextN(),
        groupLabel: "reference",
        status: "warrant",
        title: titleCap,
        facets: [],
        bodyHtml: html,
        coda: isLast ? `updated: ${realPlay.reference.updated}` : null,
      });
    });
  }

  // Download cover spread
  const jsonPath = join(
    process.cwd(),
    "public",
    "downloads",
    "plays",
    realPlay.houseId,
    `${realPlay.id}.json`,
  );
  if (existsSync(jsonPath)) {
    try {
      const sidecar = JSON.parse(readFileSync(jsonPath, "utf-8"));
      spreads.push({
        slug: "download",
        n: nextN(),
        groupLabel: "download",
        status: "artifact",
        title: "Download Playbook",
        facets: [],
        download: {
          href: `${URLS.plays}downloads/plays/${realPlay.houseId}/${realPlay.id}.zip`,
          filename: `${realPlay.id}.zip`,
          size: sidecar.size,
          sha256: sidecar.sha256,
          note: `Includes the play configuration and all staged elements.`,
        },
      });
    } catch (e) {
      console.error("Failed to load play sidecar JSON:", e);
    }
  }
} else {
  // Mock fallback
  title = play.title;
  subtitle = play.blurb;
  ctaHref = `#synopsis`;

  spreads = [
    {
      slug: "synopsis",
      n: "00",
      groupLabel: "the play",
      status: "synopsis",
      title: "Synopsis",
      facets: [],
      bodyHtml: `<p>${play.blurb}</p>`,
      coda: null,
    },
    {
      slug: "house",
      n: "01",
      groupLabel: "the house",
      status: "mock",
      title: "From the house",
      facets: [],
      bodyHtml: `<p>The full playbook is generated from the house's programme package (<code>${house.package}</code>) and read here. This is a placeholder while the khai-plays registry is empty.</p>`,
      coda: null,
    },
  ];
}
---

<BaseLayout title={`${title} · KHAI Plays · kaihacks`} description={subtitle}>
  <div class={`voice-${voiceRegister}`}>
    <Book
      header={{ domain: "plays", tld: ".kaihacks.ai", location: `${house.id} · ${play.id}` }}
      cover={{
        overline,
        title,
        subtitle,
        edition: house.title,
        ctaHref,
        ctaLabel,
        backHref: "../",
        backLabel: `← ${house.title}`,
      }}
      spreads={spreads}
      tocEyebrow={`playbook · ${play.id}`}
    />
  </div>
</BaseLayout>
