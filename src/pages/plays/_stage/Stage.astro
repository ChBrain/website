---
// The Stage: a full-bleed theatrical view of one play. Underscore-pathed
// (src/pages/plays/_stage/) so Astro keeps it out of routing; it is a
// plays-surface component, rendered by [house]/[play]/stage/index.astro.
//
// Four states, toggled client-side (single page, no route change):
//   closed  — curtains drawn, the playbill; the resting state.
//   backstage — the call board overlay (left panel / phone bottom sheet),
//               cast/set/props from the play's real elements.
//   open    — curtains parted, the mocked scene + the (static) Souffleur.
// The scene is a rehearsal placeholder (see _stage/scene.ts); wiring the
// Souffleur to actually drive it is the later integration work.
import type { Company, Scene } from "./scene";

interface Props {
  title: string;
  houseTitle: string;
  voiceRegister: string;
  backHref: string;
  company: Company;
  scene: Scene;
}

const { title, houseTitle, voiceRegister, backHref, company, scene } = Astro.props;
const { cast, set, props } = company;

const stagedCast = new Set(scene.staged.castIds);
const stagedPlace = scene.staged.placeId;
const stagedProp = scene.staged.propId;

const bulbs = Array.from({ length: 18 });
---

<section class={`stage voice-${voiceRegister} is-closed`} id="stage" data-state="closed">
  <header class="stage-head">
    <a class="brand" href={backHref} aria-label="Back to the playbook">
      <span class="brand-k" aria-hidden="true">k</span>
      <span class="brand-title">{title}</span>
    </a>
    <button
      class="backstage-btn"
      id="backstage-btn"
      aria-controls="backstage"
      aria-expanded="false"
    >
      <span class="bs-ico" aria-hidden="true">‖</span> BACKSTAGE
    </button>
  </header>

  <div class="house">
    <div class="vignette" aria-hidden="true"></div>

    <!-- the open scene (revealed when the curtain parts) -->
    <div class="scene" id="scene">
      <div class="scene-inner">
        <p class="scene-act">{scene.act} · {scene.scene}</p>
        <hr class="scene-rule" />
        {
          scene.beats.map((b) =>
            b.type === "direction" ? (
              <p class="beat-dir">{b.text}</p>
            ) : (
              <div class="beat-line">
                <p class="cue">
                  <span class="cue-dot" aria-hidden="true">
                    •
                  </span>
                  {b.cue}
                </p>
                <p class="say">{b.text}</p>
              </div>
            ),
          )
        }
      </div>
    </div>

    <!-- the theatre frame -->
    <div class="curtain curtain-left" aria-hidden="true"></div>
    <div class="curtain curtain-right" aria-hidden="true"></div>
    <div class="valance" aria-hidden="true"></div>
    <div class="tieback tieback-left" aria-hidden="true"></div>
    <div class="tieback tieback-right" aria-hidden="true"></div>

    <!-- closed-state playbill -->
    <div class="playbill" id="playbill">
      <p class="playbill-eyebrow">khai · the stage</p>
      <h1 class="playbill-title">{title}</h1>
      <p class="playbill-sub">{houseTitle}</p>
      <button class="raise raise-front" id="raise-front" type="button">
        <span class="raise-main">Raise the Curtain</span>
        <span class="raise-ar" aria-hidden="true">▲▲</span>
      </button>
      <button class="playbill-backstage" id="playbill-backstage" type="button">
        or step backstage →
      </button>
    </div>

    <!-- footlights, wings, apron -->
    <div class="footlights" aria-hidden="true">{bulbs.map(() => <span class="bulb" />)}</div>
    <span class="wing wing-left" aria-hidden="true">WINGS</span>
    <span class="wing wing-right" aria-hidden="true">WINGS</span>
    <span class="apron-label" aria-hidden="true">APRON · FORESTAGE</span>

    <!-- souffleur (open state) -->
    <div class="souffleur" id="souffleur">
      <div class="souffleur-bar">
        <span class="souffleur-label">PROMPT BOX · SOUFFLEUR</span>
        <span class="souffleur-meta">STAGE DIRECTION</span>
      </div>
      <div class="souffleur-field">
        <input
          class="souffleur-input"
          type="text"
          placeholder="Whisper a direction to the players…"
          aria-label="Whisper a direction to the players"
          disabled
        />
        <button class="cue" type="button" disabled>CUE</button>
      </div>
      <div class="chips">
        <span class="chip">The Abyss</span>
        <span class="chip">A Sudden Movement</span>
        <span class="chip">Nature Answers</span>
      </div>
      <p class="souffleur-note">The souffleur sleeps · this scene is a rehearsal placeholder.</p>
    </div>
  </div>

  <!-- backstage overlay -->
  <div class="backstage" id="backstage" hidden>
    <div class="backstage-scrim" id="backstage-scrim"></div>
    <aside class="callboard" role="dialog" aria-modal="true" aria-label="Backstage call board">
      <div class="cb-head">
        <div>
          <p class="cb-title">BACKSTAGE</p>
          <p class="cb-sub">CALL BOARD · ENTER FROM THE WINGS</p>
        </div>
        <button class="cb-close" id="cb-close" type="button" aria-label="Close backstage">×</button>
      </div>

      <div class="cb-scroll">
        <section class="cb-section">
          <p class="cb-section-head">
            <span class="cb-sec-dot" aria-hidden="true"></span>
            DRESSING ROOMS
            <span class="cb-meta">CAST · {cast.length}</span>
          </p>
          {
            cast.length ? (
              cast.map((it) => (
                <div class={`cb-item${stagedCast.has(it.id) ? " is-staged" : ""}`}>
                  <div class="cb-item-row">
                    <span class="cb-item-name">{it.name}</span>
                    {stagedCast.has(it.id) && <span class="cb-badge">IN THE WINGS</span>}
                  </div>
                  {it.blurb && <p class="cb-item-blurb">{it.blurb}</p>}
                </div>
              ))
            ) : (
              <p class="cb-empty">No cast listed.</p>
            )
          }
        </section>

        <section class="cb-section">
          <p class="cb-section-head">
            <span class="cb-sec-dot" aria-hidden="true"></span>
            THE SET
            <span class="cb-meta">BACKDROP · {set.length}</span>
          </p>
          {
            set.length ? (
              set.map((it) => (
                <div class={`cb-item${stagedPlace === it.id ? " is-staged" : ""}`}>
                  <div class="cb-item-row">
                    <span class="cb-item-name">{it.name}</span>
                    {stagedPlace === it.id && <span class="cb-badge">ON STAGE</span>}
                  </div>
                  {it.blurb && <p class="cb-item-blurb">{it.blurb}</p>}
                </div>
              ))
            ) : (
              <p class="cb-empty">No set listed.</p>
            )
          }
        </section>

        <section class="cb-section">
          <p class="cb-section-head">
            <span class="cb-sec-dot" aria-hidden="true"></span>
            PROP TABLE
            <span class="cb-meta">PROPERTIES · {props.length}</span>
          </p>
          {
            props.length ? (
              props.map((it) => (
                <div class={`cb-item${stagedProp === it.id ? " is-staged" : ""}`}>
                  <div class="cb-item-row">
                    <span class="cb-item-name">{it.name}</span>
                    {stagedProp === it.id && <span class="cb-badge">IN PLAY</span>}
                  </div>
                  {it.blurb && <p class="cb-item-blurb">{it.blurb}</p>}
                </div>
              ))
            ) : (
              <p class="cb-empty">No props listed.</p>
            )
          }
        </section>
      </div>

      <button class="raise raise-cb" id="raise-cb" type="button" data-mode="raise">
        <span class="raise-main">Raise the Curtain</span>
        <span class="raise-sub">CAST · SET · BEGIN</span>
        <span class="raise-ar" aria-hidden="true">▲▲</span>
      </button>
    </aside>
  </div>
</section>

<style>
  /* local theatre palette — the stage breaks the paper/ink system on purpose */
  .stage {
    /* the theatre is dark, but every shade is derived from the canonical
       tokens (ink/brick/amber/paper) via color-mix — no off-palette hex. */
    --stage-bg: color-mix(in srgb, var(--color-ink) 86%, black);
    --stage-glow: color-mix(in srgb, var(--color-brick) 22%, var(--color-ink));
    --stage-fg: var(--color-paper);
    --stage-fg-soft: color-mix(in srgb, var(--color-paper) 64%, var(--color-ink));
    --stage-fg-mute: color-mix(in srgb, var(--color-paper) 42%, var(--color-ink));
    --curtain-a: color-mix(in srgb, var(--color-brick) 85%, black);
    --curtain-b: color-mix(in srgb, var(--color-brick) 52%, black);
    --foot: color-mix(in srgb, var(--color-amber) 72%, white);
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overflow: hidden;
    color: var(--stage-fg);
    background:
      radial-gradient(120% 80% at 50% -10%, var(--stage-glow), transparent 60%), var(--stage-bg);
    font-family: var(--font-prose);
  }

  /* header */
  .stage-head {
    position: relative;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-paper) 6%, transparent);
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--color-ink) 50%, transparent),
      transparent
    );
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--stage-fg);
  }
  .brand-k {
    display: inline-grid;
    place-items: center;
    width: 22px;
    height: 22px;
    font-family: var(--font-display);
    font-size: 15px;
    border: 1px solid var(--stage-fg-soft);
    color: var(--stage-fg);
  }
  .brand-title {
    font-family: var(--font-display);
    font-size: 17px;
    letter-spacing: 0.01em;
  }
  .backstage-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--stage-fg);
    background: color-mix(in srgb, var(--color-ink) 35%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-paper) 16%, transparent);
    padding: 0.45rem 0.7rem;
    cursor: pointer;
  }
  .backstage-btn:hover {
    border-color: var(--curtain-a);
  }
  .bs-ico {
    color: var(--curtain-a);
    font-size: 12px;
  }

  /* the stage box */
  .house {
    position: relative;
    flex: 1;
    overflow: hidden;
  }
  .vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow: inset 0 0 220px 60px color-mix(in srgb, var(--color-ink) 70%, transparent);
    z-index: 5;
  }

  /* scene */
  .scene {
    position: absolute;
    inset: 0;
    z-index: 6;
    overflow-y: auto;
    padding: 2.5rem 1.25rem 8.5rem;
    opacity: 0;
    transition: opacity 0.5s ease 0.35s;
  }
  .stage.is-open .scene {
    opacity: 1;
  }
  .scene-inner {
    max-width: 600px;
    margin: 0 auto;
  }
  .scene-act {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--stage-fg-mute);
    margin: 0;
  }
  .scene-rule {
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-paper) 10%, transparent);
    margin: 0.9rem 0 1.6rem;
  }
  .beat-dir {
    font-family: var(--font-prose);
    font-style: italic;
    font-size: 15px;
    line-height: 1.55;
    color: var(--stage-fg-soft);
    border-left: 2px solid var(--curtain-a);
    padding-left: 0.8rem;
    margin: 1.4rem 0;
  }
  .beat-line {
    margin: 1.2rem 0;
  }
  .cue {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0 0 0.25rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--stage-fg-soft);
  }
  .cue-dot {
    color: var(--curtain-a);
  }
  .say {
    margin: 0;
    font-family: var(--font-display);
    font-size: 19px;
    line-height: 1.4;
    color: var(--stage-fg);
  }

  /* curtains */
  .curtain {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 52%;
    z-index: 14;
    background:
      repeating-linear-gradient(
        90deg,
        color-mix(in srgb, var(--color-ink) 45%, transparent) 0,
        color-mix(in srgb, var(--color-paper) 5%, transparent) 14px,
        color-mix(in srgb, var(--color-ink) 45%, transparent) 30px
      ),
      linear-gradient(to bottom, var(--curtain-a), var(--curtain-b));
    box-shadow: inset 0 -40px 80px color-mix(in srgb, var(--color-ink) 50%, transparent);
    transition: transform 0.9s cubic-bezier(0.7, 0, 0.2, 1);
    will-change: transform;
  }
  .curtain-left {
    left: 0;
  }
  .curtain-right {
    right: 0;
  }
  .stage.is-open .curtain-left {
    transform: translateX(-86%);
  }
  .stage.is-open .curtain-right {
    transform: translateX(86%);
  }
  .valance {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 42px;
    z-index: 16;
    background: linear-gradient(to bottom, var(--curtain-a), var(--curtain-b));
    box-shadow:
      0 6px 14px color-mix(in srgb, var(--color-ink) 50%, transparent),
      inset 0 -6px 16px color-mix(in srgb, var(--color-ink) 40%, transparent);
  }
  .tieback {
    position: absolute;
    top: 46%;
    width: 12%;
    height: 8px;
    border-radius: 4px;
    z-index: 17;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--color-brick) 95%, white),
      var(--curtain-b)
    );
    box-shadow: 0 2px 6px color-mix(in srgb, var(--color-ink) 50%, transparent);
    opacity: 0;
    transition: opacity 0.4s ease 0.5s;
  }
  .tieback-left {
    left: 0.5%;
  }
  .tieback-right {
    right: 0.5%;
  }
  .stage.is-open .tieback {
    opacity: 1;
  }

  /* playbill (closed) */
  .playbill {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 20;
    width: min(90%, 460px);
    text-align: center;
    transition:
      opacity 0.45s ease,
      transform 0.45s ease;
  }
  .stage.is-open .playbill {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.96);
    pointer-events: none;
  }
  .playbill-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--foot);
    margin: 0 0 0.6rem;
  }
  .playbill-title {
    font-family: var(--font-display);
    font-weight: 350;
    font-size: clamp(40px, 9vw, 84px);
    line-height: 0.96;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-paper-warm);
  }
  .playbill-sub {
    font-family: var(--font-prose);
    font-style: italic;
    font-size: 16px;
    color: var(--stage-fg-soft);
    margin: 0.8rem 0 1.8rem;
  }
  .playbill-backstage {
    display: block;
    margin: 1rem auto 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--stage-fg-mute);
    background: none;
    border: none;
    cursor: pointer;
  }
  .playbill-backstage:hover {
    color: var(--stage-fg);
  }

  /* raise buttons */
  .raise {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    cursor: pointer;
    color: var(--color-paper-warm);
    background: linear-gradient(to bottom, var(--color-brick), var(--curtain-b));
    border: 1px solid color-mix(in srgb, var(--color-ink) 30%, transparent);
    box-shadow: 0 10px 30px -12px color-mix(in srgb, var(--color-ink) 80%, transparent);
    transition:
      transform 0.16s,
      filter 0.16s;
  }
  .raise:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
  }
  .raise-main {
    font-family: var(--font-display);
    font-size: 19px;
  }
  .raise-sub,
  .raise-ar {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    opacity: 0.85;
  }
  .raise-front {
    padding: 0.7rem 1.6rem;
  }
  .raise-front .raise-ar {
    margin-top: 2px;
  }

  /* footlights / wings / apron */
  .footlights {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 30px;
    z-index: 18;
    display: flex;
    justify-content: center;
    gap: clamp(14px, 3.4vw, 40px);
    pointer-events: none;
  }
  .bulb {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--foot);
    box-shadow:
      0 0 10px 3px color-mix(in srgb, var(--color-amber) 50%, transparent),
      0 0 22px 8px color-mix(in srgb, var(--color-amber) 20%, transparent);
  }
  .wing,
  .apron-label {
    position: absolute;
    z-index: 18;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.22em;
    color: var(--stage-fg-mute);
    opacity: 0.6;
  }
  .wing-left {
    left: 1rem;
    bottom: 52px;
  }
  .wing-right {
    right: 1rem;
    bottom: 52px;
  }
  .apron-label {
    left: 1rem;
    bottom: 12px;
  }

  /* souffleur */
  .souffleur {
    position: absolute;
    left: 50%;
    bottom: 18px;
    transform: translate(-50%, 18px);
    z-index: 24;
    width: min(92%, 560px);
    padding: 0.7rem 0.85rem 0.85rem;
    background: color-mix(in srgb, var(--color-ink) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-paper) 12%, transparent);
    box-shadow: 0 18px 50px -20px color-mix(in srgb, var(--color-ink) 90%, transparent);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.4s ease 0.5s,
      transform 0.4s ease 0.5s;
  }
  .stage.is-open .souffleur {
    opacity: 1;
    transform: translate(-50%, 0);
    pointer-events: auto;
  }
  .souffleur-bar {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--stage-fg-mute);
    margin-bottom: 0.5rem;
  }
  .souffleur-field {
    display: flex;
    gap: 0.5rem;
  }
  .souffleur-input {
    flex: 1;
    min-width: 0;
    font-family: var(--font-prose);
    font-style: italic;
    font-size: 14px;
    color: var(--stage-fg-soft);
    background: color-mix(in srgb, var(--color-ink) 35%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-paper) 12%, transparent);
    padding: 0.5rem 0.7rem;
  }
  .cue {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-paper-warm);
    background: linear-gradient(to bottom, var(--color-brick), var(--curtain-b));
    border: none;
    padding: 0 1.1rem;
    cursor: not-allowed;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }
  .chip {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--stage-fg-soft);
    border: 1px solid color-mix(in srgb, var(--color-paper) 14%, transparent);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
  }
  .souffleur-note {
    margin: 0.6rem 0 0;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.06em;
    color: var(--stage-fg-mute);
  }

  /* backstage overlay */
  .backstage[hidden] {
    display: none;
  }
  .backstage {
    position: fixed;
    inset: 0;
    z-index: 60;
  }
  .backstage-scrim {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-ink) 55%, transparent);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .backstage.is-open .backstage-scrim {
    opacity: 1;
  }
  .callboard {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(86%, 360px);
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    color: var(--color-ink);
    border-right: 1px solid var(--color-ink);
    box-shadow: 24px 0 60px -30px color-mix(in srgb, var(--color-ink) 80%, transparent);
    transform: translateX(-100%);
    transition: transform 0.32s cubic-bezier(0.5, 0, 0.2, 1);
  }
  .backstage.is-open .callboard {
    transform: translateX(0);
  }
  .cb-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1rem 1.1rem 0.75rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .cb-title {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    margin: 0;
    color: var(--color-ink);
  }
  .cb-sub {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    color: var(--color-ink-mute);
    margin: 0.25rem 0 0;
  }
  .cb-close {
    font-size: 18px;
    line-height: 1;
    color: var(--color-ink-soft);
    background: none;
    border: 1px solid var(--color-rule);
    border-radius: 50%;
    width: 24px;
    height: 24px;
    cursor: pointer;
  }
  .cb-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 1.1rem 1rem;
  }
  .cb-section {
    margin-top: 1rem;
  }
  .cb-section-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--color-ink-soft);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 0.4rem;
    margin: 0 0 0.5rem;
  }
  .cb-sec-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-brick);
  }
  .cb-meta {
    margin-left: auto;
    color: var(--color-ink-mute);
    letter-spacing: 0.1em;
  }
  .cb-item {
    padding: 0.5rem 0.6rem;
    border-left: 2px solid transparent;
  }
  .cb-item.is-staged {
    border-left-color: var(--color-brick);
    background: var(--color-paper-warm);
  }
  .cb-item-row {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .cb-item-name {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--color-ink);
  }
  .cb-badge {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.14em;
    color: var(--color-brick);
    white-space: nowrap;
  }
  .cb-item-blurb {
    margin: 0.15rem 0 0;
    font-family: var(--font-prose);
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--color-ink-soft);
  }
  .cb-empty {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-mute);
    padding: 0.4rem 0.6rem;
  }
  .raise-cb {
    margin: 0;
    width: 100%;
    border: none;
    border-radius: 0;
    padding: 0.85rem 1rem;
  }

  /* phone: backstage becomes a bottom sheet */
  @media (max-width: 640px) {
    .callboard {
      top: auto;
      left: 0;
      right: 0;
      width: 100%;
      max-height: 84vh;
      border-right: none;
      border-top: 1px solid var(--color-ink);
      transform: translateY(100%);
    }
    .backstage.is-open .callboard {
      transform: translateY(0);
    }
    .brand-title {
      max-width: 48vw;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .scene {
      padding-top: 4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .curtain,
    .scene,
    .playbill,
    .souffleur,
    .callboard,
    .tieback,
    .backstage-scrim {
      transition: none;
    }
  }
</style>

<style is:global>
  /* the stage is full-bleed: drop BaseLayout's paper padding and prose width,
     and let the dark theatre own the whole viewport. */
  body:has(.stage) {
    padding: 0;
    background: color-mix(in srgb, var(--color-ink) 88%, black);
  }
  body:has(.stage) main {
    max-width: none;
    margin: 0;
  }
</style>

<script is:inline>
  (function () {
    var stage = document.getElementById("stage");
    var backstage = document.getElementById("backstage");
    var bsBtn = document.getElementById("backstage-btn");
    if (!stage || !backstage) return;
    var raiseCb = document.getElementById("raise-cb");
    var raiseCbMain = raiseCb ? raiseCb.querySelector(".raise-main") : null;
    var closeTimer;

    function isOpen() {
      return stage.classList.contains("is-open");
    }
    function syncRaise() {
      if (!raiseCb) return;
      var open = isOpen();
      if (raiseCbMain) raiseCbMain.textContent = open ? "Lower the Curtain" : "Raise the Curtain";
      raiseCb.setAttribute("data-mode", open ? "lower" : "raise");
    }
    function openBackstage() {
      clearTimeout(closeTimer);
      backstage.hidden = false;
      requestAnimationFrame(function () {
        backstage.classList.add("is-open");
      });
      bsBtn.setAttribute("aria-expanded", "true");
      syncRaise();
    }
    function closeBackstage() {
      backstage.classList.remove("is-open");
      bsBtn.setAttribute("aria-expanded", "false");
      closeTimer = setTimeout(function () {
        backstage.hidden = true;
      }, 320);
    }
    function toggleBackstage() {
      backstage.hidden ? openBackstage() : closeBackstage();
    }
    function setState(open) {
      stage.classList.toggle("is-open", open);
      stage.classList.toggle("is-closed", !open);
      stage.setAttribute("data-state", open ? "open" : "closed");
      closeBackstage();
    }

    bsBtn.addEventListener("click", toggleBackstage);

    var cbClose = document.getElementById("cb-close");
    var scrim = document.getElementById("backstage-scrim");
    var playbillBs = document.getElementById("playbill-backstage");
    var raiseFront = document.getElementById("raise-front");
    if (cbClose) cbClose.addEventListener("click", closeBackstage);
    if (scrim) scrim.addEventListener("click", closeBackstage);
    if (playbillBs) playbillBs.addEventListener("click", openBackstage);
    if (raiseFront)
      raiseFront.addEventListener("click", function () {
        setState(true);
      });
    if (raiseCb)
      raiseCb.addEventListener("click", function () {
        setState(!isOpen());
      });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !backstage.hidden) closeBackstage();
    });
  })();
</script>
