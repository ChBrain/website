      font-family: var(--font-prose);
      font-style: italic;
      font-size: 16px;
      line-height: 1.6;
      color: var(--stage-fg-soft);
      border-left: 2px solid var(--curtain-a);
      padding-left: 0.8rem;
      margin: 1.4rem 0;
    }
    /* an action spoken inline within a move: (he turns away) */
    .stage .say-action {
      font-style: italic;
      color: var(--stage-fg-soft);
    }
    .stage .beat-line {
      margin: 1.2rem 0;
    }
    .stage .cue {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin: 0 0 0.25rem;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--stage-fg-soft);
    }
    .stage .cue-dot {
      color: var(--curtain-a);
    }
    .stage .say {
      margin: 0;
      font-family: var(--font-display);
      font-size: 21px;
      line-height: 1.45;
      color: var(--stage-fg);
    }
    /* a move on one flowing line: NAME (dir): speech, hanging-indented on wrap */
    .stage .move {
      margin: 1rem 0;
      font-family: var(--font-display);
      font-size: 21px;
      line-height: 1.45;
      color: var(--stage-fg);
      padding-left: 1.8em;
      text-indent: -1.8em;
    }
    .stage .move-cue {
      font-weight: 600;
      color: var(--stage-fg);
    }
  </style>

  <script is:inline>
    (function () {
      var stage = document.getElementById("stage");
      var backstage = document.getElementById("backstage");
      var bsBtn = document.getElementById("backstage-btn");
      var dataEl = document.getElementById("stage-data");
      if (!stage || !backstage || !dataEl) return;

      var data;
      try {
        data = JSON.parse(dataEl.textContent || "{}");
      } catch (e) {
        return;
      }

      var GROUPS = ["cast", "set", "props"];
      var sel = {
        cast: new Set((data.sel && data.sel.cast) || []),
        set: new Set((data.sel && data.sel.set) || []),
        props: new Set((data.sel && data.sel.props) || []),
      };
      var byName = {};
      GROUPS.forEach(function (g) {
        byName[g] = {};
        (data[g] || []).forEach(function (i) {
          byName[g][i.id] = i;
        });
      });
      var plotsById = {};
      (data.plots || []).forEach(function (p) {
        plotsById[p.id] = p;
      });

      var board = document.querySelector(".cb-board");
      var chipsEl = document.getElementById("souffleur-chips");
      var noteEl = document.getElementById("souffleur-note");
      var ranksEl = document.getElementById("cb-ranks");
      var raiseSub = document.getElementById("raise-sub");
      var sceneInner = document.getElementById("scene-inner");

      // Cast/set/props/plot buttons are server-rendered and never added/removed,
      // so query them once.
      var itemEls = stage.querySelectorAll(".cb-item");
      var plotEls = stage.querySelectorAll(".cb-plot");

      // --- Souffleur (bring-your-own Gemini key) ---------------------------------
      // The key lives only in the browser (sessionStorage, or localStorage if the
      // visitor opts in) and is sent straight to Google with the x-goog-api-key
      // header, never to kaihacks (there is no server). Models are free-tier
      // Gemini text models, chosen in the Gridiron panel.
      var MODELS = [
        { id: "gemini-3.1-flash-lite", label: "Gemini 3.1 Flash Lite · 500/day" },
        { id: "gemini-3.5-flash", label: "Gemini 3.5 Flash · 20/day" },
        { id: "gemini-3-flash", label: "Gemini 3 Flash · 20/day" },
        { id: "gemini-2.5-flash", label: "Gemini 2.5 Flash · 20/day" },
        { id: "gemini-2.5-flash-lite", label: "Gemini 2.5 Flash Lite · 20/day" },
      ];
      var MODEL_KEY = "kai.stage.model";
      function loadModel() {
        try {
          return localStorage.getItem(MODEL_KEY) || "gemini-3.1-flash-lite";
        } catch (e) {
          return "gemini-3.1-flash-lite";
        }
      }
      var MODEL = loadModel();
      // Gemini 3.x can't fully disable thinking and takes thinkingLevel, not
      // thinkingBudget (sending the wrong knob is a 400); "minimal" is the floor.
      // 2.5 takes thinkingBudget: 0. Choosing per model keeps the cue and the
      // seed call from truncating or erroring as you switch models.
      function thinkingConfigFor(model) {
        return /^gemini-3/.test(model) ? { thinkingLevel: "minimal" } : { thinkingBudget: 0 };
      }
      // Pull Google's RetryInfo.retryDelay out of a 429 body so we can tell the
      // visitor when the quota frees up rather than a vague "try later".
      function retryDelayOf(errBody) {
        try {
          var details = (errBody && errBody.error && errBody.error.details) || [];
          for (var i = 0; i < details.length; i++) {
            var d = details[i];
            if (d && /RetryInfo/.test(d["@type"] || "") && d.retryDelay) return d.retryDelay;
          }
        } catch (e) {}
        return "";
      }
      // Per-model rate-limit backstop: when a model returns 429 we remember when
      // its quota frees up (from RetryInfo) so the selector shows it red with a
      // "free at" time. Persisted, so a reload doesn't paint a false green.
      var LIMIT_KEY = "kai.stage.limited";
      function loadLimits() {
        try {
          return JSON.parse(localStorage.getItem(LIMIT_KEY) || "{}") || {};
        } catch (e) {
          return {};
        }
      }
      var limits = loadLimits(); // modelId -> epoch-ms the quota frees up
      function setLimit(model, retryDelay) {
        var secs = parseFloat((retryDelay || "").replace(/[^\d.]/g, "")) || 0;
        limits[model] = Date.now() + (secs > 0 ? secs * 1000 : 60000);
        try {
          localStorage.setItem(LIMIT_KEY, JSON.stringify(limits));
        } catch (e) {}
        renderModelOptions();
      }
      function limitedUntil(model) {
        var t = limits[model] || 0;
        return t > Date.now() ? t : 0;
      }
      function freeAtLabel(ts) {
        try {
          return new Date(ts).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
        } catch (e) {
          return "";
        }
      }
      function renderModelOptions() {
        var box = document.getElementById("model-options");
        if (!box) return;
        box.innerHTML = MODELS.map(function (m) {
          var until = limitedUntil(m.id);
          var note = until ? " · free " + freeAtLabel(until) : "";
          return (
            '<label class="model-opt"><input type="radio" name="stage-model" value="' +
            esc(m.id) +
            '"' +
            (m.id === MODEL ? " checked" : "") +
            '/> <span class="model-dot ' +
            (until ? "is-limited" : "is-free") +
            '" aria-hidden="true">●</span><span>' +
            esc(m.label + note) +
            "</span></label>"
          );
        }).join("");
        box.querySelectorAll('input[name="stage-model"]').forEach(function (r) {
          r.addEventListener("change", function (e) {
            MODEL = e.target.value;
            try {
              localStorage.setItem(MODEL_KEY, MODEL);
            } catch (err) {}
          });
        });
      }

      var KEY_NAME = "kai.gemini.key";
      var souffleurEl = document.getElementById("souffleur");
      var keyPanel = document.getElementById("key-panel");
      var openGridironLink = document.getElementById("open-gridiron-link");

      // Gridiron Settings elements
      var gridironOverlay = document.getElementById("gridiron-overlay");
      var gridironBtn = document.getElementById("gridiron-btn");
      var gridironClose = document.getElementById("gridiron-close");
      var gridironScrim = document.getElementById("gridiron-scrim");
      var gridironKeyInput = document.getElementById("gridiron-key-input");
      var gridironKeySave = document.getElementById("gridiron-key-save");
      var gridironKeyRemember = document.getElementById("gridiron-key-remember");
      var gridironKeyForget = document.getElementById("gridiron-key-forget");

      var dirField = document.getElementById("direction-field");
      var dirInput = document.getElementById("souffleur-input");
      var dirCue = document.getElementById("souffleur-cue");

      function loadKey() {
        try {
          var sk = sessionStorage.getItem(KEY_NAME);
          var lk = localStorage.getItem(KEY_NAME);
          if (lk && gridironKeyRemember) {
            gridironKeyRemember.checked = true;
          }
          return sk || lk || "";
        } catch (e) {
          return "";
        }
      }
      var apiKey = loadKey();
      var ctx = null; // lazily fetched stage-context.json
      var transcript = []; // [{ role: "user"|"model", text }]
      var ledger = {}; // planId -> { status, condition, met }; the scene's progress
      var busy = false;
      var eyebrow = "Live scene";
      var anchorNew = false; // on a fresh turn, scroll its first line to the top

      // Director mode: the success targets the director authors per plan, keyed
      // by plot then plan. Persisted per play so they outlive a reload or a
      // re-light of the same plot. The souffleur plays toward them; Play mode
      // (phase 2) will judge them.
      var RUBRIC_KEY = "kai.stage.rubric:" + location.pathname;
      function loadRubric() {
        try {
          return JSON.parse(localStorage.getItem(RUBRIC_KEY) || "{}") || {};
        } catch (e) {
          return {};
        }
      }
      function saveRubric() {
        try {
          localStorage.setItem(RUBRIC_KEY, JSON.stringify(rubric));
        } catch (e) {}
      }
      var rubric = loadRubric();

      function reflectKey() {
        var has = !!apiKey;
        if (keyPanel) keyPanel.hidden = has;
        if (dirField) dirField.hidden = !has;
        if (chipsEl) chipsEl.hidden = !has;
        if (gridironKeyForget) gridironKeyForget.hidden = !has;
        if (gridironKeyInput) {
          gridironKeyInput.placeholder = has ? "••••••••••••••••" : "Paste API key here…";
        }
      }
      function setThinking(on, msg) {
        if (!noteEl) return;
        noteEl.classList.toggle("is-thinking", !!on);
        if (msg) noteEl.textContent = msg;
      }
      function setBusy(on) {
        if (dirInput) dirInput.disabled = !!on;
        if (dirCue) dirCue.disabled = !!on;
        if (gridironKeySave) gridironKeySave.disabled = !!on;
        if (gridironKeyForget) gridironKeyForget.disabled = !!on;

        var rads = document.querySelectorAll(
          'input[name="stage-language"], input[name="stage-model"]',
        );
        rads.forEach(function (r) {
          r.disabled = !!on;
        });

        if (chipsEl) {
          var buttons = chipsEl.querySelectorAll("button");
          buttons.forEach(function (btn) {
            btn.disabled = !!on;
          });
        }
        if (souffleurEl) {
          souffleurEl.classList.toggle("is-busy", !!on);
        }
      }

      function eqSet(arr, set) {
        if (arr.length !== set.size) return false;
        for (var i = 0; i < arr.length; i++) if (!set.has(arr[i])) return false;
        return true;
      }
      // Exact rule: a scene is lit only when the selection equals its company
      // exactly, group by group.
      function litPlot() {
        for (var i = 0; i < (data.plots || []).length; i++) {
          var p = data.plots[i];
          if (eqSet(p.cast, sel.cast) && eqSet(p.set, sel.set) && eqSet(p.props, sel.props))
            return p;
        }
        return null;
      }

      function esc(s) {
        return String(s).replace(/[&<>"]/g, function (c) {
          return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c];
        });
      }

      function chip(name) {
        return '<button class="chip" type="button">' + esc(name) + "</button>";
      }
      function rank(name) {
        return '<span class="cb-rank">' + esc(name) + "</span>";
      }

      // The name to show for an item under the current stage language: the
      // English `title` (name) only when the visitor chose English Translation;
      // otherwise the original-language `declared` (the default). This is the
      // fix for "English shown on a German play": the call board read `title`
      // unconditionally; now the language toggle picks the field.
      function nm(it) {
        if (!it) return "";
        return langOption === "en" ? it.name : it.declared || it.name;
      }

      // Mirror of scene.ts composeScene: the casting drives the (mocked) lines.
      function nameOf(group, id) {
        return nm(byName[group][id]);
      }
      function composeScene(lit) {
        if (!sceneInner) return;
        var castNames = [];
        sel.cast.forEach(function (id) {
          var n = nameOf("cast", id);
          if (n) castNames.push(n);
        });
        var placeName = nameOf("set", sel.set.values().next().value);
        var propName = nameOf("props", sel.props.values().next().value);
        var a = castNames[0];
        var b = castNames[1];
        var speakerA = a || "A Voice";
        var speakerB = b || "The House";

        var beats = [];
        beats.push({
          dir:
            "[ " +
            (placeName ? placeName + " holds the dark" : "The dark holds") +
            ". " +
            speakerA +
            " waits at the edge. ]",
        });
        if (a) beats.push({ cue: speakerA, say: "Every entrance is a kind of falling." });
        if (b) beats.push({ cue: speakerB, say: "Then say the fall has already begun." });
        beats.push({
          dir: propName
            ? "[ " + speakerB + " turns. " + propName + " catches the little light there is. ]"
            : "[ " + speakerB + " turns toward the house. ]",
        });
        if (a) beats.push({ cue: speakerA, say: "The play will find its way without us." });
        if (b) beats.push({ cue: speakerB, say: "Or we are the way it finds." });

        // The eyebrow names the lit scene (or flags a custom casting). Local
        // (not the module-scoped `eyebrow`, which names the live AI scene).
        var label = lit ? nm(lit) : "Custom casting";
        var html = '<p class="scene-act">' + esc(label) + '</p><hr class="scene-rule" />';
        beats.forEach(function (bt) {
          if (bt.dir) {
            html += '<p class="beat-dir">' + esc(bt.dir) + "</p>";
          } else {
            html +=
              '<div class="beat-line"><p class="cue"><span class="cue-dot" aria-hidden="true">•</span>' +
              esc(bt.cue) +
              '</p><p class="say">' +
              esc(bt.say) +
              "</p></div>";
          }
        });
        sceneInner.innerHTML = html;
        var sceneEl = document.getElementById("scene");
        if (sceneEl) {
          sceneEl.scrollTop = 0;
        }
      }

      function loadContext() {
        if (ctx) return Promise.resolve(ctx);
        return fetch("../stage-context.json")
          .then(function (r) {
            return r.ok ? r.json() : null;
          })
          .then(function (c) {
            ctx = c;
            var labelEl = document.getElementById("declared-lang-label");
            if (labelEl && c && c.language) {
              var prettyName = c.language === "de" ? "German" : c.language.toUpperCase();
              labelEl.textContent = "Original (" + prettyName + ")";
            }
            return c;
          })
          .catch(function () {
            return null;
          });
      }

      // Element 2 of the cue: the play frame, the language, and the khai files
      // (synopsis, the lit scene, and the selected cast/set/props). Real play
      // data, fixed for a given casting, so it caches behind the HACKS prefix.
      function playContext(lit) {
        var L = [];
        L.push(
          "The play is «" + ctx.title + "» (" + ctx.declared + "), of the house " + ctx.house + ".",
        );
        var activeLang = langOption === "en" ? "en" : ctx.language || "en";
        if (activeLang === "de") {
          L.push(
            "Perform the scene entirely in German, using the declared (German) names from the company. Even if a cue is in English, translate it and keep everything in German. Do not mix languages.",
          );
        } else {
          L.push(
            "Perform the scene entirely in the language of the play's synopsis, elements, and plots. Do not mix languages. If the context is in English, write everything in English.",
          );
        }
        if (ctx.synopsis) L.push("Synopsis: " + ctx.synopsis);
        if (lit && ctx.plots[lit.id])
          L.push("This scene (" + ctx.plots[lit.id].name + "): " + ctx.plots[lit.id].text);
        function add(label, id) {
          var e = ctx.elements[id];
          if (e) L.push(label + " - " + e.name + " (" + e.declared + "): " + e.text);
        }
        sel.cast.forEach(function (id) {
          add("Cast", id);
        });
        sel.set.forEach(function (id) {
          add("Set", id);
        });
        sel.props.forEach(function (id) {
          add("Prop", id);
        });
        return L.join("\n\n");
      }

      // Element 3 of the cue: the conditions in play (the lit scene's plans with
      // their live status and targets). Dynamic, so it follows the fixed context
      // as its own turn. Returns "" when the scene carries no plans.
      function plansContext(lit) {
        if (!(lit && lit.objectives.length && ctx.plans)) return "";
        var plotRubric = rubric[lit.id] || {};
        var conds = lit.objectives
          .map(function (o) {
            var p = ctx.plans[o.id];
            if (!p) return "";
            var e = ledger[o.id] || {};
            var line = "- " + p.name + " [" + (e.status || "open") + "]: " + p.text;
            var r = plotRubric[o.id];
            if (r && r.targets && r.targets.length) {
              var met = e.met || {};
              line +=
                "\n  Targets: " +
                r.targets
                  .map(function (t, i) {
                    return (met[i] ? "[x] " : "[ ] ") + t;
                  })
                  .join("; ");
            }
            if (e.condition) line += "\n  Condition: " + e.condition;
            return line;
          })
          .filter(Boolean);
        if (!conds.length) return "";
        return (
          "Conditions in play (advance these through the action; honor what is " +
          "achieved, do not revive what is abandoned):\n" +
          conds.join("\n")
        );
      }

      // Inline markup inside a spoken line: (action) shown subtly, _setting_ in
      // italic. Escape first, then wrap, so the wrapped content stays escaped.
      function sayInline(s) {
        var out = esc(s);
        out = out.replace(/_([^_]+)_/g, "<em>$1</em>");
        out = out.replace(/\(([^)]+)\)/g, '<span class="say-action">($1)</span>');
        return out;
      }
      // Render the performance into the scene per the HACKS System grammar:
      //   [Persona]          starts a move (the persona speaking)
      //   (stage direction)  a persona action
      //   _stage direction_  an environment setting, shown in italic
      // The model writes [Persona] (or **Persona**) then the action and speech
      // on following lines; a move is coalesced into the book grammar:
      // **Name** (direction). dialogue. Speaker bold, a leading stage direction
      // in italic before the period, each speaker its own clean paragraph,
      // hanging-indented on wrap. (Styling follows the stage's own CVI.)
      // `liveText` is the streaming turn; completed model turns stay on screen.
      // A move opens with [Persona] (the SYSTEM grammar). Models often emit
      // markdown bold instead (**Persona** / **Persona:**) despite the grammar,
      // so accept both and return the bare name plus the rest of the line.
      function moveHeader(s) {
        var m = s.match(/^\[([^\]]+)\]\s*([\s\S]*)$/);
        if (m) return { name: m[1].trim(), rest: m[2] };
        m = s.match(/^\*\*\s*([^*\n]+?)\s*\*\*\s*([\s\S]*)$/);
        if (m) return { name: m[1].replace(/\s*:\s*$/, "").trim(), rest: m[2] };
        return null;
      }
      function isMoveLine(s) {
        return moveHeader(s) !== null;
      }
      function isSettingLine(s) {
        return /^_.+_$/.test(s);
      }
      function moveHtml(name, parts) {
        // Book grammar: **Name** (stage direction). Dialogue. A leading stage
        // direction sits in italic between the speaker and the period; later
        // directions stay inline (sayInline). Each move is its own clean
        // paragraph led by the bold speaker.
        var body = parts.join(" ").trim();
        var dir = "";
        var lm = body.match(/^\(([^)]*)\)\s*([\s\S]*)$/);
        if (lm) {
          dir = ' <span class="say-action">(' + esc(lm[1]) + ")</span>";
          body = lm[2];
        }
        return (
          '<p class="move"><span class="move-cue">' +
          esc(name) +
          "</span>" +
          dir +
          ". " +
          sayInline(body) +
          "</p>"
        );
      }
      function beatsHtml(textRaw) {
        var lines = textRaw.split("\n");
        var html = "";
        var i = 0;
        while (i < lines.length) {
          var t = lines[i].trim();
          if (!t) {
            i++;
            continue;
          }
          // Environment setting: a whole line in underscores, italic, standalone.
          if (isSettingLine(t)) {
            html +=
              '<p class="beat-dir beat-setting"><em>' +
              esc(t.replace(/^_+|_+$/g, "")) +
              "</em></p>";
            i++;
            continue;
          }
          // Persona move: gather the action and speech lines that follow the
          // [Persona] (or **Persona**) header, until the next move or a setting.
          var hd = moveHeader(t);
          if (hd) {
            var name = hd.name;
            var parts = [];
            if (hd.rest) parts.push(hd.rest);
            i++;
            while (i < lines.length) {
              var nt = lines[i].trim();
              if (!nt) {
                i++;
                continue;
              }
              if (isMoveLine(nt) || isSettingLine(nt)) break;
              parts.push(nt);
              i++;
            }
            html += moveHtml(name, parts);
            continue;
          }
          // A standalone action, or any stray line.
          if (/^\(.+\)$/.test(t)) {
            html += '<p class="beat-dir">' + esc(t) + "</p>";
            i++;
            continue;
          }
          html += '<p class="say">' + sayInline(t) + "</p>";
          i++;
        }
        return html;
      }
      function renderScene(liveText) {
        if (!sceneInner) return;
        var prior = [];
        transcript.forEach(function (t) {
          if (t.role === "model" && t.text) prior.push(t.text);
        });

        var html = '<p class="scene-act">' + esc(eyebrow) + '</p><hr class="scene-rule" />';
        html += beatsHtml(prior.join("\n\n"));
        // A zero-height marker at the new turn's start, so we can bring the fresh
        // beat to the top instead of fast-forwarding to the bottom of the stream.
        if (liveText) html += '<div id="live-start"></div>' + beatsHtml(liveText);
        sceneInner.innerHTML = html;

        var sceneEl = document.getElementById("scene");
        if (sceneEl && anchorNew) {
          // Once per turn: park the new beat's first line near the top, then let
          // the reader read down at their own pace without chasing the stream.
          var marker = document.getElementById("live-start");
          sceneEl.scrollTop = marker ? Math.max(0, marker.offsetTop - 16) : 0;
          anchorNew = false;
        }
      }

      function streamGemini(system, turns) {
        var url =
          "https://generativelanguage.googleapis.com/v1beta/models/" +
          MODEL +
          ":streamGenerateContent?alt=sse";
        var body = {
          systemInstruction: { parts: [{ text: system }] },
          contents: turns.map(function (t) {
            return { role: t.role, parts: [{ text: t.text }] };
          }),
          generationConfig: {
            temperature: 0.9,
            maxOutputTokens: 2048,
            // Reasoning tokens count against maxOutputTokens; left on, thinking
            // ate the budget and the reply was truncated mid-sentence. Hold it to
            // the floor per model (see thinkingConfigFor) so the scene gets prose.
            thinkingConfig: thinkingConfigFor(MODEL),
          },
        };
        return fetch(url, {
          method: "POST",
          headers: { "content-type": "application/json", "x-goog-api-key": apiKey },
          body: JSON.stringify(body),
        }).then(function (res) {
          if (!res.ok || !res.body) {
            return res
              .json()
              .catch(function () {
                return null;
              })
              .then(function (errBody) {
                if (res.status === 429) throw new Error("rate-limited|" + retryDelayOf(errBody));
                var rejected = res.status === 400 || res.status === 403;
                throw new Error(rejected ? "key-rejected" : "http-" + res.status);
              });
          }
          var reader = res.body.getReader();
          var dec = new TextDecoder();
          var buf = "";
          var full = "";
          var finish = "";
          function handleLine(line) {
            line = line.trim();
            if (line.indexOf("data:") !== 0) return;
            var payload = line.slice(5).trim();
            if (!payload || payload === "[DONE]") return;
            try {
              var obj = JSON.parse(payload);
              var c = obj.candidates && obj.candidates[0];
              if (c && c.finishReason) finish = c.finishReason;
              var part = c && c.content && c.content.parts && c.content.parts[0];
              if (part && part.text) {
                full += part.text;
                renderScene(full);
              }
            } catch (e) {}
          }
          function pump() {
            return reader.read().then(function (r) {
              if (r.done) {
                // Flush the final event: the last SSE line often arrives with
                // no trailing newline, so it never split out of `buf` above.
                buf += dec.decode();
                if (buf) handleLine(buf);
                return { text: full, finish: finish };
              }
              buf += dec.decode(r.value, { stream: true });
              var lines = buf.split("\n");
              buf = lines.pop();
              lines.forEach(handleLine);
              return pump();
            });
          }
          return pump().catch(function (e) {
            // A mid-stream drop (the reader threw) after text has already
            // streamed: keep the partial so the scene holds the beat and a
            // "continue" cue resumes it. Only a no-text failure propagates to
            // the hard error handler (rate-limit / key / http stay above, at
            // the res.ok check, so they never carry a partial).
            if (full && full.trim()) return { text: full, finish: "dropped" };
            throw e;
          });
        });
      }

      function generate(direction) {
        if (busy || !apiKey) return;
        busy = true;
        setBusy(true);
        setThinking(true, "The souffleur is thinking…");
        loadContext().then(function (c) {
          if (!c) {
            setThinking(true, "Scene context unavailable.");
            busy = false;
            setBusy(false);
            return;
          }

          var activeLang = langOption === "en" ? "en" : c.language || "en";

          var lit = litPlot();
          eyebrow = lit ? nm(lit) : "Live scene";

          // Lock 1: never send the visitor's cue as a bare instruction (which
          // invites "ignore the play, explain X"). Frame it as a stage direction
          // called from the house, so an off-play request arrives as words the
          // scene reacts to, not a command the souffleur obeys.
          function framedCue(dir) {
            if (!dir) return "";
            return activeLang === "de"
              ? "Regieanweisung aus dem Zuschauerraum: «" +
                  dir +
                  "». Spiele, wie die Szene darauf antwortet; verlass das Stück nicht."
              : "Stage direction from the house: «" +
                  dir +
                  "». Play how the scene answers it; never leave the play.";
          }
          var framed = framedCue(direction);
          var userText;
          if (activeLang === "de") {
            userText =
              transcript.length === 0
                ? "Hebe den Vorhang für diese Szene." + (framed ? " " + framed : "")
                : framed || "Setze die Szene fort.";
          } else {
            userText =
              transcript.length === 0
                ? "Raise the curtain on this scene." + (framed ? " " + framed : "")
                : framed || "Continue the scene.";
          }

          transcript.push({
            role: "user",
            text: userText,
          });
          anchorNew = true; // bring this fresh beat to the top as it streams
          // Element 2 (play context) and element 3 (plans) lead the contents as
          // their own turns; history and the framed cue follow. Element 1 (HACKS)
          // is the systemInstruction. HACKS + play context are the cache prefix;
          // plans, history, and the cue are the moving tail.
          var contextTurns = [{ role: "user", text: playContext(lit) }];
          var plansText = plansContext(lit);
          if (plansText) contextTurns.push({ role: "user", text: plansText });
          streamGemini(assembleHacks(), contextTurns.concat(transcript))
            .then(function (res) {
              var full = res && res.text;
              busy = false;
              setBusy(false);
              if (dirInput) dirInput.focus();
              if (!full || !full.trim()) {
                // No text came back (e.g. a safety block); don't record an
                // empty turn or the next cue feeds the model a blank reply.
                transcript.pop();
                setThinking(true, "The players stayed silent. Try another cue.");
                return;
              }
              transcript.push({ role: "model", text: full });
              setThinking(
                res.finish === "dropped",
                res.finish === "MAX_TOKENS"
                  ? "The scene ran long. Cue again to continue."
                  : res.finish === "dropped"
                    ? "The line dropped mid-beat. Cue to continue."
                    : "Whisper another direction, or re-cast backstage.",
              );
              maybeJudge(lit); // Play mode: judge the plans against the scene so far
            })
            .catch(function (err) {
              transcript.pop(); // a failed turn shouldn't poison the history
              busy = false;
              setBusy(false);
              if (dirInput) dirInput.focus();
              var failure = String(err && err.message);
              if (failure === "key-rejected") {
                apiKey = "";
                try {
                  sessionStorage.removeItem(KEY_NAME);
                  localStorage.removeItem(KEY_NAME);
                } catch (e) {}
                reflectKey();
                setThinking(true, "That key was rejected. Try another.");
              } else if (failure.indexOf("rate-limited") === 0) {
                setLimit(MODEL, failure.split("|")[1] || "");
                var at = freeAtLabel(limitedUntil(MODEL));
                setThinking(
                  true,
                  at
                    ? "Rate limited. This model frees up around " +
                        at +
                        "; pick another in Gridiron."
                    : "Rate limited by Google. Try the cue again shortly.",
                );
              } else {
                setThinking(true, "The line failed. Try the cue again.");
              }
            });
        });
      }

      // Relabel the static call-board lists (cast/set/props/scene-plot names),
      // which render() only toggles state on, never rebuilds. Each name node
      // carries both faces in data-name-en/-de; pick per the stage language.
      function applyLang() {
        var nodes = document.querySelectorAll("[data-name-de]");
        for (var i = 0; i < nodes.length; i++) {
          var el = nodes[i];
          el.textContent =
            langOption === "en"
              ? el.getAttribute("data-name-en") || ""
              : el.getAttribute("data-name-de") || "";
        }
      }

      function render() {
        var lit = litPlot();
        // items
        itemEls.forEach(function (el) {
          var on = sel[el.getAttribute("data-group")].has(el.getAttribute("data-id"));
          el.classList.toggle("is-on", on);
          el.setAttribute("aria-pressed", on ? "true" : "false");
        });
        // plots
        plotEls.forEach(function (el) {
          var on = lit && el.getAttribute("data-plot") === lit.id;
          el.classList.toggle("is-lit", !!on);
          el.setAttribute("aria-pressed", on ? "true" : "false");
        });
        // blocking
        if (ranksEl) ranksEl.innerHTML = lit ? lit.ranks.map((r) => rank(nm(r))).join("") : "";
        // souffleur cues
        if (chipsEl) {
          var cues = lit ? lit.business.concat(lit.objectives) : [];
          chipsEl.innerHTML = cues.map((c) => chip(nm(c))).join("");
        }
        if (noteEl)
          noteEl.textContent = lit
            ? "The souffleur sleeps · cues are " + nm(lit) + "'s business & objectives."
            : "Custom casting · pick a Scene Plot for its cues.";
        if (raiseSub) raiseSub.textContent = lit ? nm(lit) : "custom casting";
        renderLedger();
        // Don't clobber a live (AI) scene with the mock; re-casting resets the
        // transcript (below), so a fresh cast falls back to the mock placeholder.
        if (!transcript.length) composeScene(lit);
      }

      // Re-casting starts a new scene.
      function resetScene() {
        transcript = [];
        ledger = {};
      }
      function toggleItem(group, id) {
        var s = sel[group];
        if (s.has(id)) s.delete(id);
        else s.add(id);
        resetScene();
        render();
      }
      function selectPlot(id) {
        resetScene();
        var p = plotsById[id];
        if (!p) return;
        sel.cast = new Set(p.cast);
        sel.set = new Set(p.set);
        sel.props = new Set(p.props);
        render();
      }

      if (board)
        board.addEventListener("click", function (ev) {
          var item = ev.target.closest(".cb-item");
          if (item) {
            toggleItem(item.getAttribute("data-group"), item.getAttribute("data-id"));
            return;
          }
          var plot = ev.target.closest(".cb-plot");
          if (plot) selectPlot(plot.getAttribute("data-plot"));
        });

      // curtain + overlay state
      var raiseCb = document.getElementById("raise-cb");
      var raiseCbMain = raiseCb ? raiseCb.querySelector(".raise-main") : null;
      var closeTimer;
      var gridironCloseTimer;
      var headEl = stage.querySelector(".stage-head");
      var houseEl = stage.querySelector(".house");
      var cbCloseEl = document.getElementById("cb-close");
      var opener = null;
      var gridironOpener = null;

      function isOpen() {
        return stage.classList.contains("is-open");
      }
      function syncRaise() {
        if (!raiseCbMain) return;
        raiseCbMain.textContent = isOpen() ? "Lower the Curtain" : "Raise the Curtain";
      }
      // The dialog lives outside .house/.stage-head, so inert-ing those two traps
      // focus in the call board (nothing else is tabbable) and hides the stage
      // behind it from assistive tech.
      function setBackgroundInert(on) {
        [headEl, houseEl].forEach(function (el) {
          if (!el) return;
          if (on) el.setAttribute("inert", "");
          else el.removeAttribute("inert");
        });
      }
      function openBackstage() {
        clearTimeout(closeTimer);
        opener = document.activeElement;
        backstage.hidden = false;
        requestAnimationFrame(function () {
          backstage.classList.add("is-open");
        });
        bsBtn.setAttribute("aria-expanded", "true");
        setBackgroundInert(true);
        if (cbCloseEl) cbCloseEl.focus();
        syncRaise();
      }
      function closeBackstage() {
        backstage.classList.remove("is-open");
        bsBtn.setAttribute("aria-expanded", "false");
        setBackgroundInert(false);
        if (opener && opener.focus) opener.focus();
        opener = null;
        closeTimer = setTimeout(function () {
          backstage.hidden = true;
        }, 320);
      }
      // --- Director mode -----------------------------------------------------
      // Targets are scoped to the lit plot's plans, so the panel is only shown
      // when a plot is lit. Rebuilt on open (not every render) so live edits in
      // the textareas aren't clobbered.
      function setTargets(plotId, planId, raw) {
        var list = raw
          .split("\n")
          .map(function (s) {
            return s.trim();
          })
          .filter(Boolean);
        if (!rubric[plotId]) rubric[plotId] = {};
        if (!rubric[plotId][planId]) rubric[plotId][planId] = {};
        rubric[plotId][planId].targets = list;
        saveRubric();
      }
      function resetSeedBtn(btn) {
        if (!btn) return;
        btn.disabled = false;
        btn.textContent = "SEED FROM PROSE";
      }
      function seedTargets(name, prose) {
        var url =
          "https://generativelanguage.googleapis.com/v1beta/models/" + MODEL + ":generateContent";
        var body = {
          systemInstruction: {
            parts: [
              {
                text:
                  "You are a dramaturg. Propose 2 to 4 concrete, checkable success targets a " +
                  "scene could reach for the given plan/objective. Write each as a short clause " +
                  "in the same language as the prose. Return JSON.",
              },
            ],
          },
          contents: [{ role: "user", parts: [{ text: "Plan: " + name + "\n\n" + prose }] }],
          generationConfig: {
            temperature: 0.3,
            maxOutputTokens: 512,
            thinkingConfig: thinkingConfigFor(MODEL),
            responseMimeType: "application/json",
            responseSchema: {
              type: "object",
              properties: { targets: { type: "array", items: { type: "string" } } },
              required: ["targets"],
            },
          },
        };
        return fetch(url, {
          method: "POST",
          headers: { "content-type": "application/json", "x-goog-api-key": apiKey },
          body: JSON.stringify(body),
        })
          .then(function (res) {
            if (res.ok) return res.json();
            return res
              .json()
              .catch(function () {
                return null;
              })
              .then(function (errBody) {
                if (res.status === 429) throw new Error("rate-limited|" + retryDelayOf(errBody));
                throw new Error("seed-" + res.status);
              });
          })
          .then(function (data) {
            var c = data.candidates && data.candidates[0];
            var part = c && c.content && c.content.parts && c.content.parts[0];
            var obj = part && part.text ? JSON.parse(part.text) : {};
            return (obj && obj.targets) || [];
          });
      }
      function seedPlan(plotId, planId, ta, btn) {
        if (!apiKey) {
          if (btn) btn.textContent = "ADD A KEY FIRST";
          return;
        }
        if (btn) {
          btn.disabled = true;
          btn.textContent = "SEEDING…";
        }
        loadContext()
          .then(function (c) {
            var plan = c && c.plans && c.plans[planId];
            if (!plan) {
              resetSeedBtn(btn);
              return;
            }
            return seedTargets(plan.name, plan.text).then(function (targets) {
              if (targets.length && ta) {
                ta.value = targets.join("\n");
                setTargets(plotId, planId, ta.value);
              }
              resetSeedBtn(btn);
            });
          })
          .catch(function (err) {
            var msg = String(err && err.message);
            if (msg.indexOf("rate-limited") === 0) setLimit(MODEL, msg.split("|")[1] || "");
            resetSeedBtn(btn);
          });
      }

      // --- Play mode: judge the plans -------------------------------------------
      // After a move, ask the model which of each plan's authored targets the
      // scene has now reached. A separate JSON-mode call (structured, temp ~0)
      // keeps the creative cue stream untouched. Best-effort: any failure leaves
      // the ledger as-is.
      function plansWithTargets(lit) {
        var plotRubric = (lit && rubric[lit.id]) || {};
        return lit
          ? lit.objectives
              .map(function (o) {
                var r = plotRubric[o.id];
                if (!r || !r.targets || !r.targets.length) return null;
                return { id: o.id, name: o.name, targets: r.targets };
              })
              .filter(Boolean)
          : [];
      }
      // A ledger entry keeps the model's verdict (`judged`) and the director's
      // overrides (`manual`) apart; the effective `met` is the merge, with the
      // director winning so a correction survives the next judgment.
      function deriveStatus(met, targetsLen) {
        var n = Object.keys(met).length;
        return n === 0 ? "open" : targetsLen && n >= targetsLen ? "achieved" : "active";
      }
      function refreshEntry(planId, targetsLen) {
        var e = ledger[planId] || (ledger[planId] = {});
        var met = {};
        var j = e.judged || {};
        for (var a in j) if (j[a]) met[a] = true;
        var m = e.manual || {};
        for (var b in m) {
          if (m[b]) met[b] = true;
          else delete met[b];
        }
        e.met = met;
        e.status = deriveStatus(met, targetsLen);
      }
      function applyJudgment(plotId, verdicts) {
        var plotRubric = rubric[plotId] || {};
        (verdicts || []).forEach(function (v) {
          if (!v || !v.id) return;
          var targets = (plotRubric[v.id] && plotRubric[v.id].targets) || [];
          var e = ledger[v.id] || (ledger[v.id] = {});
          var judged = {};
          (v.met || []).forEach(function (i) {
            if (i >= 0 && i < targets.length) judged[i] = true;
          });
          e.judged = judged;
          e.condition = v.condition || e.condition || "";
          refreshEntry(v.id, targets.length);
        });
      }
      // Director override: flip a single target's effective met-state and keep it
      // (manual wins over the model). Folds straight into the next prompt.
      function toggleTarget(plotId, planId, i) {
        var targets =
          (rubric[plotId] && rubric[plotId][planId] && rubric[plotId][planId].targets) || [];
        var e = ledger[planId] || (ledger[planId] = {});
        if (!e.manual) e.manual = {};
        e.manual[i] = !(e.met && e.met[i]);
        refreshEntry(planId, targets.length);
        renderLedger();
      }
      function judgePlans(lit) {
        var plans = plansWithTargets(lit);
        if (!plans.length) return Promise.resolve(null);
        var scene = transcript
          .filter(function (t) {
            return t.role === "model" && t.text;
          })
          .map(function (t) {
            return t.text;
          })
          .join("\n\n");
        if (!scene) return Promise.resolve(null);
        var rubricText = plans
          .map(function (p) {
            return (
              p.name +
              " (id " +
              p.id +
              "):\n" +
              p.targets
                .map(function (t, i) {
                  return "  [" + i + "] " + t;
                })
                .join("\n")
            );
          })
          .join("\n\n");
        var url =
          "https://generativelanguage.googleapis.com/v1beta/models/" + MODEL + ":generateContent";
        var body = {
          systemInstruction: {
            parts: [
              {
                text:
                  "You are the stage manager judging scene progress. For each plan, decide from " +
                  "the scene which of its numbered targets are now met, and write a one-line " +
                  "condition for where the plan stands. Mark a target met only if the scene " +
                  "clearly shows it; be conservative. Write the condition in the scene's language.",
              },
            ],
          },
          contents: [
            {
              role: "user",
              parts: [
                { text: "Plans and targets:\n" + rubricText + "\n\nScene so far:\n" + scene },
              ],
            },
          ],
          generationConfig: {
            temperature: 0,
            maxOutputTokens: 1024,
            thinkingConfig: thinkingConfigFor(MODEL),
            responseMimeType: "application/json",
            responseSchema: {
              type: "object",
              properties: {
                plans: {
                  type: "array",
                  items: {
                    type: "object",
                    properties: {
                      id: { type: "string" },
                      met: { type: "array", items: { type: "integer" } },
                      condition: { type: "string" },
                    },
                    required: ["id", "met", "condition"],
                  },
                },
              },
              required: ["plans"],
            },
          },
        };
        return fetch(url, {
          method: "POST",
          headers: { "content-type": "application/json", "x-goog-api-key": apiKey },
          body: JSON.stringify(body),
        })
          .then(function (res) {
            if (res.ok) return res.json();
            return res
              .json()
              .catch(function () {
                return null;
              })
              .then(function (errBody) {
                if (res.status === 429) throw new Error("rate-limited|" + retryDelayOf(errBody));
                throw new Error("judge-" + res.status);
              });
          })
          .then(function (data) {
            var c = data.candidates && data.candidates[0];
            var part = c && c.content && c.content.parts && c.content.parts[0];
            var obj = part && part.text ? JSON.parse(part.text) : {};
            return (obj && obj.plans) || [];
          });
      }
      function maybeJudge(lit) {
        if (!lit || !apiKey || !plansWithTargets(lit).length) return;
        judgePlans(lit)
          .then(function (verdicts) {
            if (!verdicts) return;
            applyJudgment(lit.id, verdicts);
            renderLedger();
          })
          .catch(function (err) {
            var msg = String(err && err.message);
            if (msg.indexOf("rate-limited") === 0) setLimit(MODEL, msg.split("|")[1] || "");
            // otherwise silent: judgment is best-effort, the scene already played
          });
      }
      function renderLedger() {
        var box = document.getElementById("ledger");
        if (!box) return;
        var lit = litPlot();
        var plans = plansWithTargets(lit);
        if (!plans.length) {
          box.hidden = true;
          box.innerHTML = "";
          return;
        }
        box.hidden = false;
        box.innerHTML = plans
          .map(function (p) {
            var e = ledger[p.id] || { status: "open", condition: "", met: {} };
            var met = e.met || {};
            var head =
              '<div class="ledger-row"><span class="ledger-dot is-' +
              esc(e.status || "open") +
              '" aria-hidden="true">●</span><span class="ledger-name">' +
              esc(p.name) +
              "</span>" +
              (e.condition ? '<span class="ledger-cond">' + esc(e.condition) + "</span>" : "") +
              "</div>";
            var targets = p.targets
              .map(function (t, i) {
                return (
                  '<button class="ledger-target' +
                  (met[i] ? " is-met" : "") +
                  '" type="button" data-plan="' +
                  esc(p.id) +
                  '" data-i="' +
                  i +
                  '">' +
                  (met[i] ? "[x] " : "[ ] ") +
                  esc(t) +
                  "</button>"
                );
              })
              .join("");
            return '<div class="ledger-plan">' + head + targets + "</div>";
          })
          .join("");
        var plotId = lit ? lit.id : "";
        box.querySelectorAll(".ledger-target").forEach(function (btn) {
          btn.addEventListener("click", function () {
            toggleTarget(
              plotId,
              btn.getAttribute("data-plan"),
              parseInt(btn.getAttribute("data-i"), 10),
            );
          });
        });
      }
      function renderDirector() {
        var section = document.getElementById("director-section");
        var body = document.getElementById("director-body");
        if (!section || !body) return;
        var lit = litPlot();
        if (!lit || !lit.objectives.length) {
          section.hidden = true;
          body.innerHTML = "";
          return;
        }
        section.hidden = false;
        var plotRubric = rubric[lit.id] || {};
        body.innerHTML = lit.objectives
          .map(function (o) {
            var r = plotRubric[o.id] || {};
            var targets = esc((r.targets || []).join("\n"));
            return (
              '<div class="director-plan" data-plan="' +
              esc(o.id) +
              '"><p class="director-plan-name">' +
              esc(o.name) +
              '</p><textarea class="director-targets" rows="3" placeholder="One target per line…">' +
              targets +
              '</textarea><button class="souffleur-cue director-seed" type="button">SEED FROM PROSE</button></div>'
            );
          })
          .join("");
        body.querySelectorAll(".director-plan").forEach(function (block) {
          var planId = block.getAttribute("data-plan");
          var ta = block.querySelector(".director-targets");
          var seed = block.querySelector(".director-seed");
          if (ta)
            ta.addEventListener("input", function () {
              setTargets(lit.id, planId, ta.value);
            });
          if (seed)
            seed.addEventListener("click", function () {
              seedPlan(lit.id, planId, ta, seed);
            });
        });
      }

      function openGridiron() {
        if (!gridironOverlay) return;
        renderDirector();
        renderModelOptions();
        clearTimeout(gridironCloseTimer);
        gridironOpener = document.activeElement;
        gridironOverlay.hidden = false;
        requestAnimationFrame(function () {
          gridironOverlay.classList.add("is-open");
        });
        if (gridironBtn) gridironBtn.setAttribute("aria-expanded", "true");
        setBackgroundInert(true);
        var gridironCloseBtn = document.getElementById("gridiron-close");
        if (gridironCloseBtn) gridironCloseBtn.focus();
      }
      function closeGridiron() {
        if (!gridironOverlay) return;
        gridironOverlay.classList.remove("is-open");
        if (gridironBtn) gridironBtn.setAttribute("aria-expanded", "false");
        setBackgroundInert(false);
        if (gridironOpener && gridironOpener.focus) gridironOpener.focus();
        gridironOpener = null;
        gridironCloseTimer = setTimeout(function () {
          gridironOverlay.hidden = true;
        }, 320);
      }
      function toggleGridiron() {
        if (!gridironOverlay) return;
        gridironOverlay.hidden ? openGridiron() : closeGridiron();
      }
      function setState(open) {
        stage.classList.toggle("is-open", open);
        stage.classList.toggle("is-closed", !open);
        stage.setAttribute("data-state", open ? "open" : "closed");
        closeBackstage();
        closeGridiron();
      }

      bsBtn.addEventListener("click", function () {
        backstage.hidden ? openBackstage() : closeBackstage();
      });
      var cbClose = document.getElementById("cb-close");
      var scrim = document.getElementById("backstage-scrim");
      var playbillBs = document.getElementById("playbill-backstage");
      var raiseFront = document.getElementById("raise-front");
      if (cbClose) cbClose.addEventListener("click", closeBackstage);
      if (scrim) scrim.addEventListener("click", closeBackstage);
      if (playbillBs) playbillBs.addEventListener("click", openBackstage);
      // Raising the curtain begins the scene if a key is already in hand.
      function openCurtain() {
        setState(true);
        if (apiKey && !transcript.length) generate("");
      }
      if (raiseFront) raiseFront.addEventListener("click", openCurtain);
      if (raiseCb)
        raiseCb.addEventListener("click", function () {
          isOpen() ? setState(false) : openCurtain();
        });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
          if (!backstage.hidden) closeBackstage();
          else if (!gridironOverlay.hidden) closeGridiron();
        }
      });

      // --- Gridiron (Settings) & Souffleur wiring ---------------------------------
      function persistKey(k, remember) {
        try {
          sessionStorage.setItem(KEY_NAME, k);
          if (remember) localStorage.setItem(KEY_NAME, k);
          else localStorage.removeItem(KEY_NAME);
        } catch (e) {}
      }
      if (gridironKeySave)
        gridironKeySave.addEventListener("click", function () {
          var k = ((gridironKeyInput && gridironKeyInput.value) || "").trim();
          if (!k) return;
          apiKey = k;
          persistKey(k, gridironKeyRemember && gridironKeyRemember.checked);
          if (gridironKeyInput) gridironKeyInput.value = "";
          reflectKey();
          closeGridiron();
          if (dirInput) dirInput.focus();
          if (isOpen()) generate("");
        });
      if (gridironKeyInput)
        gridironKeyInput.addEventListener("keydown", function (e) {
          if (e.key === "Enter" && gridironKeySave) gridironKeySave.click();
        });
      if (gridironKeyForget)
        gridironKeyForget.addEventListener("click", function () {
          apiKey = "";
          try {
            sessionStorage.removeItem(KEY_NAME);
            localStorage.removeItem(KEY_NAME);
          } catch (e) {}
          resetScene();
          reflectKey();
          render();
          closeGridiron();
        });

      // Stage Language Setting
      var LANG_KEY = "kai.stage.language";
      function loadLanguage() {
        try {
          return localStorage.getItem(LANG_KEY) || "declared";
        } catch (e) {
          return "declared";
        }
      }
      var langOption = loadLanguage();
      var rads = document.querySelectorAll('input[name="stage-language"]');
      rads.forEach(function (r) {
        if (r.value === langOption) r.checked = true;
        r.addEventListener("change", function (e) {
          langOption = e.target.value;
          try {
            localStorage.setItem(LANG_KEY, langOption);
          } catch (err) {}
          // Re-language the board: static lists via applyLang, the dynamic
          // chips/blocking/eyebrow/raise-sub via a re-render (both read nm()).
          applyLang();
          render();
        });
      });

      if (gridironBtn) gridironBtn.addEventListener("click", toggleGridiron);
      if (gridironClose) gridironClose.addEventListener("click", closeGridiron);
      if (gridironScrim) gridironScrim.addEventListener("click", closeGridiron);
      if (openGridironLink) openGridironLink.addEventListener("click", openGridiron);
      function cue() {
        var d = ((dirInput && dirInput.value) || "").trim();
        if (dirInput) dirInput.value = "";
        generate(d);
      }
      if (dirCue) dirCue.addEventListener("click", cue);
      if (dirInput)
        dirInput.addEventListener("keydown", function (e) {
          if (e.key === "Enter") cue();
        });
      if (chipsEl)
        chipsEl.addEventListener("click", function (e) {
          var b = e.target.closest(".chip");
          if (b) generate(b.textContent.trim());
        });

      // --- HACKS standing orders (editable in the Gridiron) -------------------
      // The five sections of the HACKS statement, pre-filled with the canonical
      // text; the visitor may edit, persisted per section in localStorage. They
      // are assembled by assembleHacks() into the souffleur's system instruction
      // (see generate()), so a Gridiron edit changes the next cue's prompt.
      var HACKS_CANON = {
        human: `Sets the scene.
Is the Souffleur of the play.
Does not enter the scene.`,
        agent: `Speaks through Personas.
Acts through Personas.
Observes the Environment through Personas.
Narrates the Environment to bridge where needed through Scenes.
Everything is a Scene.`,
        collaboration: `Personas interact with each other through words and actions.
One move triggers the next.
  The Persona most moved by what just happened responds.
  Not a rotation.
  A Persona might be skipped.
  A Persona might move twice.
  Silence is a move.
The Collaboration rests when it has nowhere left to go.
The Scene remains open.`,
        knowledge: `Behavior is evidence
The Environment is composed of Places and Pieces
The Environment is influenced by Processes and Personas
Personas hold Positions and try to achieve their Plans
Plots drive the Play`,
        system: `A Personas move is prefixed with [Persona]
A Personas action is shown as (stage direction).
Environment settings are shown as _stage direction_.
no em-dash / no en-dash / no dash in prose text.
no Follow-Up Questions
The Narrator does not invite the Human into the Scene.
The Narrator does not explain the Scene.
The Narrator does not explain the behavior.
The Narrator does not announce an open Scene.`,
      };
      function hacksKey(k) {
        return "kai.stage.hacks." + k;
      }
      function loadHacks(k) {
        try {
          var v = localStorage.getItem(hacksKey(k));
          return v === null ? HACKS_CANON[k] : v;
        } catch (e) {
          return HACKS_CANON[k];
        }
      }
      // Element 1 of the cue: the HACKS statement, each section under its label,
      // read live from the Gridiron edits (or the canonical text).
      function assembleHacks() {
        var label = {
          human: "HUMAN",
          agent: "AGENT",
          collaboration: "COLLABORATION",
          knowledge: "KNOWLEDGE",
          system: "SYSTEM",
        };
        return ["human", "agent", "collaboration", "knowledge", "system"]
          .map(function (k) {
            return label[k] + "\n" + loadHacks(k);
          })
          .join("\n\n");
      }
      function initHacks() {
        Object.keys(HACKS_CANON).forEach(function (k) {
          var ta = document.querySelector('[data-hacks="' + k + '"]');
          if (!ta) return;
          ta.value = loadHacks(k);
          ta.addEventListener("input", function () {
            try {
              localStorage.setItem(hacksKey(k), ta.value);
            } catch (e) {}
          });
        });
        document.querySelectorAll("[data-hacks-reset]").forEach(function (btn) {
          btn.addEventListener("click", function () {
            var k = btn.getAttribute("data-hacks-reset");
            var ta = document.querySelector('[data-hacks="' + k + '"]');
            if (!ta) return;
            ta.value = HACKS_CANON[k];
            try {
              localStorage.setItem(hacksKey(k), ta.value);
            } catch (e) {}
          });
        });
      }

      reflectKey();
      renderModelOptions();
      render();
      applyLang();
      initHacks();
    })();
  </script>
</section>
