---
// Contact: the dedicated destination for the §01 Services CTA on main.
//
// Scaffold v1: masthead + a single brick-bordered card with the mailto,
// CVR and a one-line note. No form. Kai iterates copy + adds depth as
// the conversation requires (working hours, the brief shape, etc.).
//
// Same chrome (SiteHeader + SiteFooter) as every other surface so the
// page reads as part of the company front door, not a one-off.
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
---

<BaseLayout
  title="KAI HACKS AI · Contact"
  description="Start a conversation. The direct line for engagement enquiries: workshops, advisory, implementation, transformation."
>
  <div class="arch-page contact-page">
    <SiteHeader domain="kaihacks" tld=".ai" location="contact" />

    <main>
      <header class="ct-mast">
        <div class="ct-overline">the direct line</div>
        <h1 class="ct-h1">Contact<em>.</em></h1>
        <p class="ct-lede">
          Tell me what you're working on: the shape of the team, the question, the constraint. I'll
          come back with what I see and what I'd do next.
        </p>
      </header>

      <section class="ct-card">
        <div class="ct-row">
          <div class="ct-k">Email</div>
          <a class="ct-v ct-mail" href="mailto:info@kaihacks.ai">info@kaihacks.ai</a>
        </div>
        <div class="ct-row">
          <div class="ct-k">CVR</div>
          <div class="ct-v">41768274</div>
        </div>
        <p class="ct-note">
          I read every brief.<br />If it fits, you'll hear back the same week with a first read and
          the shape of an engagement.
        </p>
      </section>
    </main>

    <SiteFooter hideContact />
  </div>

  <style>
    /* Flex column + full-viewport min-height so the sticky SiteFooter
     * pins to the bottom of the viewport on short content. <main>
     * grows to fill the gap between header and footer, AND vertical-
     * centers its content (masthead + card) — without justify-content:
     * center the content top-aligned inside the grown main, which read
     * as the page floating off-balance on tall viewports. */
    .contact-page {
      max-width: 820px;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .contact-page main {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    /* ── masthead ─────────────────────────────────────────────────────── */
    /* Centered axis: overline + h1 + lede all read on a single vertical
     * line, matching the main masthead pattern. The card rows below
     * stay left-aligned (the data is more legible flush-left); only the
     * masthead is centred. */
    .ct-mast {
      padding: 56px 0 38px;
      border-bottom: 1px solid var(--color-rule);
      text-align: center;
    }
    .ct-overline {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.26em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    @media (min-width: 641px) {
      .ct-overline {
        font-size: 11px;
      }
    }
    .ct-h1 {
      margin: 14px 0 18px;
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 52px;
      line-height: 0.94;
      letter-spacing: -0.03em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .ct-h1 {
        font-size: 96px;
      }
    }
    .ct-h1 em {
      font-style: normal;
      color: var(--color-brick);
    }
    .ct-lede {
      margin: 0 auto 16px;
      max-width: 640px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 18px;
      line-height: 1.45;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .ct-lede {
        font-size: 21px;
      }
    }
    /* ── the one card ─────────────────────────────────────────────────── */
    .ct-card {
      margin: 38px 0;
      border: 1px solid var(--color-rule);
      border-top: 4px solid var(--color-brick);
      background: var(--color-paper-warm);
      padding: 26px 22px;
    }
    @media (min-width: 641px) {
      .ct-card {
        padding: 36px 38px;
      }
    }
    /* Card rows are left-aligned — the key column at fixed 70px gives
     * the data a tidy edge. (The masthead is centred; the card stays
     * left-aligned for legibility.) */
    .ct-row {
      display: flex;
      align-items: baseline;
      gap: 18px;
      padding: 10px 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .ct-row:last-of-type {
      border-bottom: none;
    }
    .ct-k {
      flex: 0 0 70px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }
    .ct-v {
      font-family: var(--font-display);
      font-size: 22px;
      color: var(--color-ink);
      letter-spacing: -0.005em;
    }
    @media (min-width: 641px) {
      .ct-v {
        font-size: 26px;
      }
    }
    .ct-mail {
      color: var(--color-brick);
      text-decoration: none;
      border-bottom: 1px solid var(--color-rule);
    }
    .ct-mail:hover {
      border-bottom-color: var(--color-brick);
    }
    /* Two-line centered editorial note: a hard <br /> separates the
     * opening promise ("I read every brief.") from the response
     * commitment. text-align: center keeps both lines balanced under
     * the card's editorial axis. */
    .ct-note {
      margin: 18px auto 0;
      max-width: 620px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 15px;
      line-height: 1.5;
      color: var(--color-ink-soft);
      text-align: center;
    }
  </style>
</BaseLayout>
