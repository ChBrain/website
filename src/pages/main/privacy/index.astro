---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";

// Sub-processors. Each row has its own privacy-policy link.
const processors = [
  {
    who: "GoDaddy",
    what: "Domain registrar and cPanel host. Holds the domain-registration records and serves the site's pages from a shared cPanel server; logs visitor requests for security and abuse.",
    policy: "https://www.godaddy.com/legal/agreements/privacy-policy",
  },
  {
    who: "Cloudflare",
    what: "DNS provider and TLS-terminating reverse proxy. Resolves the site's DNS, issues the HTTPS certificate, and sits between visitors and the GoDaddy origin; processes every visitor's IP address and may set strictly-necessary security cookies (__cf_bm).",
    policy: "https://www.cloudflare.com/privacypolicy/",
  },
  {
    who: "GitHub",
    what: "Hosts the source repositories and downloadable artifacts referenced from this site. When you browse, clone, fork, or download from a GitHub link, your request goes to GitHub and is logged there.",
    policy: "https://docs.github.com/site-policy/privacy-policies/github-privacy-statement",
  },
  {
    who: "Substack",
    what: "Hosts and delivers the newsletter; stores subscriber emails and engagement.",
    policy: "https://substack.com/privacy",
  },
];
---

<BaseLayout
  title="KAI HACKS AI · Privacy Statement"
  description="How KAI HACKS AI handles the small amount of data that passes through this site and its newsletter - who processes it, why, and what you can ask us to do about it."
>
  <div class="arch-page privacy">
    <SiteHeader domain="kaihacks" tld=".ai" location="privacy" />

    <header class="p-mast">
      <div class="p-mono">privacy</div>
      <h1 class="p-h1">Privacy <em>Statement</em></h1>
      <p class="p-lede">
        How KAI HACKS AI handles the small amount of data that passes through this site and its
        newsletter - who processes it, why, and what you can ask us to do about it.
      </p>
      <div class="p-meta">
        <div>
          <span class="p-k">Document</span><span class="p-v">Privacy statement</span>
        </div>
        <div>
          <span class="p-k">Effective</span><span class="p-v">15 March 2026</span>
        </div>
        <div>
          <span class="p-k">Controller</span><span class="p-v"
            >Kai Schlüter, trading as KAI HACKS AI (Denmark, CVR&nbsp;41768274)</span
          >
        </div>
        <div>
          <span class="p-k">Contact</span><span class="p-v">privacy@kaihacks.ai</span>
        </div>
      </div>
    </header>

    <section class="p-section">
      <div class="book-section">
        <span class="book-secno">01</span><h2 class="book-h2">The short version</h2>
      </div>
      <p>
        This is a small site with a newsletter. We don't sell data, we don't run advertising
        trackers, and we collect the minimum needed to serve pages, keep them secure, and send you
        the newsletter if you ask for it. The few companies that help us run it are listed in
        <a href="#vendors" class="book-link">section&nbsp;04</a>.
      </p>
    </section>

    <section class="p-section">
      <div class="book-section">
        <span class="book-secno">02</span><h2 class="book-h2">What we collect</h2>
      </div>
      <h3 class="p-h3">Automatically, when you visit</h3>
      <p>
        Like every website, our hosting and security providers process basic technical data so pages
        load and stay protected:
      </p>
      <ul class="p-list">
        <li>Your <strong>IP address</strong> and approximate region</li>
        <li>Browser and device type, and the pages you request</li>
        <li>Date, time, and referring page</li>
      </ul>
      <p>
        This is handled in server logs by GoDaddy (our host) and in security logs by Cloudflare. We
        don't tie it to your identity. Our legal basis is <strong>legitimate interest</strong>
        (GDPR Art. 6(1)(f)) - serving the site, keeping it secure, preventing abuse.
      </p>

      <h3 class="p-h3">Only when you give it to us</h3>
      <p>
        If you subscribe to the newsletter, you provide your <strong>email address</strong>
        (and optionally a name). That's the only personal information we deliberately collect, and it's
        handled by Substack - see <a href="#newsletter" class="book-link">section&nbsp;03</a>.
      </p>
    </section>

    <section id="newsletter" class="p-section">
      <div class="book-section">
        <span class="book-secno">03</span><h2 class="book-h2">The newsletter</h2>
      </div>
      <p>
        Our newsletter is published on <strong>Substack</strong> at
        <a href="https://combinedcultures.substack.com" class="book-link"
          >combinedcultures.substack.com</a
        >. Subscriptions are handled entirely on Substack's own site. When you click through to
        subscribe, your email address is collected and stored by Substack as part of its own
        service, under <a href="https://substack.com/privacy" class="book-link"
          >Substack's privacy policy</a
        >. We can see open and click engagement in the Substack dashboard. We use it only to send
        the newsletter and gauge whether issues are landing - we don't build subscriber profiles,
        target off-platform advertising, or cross-reference engagement with other sources. Your
        subscription consent is our legal basis (<strong>GDPR Art. 6(1)(a)</strong>).
      </p>
      <p>
        You can unsubscribe at any time using the link in the footer of every email, or by emailing
        us.
      </p>
    </section>

    <section id="vendors" class="p-section">
      <div class="book-section">
        <span class="book-secno">04</span><h2 class="book-h2">Who helps us run this</h2>
      </div>
      <p>
        These are our service providers (sub-processors). Each has its own privacy policy governing
        the data it handles:
      </p>
      <div class="p-proc">
        {
          processors.map((p) => (
            <div class="p-proc-row">
              <div class="p-proc-who">{p.who}</div>
              <div class="p-proc-what">
                {p.what}{" "}
                <a href={p.policy} class="book-link">
                  Policy ↗
                </a>
              </div>
            </div>
          ))
        }
      </div>
      <p>
        We don't share your data with anyone beyond what's needed for these services to function,
        and we never sell it.
      </p>
      <p>
        <strong>International transfers.</strong> Our sub-processors are US-based or operate globally.
        Personal data we share with them may be transferred outside the EU under their own GDPR safeguards
        - EU-US Data Privacy Framework participation and/or Standard Contractual Clauses.
      </p>
    </section>

    <section class="p-section">
      <div class="book-section">
        <span class="book-secno">05</span><h2 class="book-h2">Cookies</h2>
      </div>
      <p>We don't use advertising or analytics-tracking cookies.</p>
      <ul class="p-list">
        <li>
          <strong>Essential security cookies</strong> may be set by Cloudflare (e.g.
          <em>__cf_bm</em>) to tell humans from bots. These are strictly necessary and don't track
          you across sites.
        </li>
        <li>
          No Substack cookies are set on this domain. Subscribing happens entirely on substack.com;
          cookies that Substack sets only apply there.
        </li>
      </ul>
    </section>

    <section class="p-section">
      <div class="book-section">
        <span class="book-secno">06</span><h2 class="book-h2">How long we keep it</h2>
      </div>
      <p>
        Technical logs are retained by our host and Cloudflare for short periods under their own
        policies. Your newsletter email is kept by Substack until you unsubscribe, after which
        Substack removes you from the active list.
      </p>
    </section>

    <section class="p-section">
      <div class="book-section">
        <span class="book-secno">07</span><h2 class="book-h2">Your choices & rights</h2>
      </div>
      <p>You can:</p>
      <ul class="p-list">
        <li>
          <strong>Unsubscribe</strong> (withdraw your consent) instantly via the link in any newsletter
          email, with immediate effect.
        </li>
        <li>
          <strong>Ask what we hold</strong> about you, and ask us to correct or delete it, by emailing
          <a href="mailto:privacy@kaihacks.ai" class="book-link">privacy@kaihacks.ai</a>.
        </li>
      </ul>
      <p>
        KAI HACKS AI operates from the EU (Denmark), so the GDPR applies to how we process your
        data. Under the GDPR you may ask us to access, correct, delete, restrict, or port your data,
        and you may lodge a complaint with your local data-protection authority - in Denmark that's
        <a href="https://www.datatilsynet.dk/" class="book-link">Datatilsynet</a>. Visitors from the
        UK or California may have additional or analogous rights (UK GDPR, CCPA); contact us at the
        address above to exercise any of them.
      </p>
    </section>

    <section class="p-section p-section--last">
      <div class="p-last-center">
        <div class="book-section">
          <span class="book-secno">08</span><h2 class="book-h2">Changes</h2>
        </div>
        <p>
          If we change how we handle data, we'll update this page and move the effective date at the
          top. Material changes to the newsletter will be noted in the newsletter itself.
        </p>
      </div>

      {
        /* Colophon inside the last panel so it lands in-viewport on snap,
        not below the fold needing an extra scroll. */
      }
      <footer class="p-foot">
        <p class="p-mono p-foot-line">KAI HACKS AI · Privacy statement</p>
        <p class="p-mono p-foot-line">Effective 15 March 2026 · privacy@kaihacks.ai</p>
      </footer>
    </section>

    <SiteFooter />
  </div>

  <style is:global>
    /* Chapter snap, scoped to the privacy surface (mirrors CVI). The
     * document snaps section-by-section; long legal sections overflow
     * and scroll internally before the next stop. Disabled on mobile,
     * where snap is friction on a long read. */
    html:has(.privacy) {
      scroll-snap-type: y mandatory;
      scroll-padding-top: 4rem;
      scroll-padding-bottom: 4rem;
      scroll-behavior: smooth;
    }
    @media (max-width: 640px) {
      html:has(.privacy) {
        scroll-snap-type: none;
      }
    }
  </style>

  <style>
    /* Legal-doc inner column. The .arch-page wrapper gives us the
     * 1080px chrome-aligned container; this narrower column keeps the
     * reading text comfortable. The numbered section head (.book-section /
     * .book-secno / .book-h2) and the link (.book-link) are the shared
     * khaibook typesetting (book.css) -- this page only adds its own
     * doc-specific layout (masthead, meta grid, list markers, the
     * sub-processor table, the snap chassis). */
    .privacy {
      max-width: 820px;
    }

    /* ── chapter snap ───────────────────────────────────────────────────── */
    .p-mast,
    .p-section {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    @media (min-width: 641px) {
      /* Each section fills the viewport (minus sticky chrome) and
       * vertical-centers its content, matching CVI's center-snap. */
      .p-mast,
      .p-section {
        min-height: calc(100vh - 8rem);
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
    }
    @media (max-width: 640px) {
      .p-mast,
      .p-section {
        scroll-snap-align: none;
        scroll-snap-stop: normal;
      }
    }
    /* §08 centers its content and pins the colophon to the panel bottom,
     * so both land in one viewport on snap. */
    .p-last-center {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .p-mono {
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 11px;
      color: var(--color-ink-mute);
    }

    /* ── masthead ───────────────────────────────────────────────────────── */
    .p-mast {
      padding: 56px 0 38px;
      border-bottom: 1px solid var(--color-rule);
    }
    .p-h1 {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 46px;
      line-height: 1.05;
      letter-spacing: -0.018em;
      margin: 14px 0 18px;
      color: var(--color-ink);
    }
    .p-h1 em {
      font-style: italic;
      color: var(--color-ink-soft);
    }
    .p-lede {
      font-size: 18px;
      color: var(--color-ink);
      line-height: 1.55;
      margin: 0 0 16px;
    }
    /* 2-column grid keeps the 4 meta rows aligned in a tidy block
     * (Document | Effective on top, Controller | Contact below) rather
     * than wrapping unpredictably as a flex-wrap row. The right column
     * has the "Effective" key hang against the right edge of the column
     * gap, balancing the left column's longer "Document" value. */
    .p-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px 48px;
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid var(--color-rule-soft);
    }
    .p-meta div span {
      display: block;
    }
    @media (max-width: 600px) {
      .p-meta {
        grid-template-columns: 1fr;
        gap: 18px;
      }
    }
    .p-k {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--color-ink-mute);
      margin-bottom: 5px;
    }
    .p-v {
      font-size: 15px;
      color: var(--color-ink);
    }

    /* ── sections ───────────────────────────────────────────────────────── */
    .p-section {
      padding: 38px 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .p-section--last {
      border-bottom: none;
    }
    /* the shared .book-section head, with this page's section spacing */
    .privacy .book-section {
      margin-bottom: 18px;
    }
    .p-h3 {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin: 22px 0 9px;
      color: var(--color-ink);
    }

    .privacy p {
      margin: 0 0 16px;
      text-wrap: pretty;
      color: var(--color-ink-soft);
    }
    .privacy strong {
      font-weight: 600;
      color: var(--color-ink);
    }
    .privacy em {
      font-style: italic;
    }

    .p-list {
      margin: 0 0 16px;
      padding-left: 0;
      list-style: none;
    }
    .p-list li {
      color: var(--color-ink-soft);
      line-height: 1.5;
      margin-bottom: 9px;
      padding-left: 20px;
      position: relative;
    }
    .p-list li::before {
      content: "-";
      position: absolute;
      left: 0;
      color: var(--color-rule);
      font-family: var(--font-mono);
    }

    /* ── sub-processor table ────────────────────────────────────────────── */
    .p-proc {
      border: 1px solid var(--color-rule-soft);
      border-radius: 3px;
      overflow: hidden;
      margin: 6px 0 16px;
    }
    .p-proc-row {
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .p-proc-row:last-child {
      border-bottom: none;
    }
    .p-proc-row:nth-child(even) {
      background: var(--color-paper-warm);
    }
    .p-proc-row > div {
      padding: 13px 16px;
    }
    .p-proc-who {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--color-ink);
      border-right: 1px solid var(--color-rule-soft);
      display: flex;
      align-items: center;
    }
    .p-proc-what {
      font-size: 14.5px;
      color: var(--color-ink-soft);
      line-height: 1.45;
    }
    .p-proc-what a {
      font-size: 12px;
    }

    /* ── footer ─────────────────────────────────────────────────────────── */
    .p-foot {
      padding: 40px 0 8px;
    }
    .p-foot-line {
      line-height: 1.9;
    }
    @media (max-width: 640px) {
      /* No snap on mobile - restore breathing room before the SiteFooter. */
      .p-foot {
        padding: 32px 0 48px;
      }
    }

    @media (max-width: 600px) {
      .p-proc-row {
        grid-template-columns: 1fr;
      }
      .p-proc-who {
        border-right: none;
        border-bottom: 1px solid var(--color-rule-soft);
      }
    }
  </style>
</BaseLayout>
