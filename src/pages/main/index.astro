---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { URLS } from "../../lib/urls";

const mainNav = [
  { label: "architecture", href: URLS.architecture },
  { label: "cultures", href: "#" },
  { label: "services", href: "#services" },
];

// §01 Services – domains (AIDE acrostic) × engagement.
// AIDE: AI · ITSM · DevOps · Enterprise Architecture – first letter of each
// is bricked at render time. Do not reorder or rename; breaks the acrostic.
const domains = ["AI", "ITSM", "DevOps", "Enterprise Architecture"];
const engage = [
  { t: "Advisory", g: "direction, review, architecture" },
  { t: "Implementation", g: "hands on the build" },
  { t: "Workshops", g: "the method, taught to your teams" },
];

// §02 Author – the range · AI → delivery → AI.
// Bookends (2004 TU München, 2026 KAI HACKS AI) are flagged ai: true and
// render with a brick dot. Order is canonical and asserted by tests.
const arc = [
  { y: "2004", co: "TU München", role: "AI research", ai: true },
  { y: "2006–’12", co: "Telefónica", role: "Architecture · ITSM · EA", ai: false },
  { y: "2012–’20", co: "Danfoss", role: "EA · IT innovation", ai: false },
  { y: "2021", co: "q.beyond", role: "CTO · Chief EA", ai: false },
  { y: "2023", co: "FLS", role: "Head of IT · infra · ops", ai: false },
  { y: "2026", co: "KAI HACKS AI", role: "AI · worlds · cultures", ai: true },
];

// §03 Method – the name reads itself. HACKS is bricked.
// Each sense is the acronym expansion, not a grammar label.
const movements = [
  {
    t: "KAI",
    sense: "Kais Architecture Instructions",
    gloss: "who builds · the architect",
    accent: false,
  },
  {
    t: "HACKS",
    sense: "Human Agent Collaboration Knowledge System",
    gloss: "how it operates · the method",
    accent: true,
  },
  {
    t: "AI",
    sense: "Agent Implemented",
    gloss: "how it runs · the optional layer",
    accent: false,
  },
];

// §04 Applications – what runs on the architecture.
const apps = [
  {
    hue: "tide",
    url: "cultures.kaihacks.ai",
    title: "Cultures",
    note: "an application for culture trainers – and the culture-curious",
    href: "#",
    state: "live",
    planned: false,
  },
  {
    hue: "rule",
    url: "–",
    title: "More applications",
    note: "the architecture is built to spawn them",
    href: "#",
    state: "in progress",
    planned: true,
  },
];
---

<BaseLayout
  title="kaihacks.ai · KAI HACKS AI"
  description="An enterprise architect’s method – applied across AI, ITSM, DevOps and enterprise architecture, with or without AI."
>
  <div class="arch-page main-home">
    <SiteHeader domain="kaihacks" tld=".ai" basePath="./" nav={mainNav} />

    <main class="snap-scroll">
      <section class="snap-panel masthead">
        <div class="overline">the company · est. 2026</div>
        <h1 class="masthead-title" aria-label="KAI HACKS AI">
          <span>KAI</span>
          <span class="masthead-title-accent">HACKS</span>
          <span>AI</span>
        </h1>
        <p class="lede">
          An enterprise architect’s method – applied across AI, ITSM, DevOps and enterprise
          architecture, with or without AI. The name is the method: it states who builds, how they
          operate, and how it runs.
        </p>
        <div class="draft-marker">
          <span class="draft-dot" aria-hidden="true"></span>draft · authored by Kai – the
          positioning, in your words
        </div>
      </section>

      <section id="services" class="snap-panel section section--services">
        <div class="section-heading">
          <div class="section-heading-lead">
            <span class="section-no">§01</span>
            <span class="section-title">Services</span>
          </div>
          <div class="section-note">have the method built for you</div>
        </div>

        <div class="services-card">
          <p class="services-lead">
            Enterprise architecture, applied to your organisation’s domain, teams and workflows.
          </p>

          <div class="services-grid">
            <div class="services-col">
              <div class="services-col-head">What we work in</div>
              {
                domains.map((d) =>
                  // prettier-ignore
                  <div class="services-domain"><span class="services-domain-initial">{d.charAt(0)}</span>{d.slice(1)}</div>,
                )
              }
              <div class="services-domain services-domain--coda">…you name it</div>
            </div>

            <div class="services-col">
              <div class="services-col-head">How we engage</div>
              {
                engage.map((e) => (
                  <div class="services-engage">
                    <div class="services-engage-name">{e.t}</div>
                    <div class="services-engage-gloss">{e.g}</div>
                  </div>
                ))
              }
            </div>
          </div>

          <a href="#contact" class="services-cta">Start a conversation →</a>
        </div>
      </section>

      <section id="author" class="snap-panel section section--author">
        <div class="section-heading">
          <div class="section-heading-lead">
            <span class="section-no">§02</span>
            <span class="section-title">The Founder</span>
          </div>
          <div class="section-note">the range · AI → delivery → AI</div>
        </div>

        <p class="author-lede">
          AI in 2004, AI in 2026 – and twenty-two years across enterprise IT in between:
          architecture, ITSM, DevOps, infrastructure, operations. The arc is the proof the method is
          earned – and the <span class="brick">range</span> it covers.
        </p>

        <ol class="arc">
          {
            arc.map((a) => (
              <li class={`arc-step ${a.ai ? "arc-step--ai" : ""}`}>
                <span class="arc-dot" aria-hidden="true" />
                <span class="arc-year">{a.y}</span>
                <span class="arc-co">{a.co}</span>
                <span class="arc-role">{a.role}</span>
              </li>
            ))
          }
        </ol>
      </section>

      <section id="method" class="snap-panel section section--method">
        <div class="section-heading">
          <div class="section-heading-lead">
            <span class="section-no">§03</span>
            <span class="section-title">Method &amp; Architecture</span>
          </div>
          <div class="section-note">the name reads itself · and what it runs on</div>
        </div>

        <div class="movements">
          {
            movements.map((m, i) => (
              <div class="movement">
                <div class="movement-meta">
                  {String(i + 1).padStart(2, "0")} · {m.sense}
                </div>
                <div class={`movement-token ${m.accent ? "movement-token--accent" : ""}`}>
                  {m.t}
                </div>
                <div class="movement-gloss">{m.gloss}</div>
              </div>
            ))
          }
        </div>

        <div class="architecture-sub">
          <span class="architecture-sub-label">Architecture · what the method runs on</span>
          <span class="architecture-sub-rule" aria-hidden="true"></span>
        </div>

        <a href={URLS.architecture} class="architecture-card">
          <div class="architecture-card-hue" aria-hidden="true"></div>
          <div class="architecture-card-body">
            <div class="architecture-card-row">
              <span class="architecture-card-url">architecture.kaihacks.ai</span>
              <span class="architecture-card-state">live · the foundation</span>
            </div>
            <div class="architecture-card-title">Architecture</div>
            <p class="architecture-card-note">
              A specification I built – the foundation its applications run on.
            </p>
            <span class="architecture-card-cta">Read the full specification →</span>
          </div>
        </a>
      </section>

      <section id="apps" class="snap-panel section section--applications">
        <div class="section-heading">
          <div class="section-heading-lead">
            <span class="section-no">§04</span>
            <span class="section-title">Applications</span>
          </div>
          <div class="section-note">what runs on the architecture</div>
        </div>

        <div class="apps">
          {
            apps.map((a) => (
              <a class={`app app--${a.hue} ${a.planned ? "app--planned" : ""}`} href={a.href}>
                {!a.planned && <div class={`app-hue app-hue--${a.hue}`} aria-hidden="true" />}
                <div class="app-body">
                  <div class="app-row">
                    <span class="app-url">{a.url}</span>
                    <span class={`app-state ${a.state === "live" ? "app-state--live" : ""}`}>
                      {a.state}
                    </span>
                  </div>
                  <div class="app-title">{a.title}</div>
                  <div class="app-note">{a.note}</div>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>

  <style is:global>
    /* Chapter snap on the document, only when this page is rendered.
     * Mirrors src/pages/main/cvi/index.astro. The viewport (html) is the
     * scroll container; putting scroll-snap-type on any nested in-flow
     * element is a no-op. `:has(.main-home)` scopes the rule to this
     * page so other surfaces (privacy, architecture) keep free scrolling.
     * scroll-padding-top/bottom match the sticky SiteHeader + SiteFooter
     * heights so snapped chapters land below the topbar rather than
     * under it. Disabled on narrow viewports – snap is friction on
     * phones, and a pitch page reads better as one long scroll there. */
    html:has(.main-home) {
      scroll-snap-type: y mandatory;
      scroll-padding-top: 4rem;
      scroll-padding-bottom: 4rem;
      scroll-behavior: smooth;
    }
    @media (max-width: 640px) {
      html:has(.main-home) {
        scroll-snap-type: none;
      }
    }
  </style>

  <style>
    /* topbar + footer styles live in SiteHeader.astro + SiteFooter.astro */

    /* ── snap chassis (CVI parity) ──────────────────────────────────────────
     * snap-type lives on `html:has(.main-home)` in the is:global block
     * above; here we set the per-panel snap-align and the viewport-height
     * sizing that makes each chapter stand on its own. SiteFooter sits
     * outside main.snap-scroll so it scrolls past the last snap point. */
    .snap-panel {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    @media (min-width: 641px) {
      .snap-panel {
        min-height: calc(100vh - 8rem);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-top: 2.25rem;
        padding-bottom: 2.25rem;
      }
    }
    @media (max-width: 640px) {
      .snap-panel {
        scroll-snap-align: none;
        scroll-snap-stop: normal;
      }
    }

    /* ── masthead ───────────────────────────────────────────────────────── */
    .masthead {
      padding: 1.875rem 0 1.75rem;
    }
    @media (min-width: 641px) {
      .masthead {
        /* snap-panel handles vertical centring; reset the legacy top/bottom */
        padding: 4.375rem 0 2.75rem;
      }
    }
    .overline {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.26em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    @media (min-width: 641px) {
      .overline {
        font-size: 11px;
      }
    }
    .masthead-title {
      margin: 18px 0 0;
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 52px;
      line-height: 0.94;
      letter-spacing: -0.03em;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      column-gap: 0.26em;
    }
    @media (min-width: 641px) {
      .masthead-title {
        font-size: 128px;
      }
    }
    .masthead-title-accent {
      color: var(--color-brick);
    }
    .lede {
      margin: 22px 0 0;
      max-width: 730px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 18px;
      line-height: 1.4;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .lede {
        margin-top: 28px;
        font-size: 25px;
      }
    }
    .draft-marker {
      margin-top: 14px;
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.2em;
      color: var(--color-amber);
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .draft-dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      background: var(--color-amber);
    }

    /* ── sections shared ────────────────────────────────────────────────── */
    .section {
      padding: 8px 0 12px;
    }
    .section-heading {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
      border-bottom: 1px solid var(--color-rule);
      padding-bottom: 10px;
    }
    @media (min-width: 641px) {
      .section-heading {
        flex-direction: row;
        align-items: baseline;
        gap: 0;
      }
    }
    .section-heading-lead {
      display: flex;
      align-items: baseline;
      gap: 14px;
    }
    .section-no {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-brick);
      text-transform: uppercase;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .section-title {
        font-size: 26px;
      }
    }
    .section-note {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }

    /* ── §01 services – domains × engagement · the one brick CTA ────────── */
    .services-card {
      margin-top: 24px;
      border: 1px solid var(--color-rule);
      border-top: 4px solid var(--color-brick);
      background: var(--color-paper-warm);
      padding: 26px 22px;
    }
    @media (min-width: 641px) {
      .services-card {
        padding: 38px 40px;
      }
    }
    .services-lead {
      margin: 0;
      font-family: var(--font-display);
      font-size: 26px;
      font-weight: 350;
      line-height: 1.12;
      letter-spacing: -0.01em;
      max-width: 760px;
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .services-lead {
        font-size: 36px;
      }
    }
    .services-grid {
      margin-top: 26px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 26px;
    }
    @media (min-width: 641px) {
      .services-grid {
        grid-template-columns: 1.15fr 1fr;
        gap: 44px;
        margin-top: 30px;
      }
    }
    .services-col-head {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--color-rule);
    }
    .services-domain {
      padding: 9px 0;
      border-bottom: 1px solid var(--color-rule-soft);
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .services-domain {
        font-size: 26px;
      }
    }
    .services-domain-initial {
      color: var(--color-brick);
    }
    .services-domain--coda {
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 15px;
      color: var(--color-ink-mute);
      border-bottom: none;
    }
    .services-engage {
      padding: 11px 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .services-engage-name {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 500;
      color: var(--color-ink);
      letter-spacing: -0.005em;
    }
    @media (min-width: 641px) {
      .services-engage-name {
        font-size: 19px;
      }
    }
    .services-engage-gloss {
      margin-top: 2px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 13.5px;
      color: var(--color-ink-soft);
    }
    .services-cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-top: 26px;
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--color-paper);
      background: var(--color-brick);
      padding: 15px 26px;
      text-decoration: none;
    }
    .services-cta:hover {
      background: var(--color-accent-hover);
    }
    @media (min-width: 641px) {
      .services-cta {
        margin-top: 32px;
      }
    }

    /* ── §02 author – the timeline ──────────────────────────────────────── */
    .author-lede {
      margin: 18px 0 0;
      max-width: 700px;
      font-family: var(--font-prose);
      font-size: 16px;
      line-height: 1.55;
      color: var(--color-ink);
      text-wrap: pretty;
    }
    .brick {
      color: var(--color-brick);
    }
    .arc {
      list-style: none;
      margin: 26px 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      position: relative;
    }
    @media (min-width: 641px) {
      .arc {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 6px;
      }
      .arc::before {
        content: "";
        position: absolute;
        left: 6px;
        right: 6px;
        top: 6px;
        height: 1px;
        background: var(--color-ink);
      }
    }
    .arc-step {
      position: relative;
      padding: 12px 0 12px 20px;
      border-left: 1px solid var(--color-rule);
      margin-left: 5px;
      display: grid;
      grid-template-columns: auto auto 1fr;
      column-gap: 12px;
      align-items: baseline;
    }
    @media (min-width: 641px) {
      .arc-step {
        padding: 0;
        border-left: none;
        margin-left: 0;
        display: block;
      }
    }
    .arc-dot {
      position: absolute;
      left: -6px;
      top: 15px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--color-paper);
      border: 1.5px solid var(--color-ink);
    }
    @media (min-width: 641px) {
      .arc-dot {
        position: static;
        display: block;
        margin-bottom: 8px;
      }
    }
    .arc-step--ai .arc-dot {
      width: 13px;
      height: 13px;
      background: var(--color-brick);
      border: none;
    }
    @media (min-width: 641px) {
      .arc-step--ai .arc-dot {
        margin-bottom: 5px;
      }
    }
    .arc-year {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      color: var(--color-ink-soft);
    }
    @media (min-width: 641px) {
      .arc-year {
        display: block;
        margin-top: 8px;
      }
    }
    .arc-step--ai .arc-year {
      color: var(--color-brick);
      font-weight: 600;
    }
    .arc-co {
      font-family: var(--font-display);
      font-size: 18px;
      line-height: 1.1;
      color: var(--color-ink);
      font-weight: 500;
    }
    @media (min-width: 641px) {
      .arc-co {
        display: block;
        font-size: 17px;
        margin-top: 4px;
      }
    }
    .arc-role {
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 12.5px;
      color: var(--color-ink-soft);
      line-height: 1.35;
    }
    @media (min-width: 641px) {
      .arc-role {
        display: block;
        margin-top: 3px;
      }
    }

    /* ── §03 method & architecture ──────────────────────────────────────── */
    .movements {
      margin-top: 22px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
    }
    @media (min-width: 641px) {
      .movements {
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }
    }
    .movement {
      padding: 18px 0;
      border-top: 1px solid var(--color-rule);
    }
    @media (min-width: 641px) {
      .movement {
        padding: 4px 0;
        border-top: none;
      }
    }
    .movement-meta {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }
    .movement-token {
      font-family: var(--font-display);
      font-size: 34px;
      font-weight: 400;
      letter-spacing: -0.01em;
      margin-top: 6px;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .movement-token {
        font-size: 40px;
      }
    }
    .movement-token--accent {
      color: var(--color-brick);
    }
    .movement-gloss {
      margin-top: 4px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 15px;
      color: var(--color-ink-soft);
    }
    /* sub-divider – folded under §03, not its own § */
    .architecture-sub {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 30px 0 4px;
    }
    .architecture-sub-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }
    .architecture-sub-rule {
      flex: 1;
      height: 1px;
      background: var(--color-rule-soft);
    }
    .architecture-card {
      display: block;
      text-decoration: none;
      color: var(--color-ink);
      margin-top: 24px;
      border: 1px solid var(--color-ink);
      background: var(--color-paper-warm);
      overflow: hidden;
      transition:
        transform 0.16s,
        box-shadow 0.16s;
    }
    .architecture-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px -16px var(--color-ink);
    }
    .architecture-card-hue {
      height: 6px;
      background: var(--color-sea);
    }
    .architecture-card-body {
      padding: 18px 20px 20px;
    }
    @media (min-width: 641px) {
      .architecture-card-body {
        padding: 26px 30px;
      }
    }
    .architecture-card-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 12px;
      flex-wrap: wrap;
    }
