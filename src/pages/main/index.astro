---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const mainNav = [
  { label: "architecture", href: "https://architecture.kaihacks.ai/" },
  { label: "cultures", href: "#" },
  { label: "services", href: "#services" },
];

const arc = [
  { y: "2004", co: "TU München", role: "AI research", ai: true },
  { y: "2006–’12", co: "Telefónica", role: "Architecture · ITSM · EA", ai: false },
  { y: "2012–’20", co: "Danfoss", role: "EA · IT innovation", ai: false },
  { y: "2021", co: "q.beyond", role: "CTO · Chief EA", ai: false },
  { y: "2023", co: "FLS", role: "Head of IT · infra · ops", ai: false },
  { y: "2026", co: "KAI HACKS AI", role: "AI · worlds · cultures", ai: true },
];

const movements = [
  { t: "KAI", sense: "the noun", gloss: "who builds · and what", accent: false },
  { t: "HACKS", sense: "the verbs", gloss: "how it operates", accent: true },
  { t: "AI", sense: "the verb", gloss: "how it runs", accent: false },
];

const apps = [
  {
    hue: "sea",
    url: "architecture.kaihacks.ai",
    title: "Architecture",
    note: "the method, documented – the specification",
    href: "https://architecture.kaihacks.ai/",
    state: "live",
  },
  {
    hue: "tide",
    url: "cultures.kaihacks.ai",
    title: "Cultures",
    note: "a runtime – the method implemented",
    href: "#",
    state: "live",
  },
  {
    hue: "amber",
    url: "photo.kaihacks.ai",
    title: "Photography",
    note: "the author’s eye",
    href: "#",
    state: "planned",
  },
  {
    hue: "marsh",
    url: "combinedcultures",
    title: "Writing",
    note: "the author’s voice",
    href: "#",
    state: "external ↗",
  },
];
---

<BaseLayout
  title="kaihacks.ai · KAI HACKS AI"
  description="A specification for runnable human-agent systems – and the practice that builds them."
>
  <div class="arch-page main-home">
    <SiteHeader domain="kaihacks" tld=".ai" basePath="./" nav={mainNav} />

    <section class="masthead">
      <div class="overline">the company · est. 2026</div>
      <h1 class="masthead-title" aria-label="KAI HACKS AI">
        <span>KAI</span>
        <span class="masthead-title-accent">HACKS</span>
        <span>AI</span>
      </h1>
      <div class="readout">
        Kais Artificial Intelligences ·
        <span class="readout-soft">KI is German for AI</span>
      </div>
      <p class="lede">
        A specification for runnable human-agent systems – and the practice that builds them. The
        name is the method: it states who builds, how they operate, and how it runs.
      </p>
      <div class="draft-marker">
        <span class="draft-dot" aria-hidden="true"></span>draft · authored by Kai – the positioning,
        in your words
      </div>
    </section>

    <section class="section section--method">
      <div class="section-heading">
        <div class="section-heading-lead">
          <span class="section-no">§01</span>
          <span class="section-title">The method</span>
        </div>
        <div class="section-note">the name reads itself</div>
      </div>

      <div class="movements">
        {
          movements.map((m, i) => (
            <div class="movement">
              <div class="movement-meta">
                {String(i + 1).padStart(2, "0")} · {m.sense}
              </div>
              <div class={`movement-token ${m.accent ? "movement-token--accent" : ""}`}>{m.t}</div>
              <div class="movement-gloss">{m.gloss}</div>
            </div>
          ))
        }
      </div>

      <div class="method-cta">
        <a href="https://architecture.kaihacks.ai/" class="method-cta-link">
          <span>Read the full specification</span>
          <span class="method-cta-arrow">architecture.kaihacks.ai →</span>
        </a>
      </div>
    </section>

    <section class="section section--author">
      <div class="section-heading">
        <div class="section-heading-lead">
          <span class="section-no">§02</span>
          <span class="section-title">The author</span>
        </div>
        <div class="section-note">the method is earned · AI → delivery → AI</div>
      </div>

      <p class="author-lede">
        AI in 2004, AI in 2026 – twenty-two years of IT delivery in between. The arc is not the
        story; it is the <span class="brick">proof</span> the method is earned.
      </p>

      <ol class="arc">
        {
          arc.map((a) => (
            <li class={`arc-step ${a.ai ? "arc-step--ai" : ""}`}>
              <span class="arc-dot" aria-hidden="true" />
              <span class="arc-year">{a.y}</span>
              <span class="arc-co">{a.co}</span>
              <span class="arc-role">{a.role}</span>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="section section--applications">
      <div class="section-heading">
        <div class="section-heading-lead">
          <span class="section-no">§03</span>
          <span class="section-title">The applications</span>
        </div>
        <div class="section-note">one method · several registers</div>
      </div>

      <div class="apps">
        {
          apps.map((a) => (
            <a class={`app app--${a.hue} ${a.state === "planned" ? "app--dim" : ""}`} href={a.href}>
              <div class={`app-hue app-hue--${a.hue}`} aria-hidden="true" />
              <div class="app-body">
                <div class="app-row">
                  <span class="app-url">{a.url}</span>
                  <span class={`app-state ${a.state === "live" ? "app-state--live" : ""}`}>
                    {a.state}
                  </span>
                </div>
                <div class="app-title">{a.title}</div>
                <div class="app-note">{a.note}</div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section section--services" id="services">
      <div class="section-heading">
        <div class="section-heading-lead">
          <span class="section-no">§04</span>
          <span class="section-title">Services</span>
        </div>
        <div class="section-note">have the method built for you</div>
      </div>

      <div class="services-card">
        <p class="services-lead">
          The method, applied to your organisation’s domain, teams, and workflows.
        </p>
        <div class="services-tags">
          <span class="services-tag">Advisory</span>
          <span class="services-tag">Implementation</span>
          <span class="services-tag">Workshops</span>
          <span class="services-tag services-tag--draft">draft · split pending</span>
        </div>
        <a href="#contact" class="services-cta">Start a conversation →</a>
      </div>
    </section>

    <SiteFooter siteLabel="kaihacks.ai · the company" />
  </div>

  <style>
    /* topbar + footer styles live in SiteHeader.astro + SiteFooter.astro */

    /* ── masthead ───────────────────────────────────────────────────────── */
    .masthead {
      padding: 1.875rem 0 1.75rem;
    }
    @media (min-width: 641px) {
      .masthead {
        padding: 4.375rem 0 2.75rem;
      }
    }
    .overline {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.26em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    @media (min-width: 641px) {
      .overline {
        font-size: 11px;
      }
    }
    .masthead-title {
      margin: 18px 0 0;
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 52px;
      line-height: 0.94;
      letter-spacing: -0.03em;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      column-gap: 0.26em;
    }
    @media (min-width: 641px) {
      .masthead-title {
        font-size: 128px;
      }
    }
    .masthead-title-accent {
      color: var(--color-brick);
    }
    .readout {
      margin-top: 12px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    @media (min-width: 641px) {
      .readout {
        font-size: 11px;
      }
    }
    .readout-soft {
      color: var(--color-brick);
      text-transform: none;
      letter-spacing: 0.02em;
      font-style: italic;
    }
    .lede {
      margin: 22px 0 0;
      max-width: 720px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 18px;
      line-height: 1.38;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .lede {
        margin-top: 28px;
        font-size: 25px;
      }
    }
    .draft-marker {
      margin-top: 14px;
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.2em;
      color: var(--color-amber);
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .draft-dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      background: var(--color-amber);
    }

    /* ── sections shared ────────────────────────────────────────────────── */
    .section {
      padding: 8px 0 12px;
    }
    .section--author,
    .section--applications,
    .section--services {
      padding-top: 40px;
    }
    .section-heading {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
      border-bottom: 1px solid var(--color-rule);
      padding-bottom: 10px;
    }
    @media (min-width: 641px) {
      .section-heading {
        flex-direction: row;
        align-items: baseline;
        gap: 0;
      }
    }
    .section-heading-lead {
      display: flex;
      align-items: baseline;
      gap: 14px;
    }
    .section-no {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-brick);
      text-transform: uppercase;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .section-title {
        font-size: 26px;
      }
    }
    .section-note {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }

    /* ── §01 method ─────────────────────────────────────────────────────── */
    .movements {
      margin-top: 22px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
    }
    @media (min-width: 641px) {
      .movements {
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }
    }
    .movement {
      padding: 18px 0;
      border-top: 1px solid var(--color-rule);
    }
    @media (min-width: 641px) {
      .movement {
        padding: 4px 0;
        border-top: none;
      }
    }
    .movement-meta {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }
    .movement-token {
      font-family: var(--font-display);
      font-size: 34px;
      font-weight: 400;
      letter-spacing: -0.01em;
      margin-top: 6px;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .movement-token {
        font-size: 40px;
      }
    }
    .movement-token--accent {
      color: var(--color-brick);
    }
    .movement-gloss {
      margin-top: 4px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 15px;
      color: var(--color-ink-soft);
    }
    .method-cta {
      margin-top: 22px;
      border-top: 1px solid var(--color-ink);
      padding-top: 16px;
    }
    .method-cta-link {
      display: inline-flex;
      align-items: baseline;
      gap: 12px;
      text-decoration: none;
      color: var(--color-ink);
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 400;
      letter-spacing: -0.01em;
      border-bottom: 2px solid var(--color-brick);
      padding-bottom: 4px;
    }
    @media (min-width: 641px) {
      .method-cta-link {
        font-size: 24px;
      }
    }
    .method-cta-arrow {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      color: var(--color-brick);
    }

    /* ── §02 author ─────────────────────────────────────────────────────── */
    .author-lede {
      margin: 18px 0 0;
      max-width: 680px;
      font-family: var(--font-prose);
      font-size: 16px;
      line-height: 1.55;
      color: var(--color-ink);
      text-wrap: pretty;
    }
    .brick {
      color: var(--color-brick);
    }
    .arc {
      list-style: none;
      margin: 26px 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      position: relative;
    }
    @media (min-width: 641px) {
      .arc {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 6px;
      }
      .arc::before {
        content: "";
        position: absolute;
        left: 6px;
        right: 6px;
        top: 6px;
        height: 1px;
        background: var(--color-ink);
      }
    }
    .arc-step {
      position: relative;
      padding: 12px 0 12px 20px;
      border-left: 1px solid var(--color-rule);
      margin-left: 5px;
      display: grid;
      grid-template-columns: auto auto 1fr;
      column-gap: 12px;
      align-items: baseline;
    }
    @media (min-width: 641px) {
      .arc-step {
        padding: 0;
        border-left: none;
        margin-left: 0;
        display: block;
      }
    }
    .arc-dot {
      position: absolute;
      left: -6px;
      top: 15px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--color-paper);
      border: 1.5px solid var(--color-ink);
    }
    @media (min-width: 641px) {
      .arc-dot {
        position: static;
        display: block;
        margin-bottom: 8px;
      }
    }
    .arc-step--ai .arc-dot {
      width: 13px;
      height: 13px;
      background: var(--color-brick);
      border: none;
    }
    @media (min-width: 641px) {
      .arc-step--ai .arc-dot {
        margin-bottom: 5px;
      }
    }
    .arc-year {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      color: var(--color-ink-soft);
    }
    @media (min-width: 641px) {
      .arc-year {
        display: block;
        margin-top: 8px;
      }
    }
    .arc-step--ai .arc-year {
      color: var(--color-brick);
      font-weight: 600;
    }
    .arc-co {
      font-family: var(--font-display);
      font-size: 18px;
      line-height: 1.1;
      color: var(--color-ink);
      font-weight: 500;
    }
    @media (min-width: 641px) {
      .arc-co {
        display: block;
        font-size: 17px;
        margin-top: 4px;
      }
    }
    .arc-role {
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 12.5px;
      color: var(--color-ink-soft);
      line-height: 1.35;
    }
    @media (min-width: 641px) {
      .arc-role {
        display: block;
        margin-top: 3px;
      }
    }

    /* ── §03 applications ───────────────────────────────────────────────── */
    .apps {
      margin-top: 24px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }
    @media (min-width: 641px) {
      .apps {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    .app {
      display: block;
      text-decoration: none;
      color: var(--color-ink);
      border: 1px solid var(--color-ink);
      background: var(--color-paper-warm);
      overflow: hidden;
    }
    .app--dim {
      opacity: 0.6;
    }
    .app-hue {
      height: 6px;
    }
    .app-hue--sea {
      background: var(--color-sea);
    }
    .app-hue--tide {
      background: var(--color-tide);
    }
    .app-hue--amber {
      background: var(--color-amber);
    }
    .app-hue--marsh {
      background: var(--color-marsh);
    }
    .app-body {
      padding: 16px 18px;
    }
    .app-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 10px;
    }
    .app-url {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    .app-state {
      font-family: var(--font-mono);
      font-size: 8.5px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }
    .app-state--live {
      color: var(--color-brick);
    }
    .app-title {
      font-family: var(--font-display);
      font-size: 24px;
      line-height: 1.1;
      margin-top: 8px;
      font-weight: 400;
      letter-spacing: -0.01em;
    }
    .app-note {
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 14px;
      color: var(--color-ink-soft);
      margin-top: 4px;
      line-height: 1.4;
    }

    /* ── §04 services ───────────────────────────────────────────────────── */
    .services-card {
      margin-top: 24px;
      border: 1px solid var(--color-rule);
      border-left: 4px solid var(--color-brick);
      background: var(--color-paper-warm);
      padding: 24px 22px;
    }
    @media (min-width: 641px) {
      .services-card {
        padding: 32px 36px;
      }
    }
    .services-lead {
      margin: 0;
      font-family: var(--font-display);
      font-size: 26px;
      font-weight: 350;
      line-height: 1.12;
      letter-spacing: -0.01em;
      max-width: 720px;
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .services-lead {
        font-size: 34px;
      }
    }
    .services-tags {
      margin-top: 16px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }
    @media (min-width: 641px) {
      .services-tags {
        gap: 16px;
      }
    }
    .services-tag {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
      border: 1px solid var(--color-rule);
      padding: 6px 12px;
    }
    .services-tag--draft {
      border: none;
      padding: 0;
      font-size: 9px;
      letter-spacing: 0.18em;
      color: var(--color-amber);
    }
    .services-cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-top: 22px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--color-paper);
      background: var(--color-brick);
      padding: 12px 20px;
      text-decoration: none;
    }
    .services-cta:hover {
      background: var(--color-accent-hover);
    }

  </style>
</BaseLayout>
