---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { URLS } from "../../lib/urls";

// §01 Services - two acrostics, side by side.
// Left column: AIDE = AI · ITSM · DevOps · EA (what I work in).
// Right column: WAIT = Workshops · Advisory · Implementation · Transformation (how I engage).
// First letter of each row is bricked at render time. Do not reorder
// or rename either column; breaks the acrostic.
// Gloss on the left column is the expansion of the abbreviation (artificial
// intelligence, IT service management…); on the right it's the engagement gloss.
const domains = [
  { t: "AI", g: "artificial intelligence" },
  { t: "ITSM", g: "IT service management" },
  { t: "DevOps", g: "development & operations" },
  { t: "EA", g: "enterprise architecture" },
];
const engage = [
  { t: "Workshops", g: "hackathons, code camps; tailored to the need" },
  { t: "Advisory", g: "direction, review, architecture" },
  { t: "Implementation", g: "hands on the build" },
  { t: "Transformation", g: "architecture-, project- and programme-level change" },
];

// §02 Founder - the timeline.
// Bookends (2004 TU München, 2026 KAI HACKS AI) are flagged ai: true and
// render with a brick dot. Order is canonical and asserted by tests.
// Year ranges use the spaced-hyphen form per the CVI Writing rules
// (no en-dashes anywhere, including numeric ranges).
const arc = [
  { y: "2004", co: "TU München", role: "AI research", ai: true },
  { y: "2006 - ’12", co: "Telefónica", role: "SA · ITSM · EA", ai: false },
  { y: "2012 - ’20", co: "Danfoss", role: "EA · IT Innovation", ai: false },
  { y: "2021", co: "q.beyond", role: "Chief EA", ai: false },
  { y: "2023", co: "FLS", role: "IT Operations", ai: false },
  { y: "2026", co: "KAI HACKS AI", role: "AI enablement", ai: true },
];

// §03 Method - the name reads itself, now framed as a Who/What/How triptych.
// The acronym expansion moves down into the architecture-card note line
// where it does its real work; here the meta becomes a single noun
// (Who/What/How) and the gloss becomes a single noun phrase (The
// Instructions / The Collaboration / The Implementation). HACKS bricked.
const movements = [
  { t: "KAI", meta: "Who", gloss: "The Instructions", accent: false },
  { t: "HACKS", meta: "What", gloss: "The Collaboration", accent: true },
  { t: "AI", meta: "How", gloss: "The Implementation", accent: false },
];

// §04 Applications - what runs on the architecture.
const apps = [
  {
    hue: "tide",
    url: "cultures.kaihacks.ai",
    title: "Cultures",
    note: "an application for culture trainers, and the culture-curious",
    href: "#",
    state: "live",
    planned: false,
  },
  {
    hue: "rule",
    url: "-",
    title: "More applications",
    note: "the architecture is built to spawn them",
    href: "#",
    state: "in progress",
    planned: true,
  },
];
---

<BaseLayout
  title="kaihacks.ai · KAI HACKS AI"
  description="Driving outcomes, from architecture to delivery. AI, ITSM, DevOps and enterprise architecture engagements: workshops, advisory, implementation, transformation."
>
  <div class="arch-page main-home">
    <SiteHeader domain="kaihacks" tld=".ai" location="company" />

    <main class="snap-scroll">
      <section class="snap-panel masthead">
        <div class="overline">the company</div>
        <h1 class="masthead-title" aria-label="KAI HACKS AI">
          <span>KAI</span>
          <span class="masthead-title-accent">HACKS</span>
          <span>AI<em class="masthead-title-period">.</em></span>
        </h1>
        <p class="lede">Driving outcomes,<br />from Architecture to Delivery.</p>
      </section>

      <section id="services" class="snap-panel section section--services">
        <div class="section-heading">
          <div class="section-heading-lead">
            <span class="section-no">§01</span>
            <span class="section-title">Services</span>
          </div>
          <div class="section-note">have outcomes delivered for you</div>
        </div>

        <div class="services-card">
          <p class="services-lead">I work with you on</p>

          <div class="services-grid">
            <div class="services-col">
              <div class="services-col-head">What I work in</div>
              {
                domains.map((d) => (
                  <div class="services-domain">
                    {/* prettier-ignore */}
                    <div class="services-domain-name"><span class="services-domain-initial">{d.t.charAt(0)}</span>{d.t.slice(1)}</div>
                    <div class="services-domain-gloss">{d.g}</div>
                  </div>
                ))
              }
              <div class="services-domain services-domain--coda">…you name it</div>
            </div>

            <div class="services-col">
              <div class="services-col-head">How I engage</div>
              {
                engage.map((e) => (
                  <div class="services-engage">
                    {/* prettier-ignore */}
                    <div class="services-engage-name"><span class="services-engage-initial">{e.t.charAt(0)}</span>{e.t.slice(1)}</div>
                    <div class="services-engage-gloss">{e.g}</div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="services-caption" aria-hidden="true">
            driving <span class="services-caption-aide">AIDE</span> | <span
              class="services-caption-wait">WAIT</span
            > delivery
          </div>

          <div class="services-cta-row">
            <a href={URLS.contact} class="services-cta">Start a conversation →</a>
          </div>
        </div>
      </section>

      <section id="founder" class="snap-panel section section--founder">
        <div class="section-heading">
          <div class="section-heading-lead">
            <span class="section-no">§02</span>
            <span class="section-title">The Founder</span>
          </div>
          <div class="section-note">have the founder work with you</div>
        </div>

        <p class="author-lede">
          AI in 2004, AI in 2026 and more than twenty years of enterprise IT in between.<br />
          The method carries what was learned in architecture, ITSM, DevOps, infrastructure and operations.
        </p>

        <ol class="arc">
          {
            arc.map((a) => (
              <li class={`arc-step ${a.ai ? "arc-step--ai" : ""}`}>
                <span class="arc-dot" aria-hidden="true" />
                <span class="arc-year">{a.y}</span>
                <span class="arc-co">{a.co}</span>
                <span class="arc-role">{a.role}</span>
              </li>
            ))
          }
        </ol>
      </section>

      <section id="method" class="snap-panel section section--method">
        <div class="section-heading">
          <div class="section-heading-lead">
            <span class="section-no">§03</span>
            <span class="section-title">Method &amp; Architecture</span>
          </div>
          <div class="section-note">have the method built for you</div>
        </div>

        <div class="movements">
          {
            movements.map((m, i) => (
              <div class="movement">
                <div class="movement-meta">
                  {String(i + 1).padStart(2, "0")} · {m.meta}
                </div>
                <div class={`movement-token ${m.accent ? "movement-token--accent" : ""}`}>
                  {m.t}
                </div>
                <div class="movement-gloss">{m.gloss}</div>
              </div>
            ))
          }
        </div>

        <div class="architecture-sub">
          <span class="architecture-sub-label">Architecture · what the method is</span>
          <span class="architecture-sub-rule" aria-hidden="true"></span>
        </div>

        <a href={URLS.architecture} class="architecture-card">
          <div class="architecture-card-hue" aria-hidden="true"></div>
          <div class="architecture-card-body">
            <div class="architecture-card-row">
              <span class="architecture-card-url">architecture.kaihacks.ai</span>
              <span class="architecture-card-state">live · the foundation</span>
            </div>
            <div class="architecture-card-title">KAI HACKS AI Architecture</div>
            <p class="architecture-card-note">
              Kais Architecture Instructions · Human Agent Collaboration Knowledge System · Agent
              Implemented
            </p>
            <span class="architecture-card-cta">Read the full specification →</span>
          </div>
        </a>
      </section>

      <section id="apps" class="snap-panel section section--applications">
        <div class="section-heading">
          <div class="section-heading-lead">
            <span class="section-no">§04</span>
            <span class="section-title">Applications</span>
          </div>
          <div class="section-note">what runs on the architecture</div>
        </div>

        <div class="apps">
          {
            apps.map((a) => (
              <a class={`app app--${a.hue} ${a.planned ? "app--planned" : ""}`} href={a.href}>
                {!a.planned && <div class={`app-hue app-hue--${a.hue}`} aria-hidden="true" />}
                <div class="app-body">
                  <div class="app-row">
                    <span class="app-url">{a.url}</span>
                    <span class={`app-state ${a.state === "live" ? "app-state--live" : ""}`}>
                      {a.state}
                    </span>
                  </div>
                  <div class="app-title">{a.title}</div>
                  <div class="app-note">{a.note}</div>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>

  <style is:global>
    /* Chapter snap on the document, only when this page is rendered.
     * Mirrors src/pages/main/cvi/index.astro. The viewport (html) is the
     * scroll container; putting scroll-snap-type on any nested in-flow
     * element is a no-op. `:has(.main-home)` scopes the rule to this
     * page so other surfaces (privacy, architecture) keep free scrolling.
     * scroll-padding-top/bottom match the sticky SiteHeader + SiteFooter
     * heights so snapped chapters land below the topbar rather than
     * under it. Disabled on narrow viewports; snap is friction on
     * phones, and a pitch page reads better as one long scroll there. */
    html:has(.main-home) {
      scroll-snap-type: y mandatory;
      scroll-padding-top: 4rem;
      scroll-padding-bottom: 4rem;
      scroll-behavior: smooth;
    }
    @media (max-width: 640px) {
      html:has(.main-home) {
        scroll-snap-type: none;
      }
    }
  </style>

  <style>
    /* topbar + footer styles live in SiteHeader.astro + SiteFooter.astro */

    /* ── snap chassis (CVI parity) ──────────────────────────────────────────
     * snap-type lives on `html:has(.main-home)` in the is:global block
     * above; here we set the per-panel snap-align and the viewport-height
     * sizing that makes each chapter stand on its own. SiteFooter sits
     * outside main.snap-scroll so it scrolls past the last snap point. */
    .snap-panel {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    @media (min-width: 641px) {
      .snap-panel {
        min-height: calc(100vh - 8rem);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-top: 2.25rem;
        padding-bottom: 2.25rem;
      }
    }
    @media (max-width: 640px) {
      .snap-panel {
        scroll-snap-align: none;
        scroll-snap-stop: normal;
      }
    }

    /* ── masthead ───────────────────────────────────────────────────────── */
    .masthead {
      padding: 1.875rem 0 1.75rem;
    }
    @media (min-width: 641px) {
      .masthead {
        /* snap-panel handles vertical centring; reset the legacy top/bottom */
        padding: 4.375rem 0 2.75rem;
      }
    }
    .overline {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.26em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    @media (min-width: 641px) {
      .overline {
        font-size: 11px;
      }
    }
    .masthead-title {
      margin: 18px 0 0;
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 52px;
      line-height: 0.94;
      letter-spacing: -0.03em;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      column-gap: 0.26em;
    }
    @media (min-width: 641px) {
      .masthead-title {
        font-size: 128px;
      }
    }
    .masthead-title-accent {
      color: var(--color-brick);
    }
    /* The closing period on the masthead title — same brand grammar as the
     * Cultures., Playbook., Contact. wordmarks across the rest of the site.
     * Brick, upright (em is plain), kerned tight against AI. */
    .masthead-title-period {
      color: var(--color-brick);
      font-style: normal;
    }
    .lede {
      margin: 22px 0 0;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 18px;
      line-height: 1.4;
      color: var(--color-ink-soft);
      text-wrap: pretty;
      text-align: center;
    }
    @media (min-width: 641px) {
      .lede {
        margin-top: 28px;
        font-size: 25px;
      }
    }
    .draft-marker {
      margin-top: 14px;
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.2em;
      color: var(--color-amber);
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .draft-dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      background: var(--color-amber);
    }

    /* ── sections shared ────────────────────────────────────────────────── */
    .section {
      padding: 8px 0 12px;
    }
    .section-heading {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
      border-bottom: 1px solid var(--color-rule);
      padding-bottom: 10px;
    }
    @media (min-width: 641px) {
      .section-heading {
        flex-direction: row;
        align-items: baseline;
        gap: 0;
      }
    }
    .section-heading-lead {
      display: flex;
      align-items: baseline;
      gap: 14px;
    }
    .section-no {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-brick);
      text-transform: uppercase;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .section-title {
        font-size: 26px;
      }
    }
    .section-note {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }

    /* ── §01 services: two acrostics × the one brick CTA ─────────────────
     * Left column = AIDE (what I work in). Right column = WAIT (how I
     * engage). Each row carries a .services-(domain|engage)-name with
     * the first letter wrapped in .services-(domain|engage)-initial
     * (brick), and a sibling .services-(domain|engage)-gloss line with
     * the expansion in mono uppercase ink-mute.
     *
     * The card has a centered lede, a centered editorial caption sitting
     * between the grid and the CTA ("driving AIDE | WAIT delivery"), and
     * a centered brick CTA pointing at URLS.contact. */
    .services-card {
      margin-top: 24px;
      border: 1px solid var(--color-rule);
      border-top: 4px solid var(--color-brick);
      background: var(--color-paper-warm);
      padding: 26px 22px;
    }
    @media (min-width: 641px) {
      .services-card {
        padding: 38px 40px;
      }
    }
    .services-lead {
      margin: 0;
      font-family: var(--font-display);
      font-size: 26px;
      font-weight: 350;
      line-height: 1.12;
      letter-spacing: -0.01em;
      text-wrap: pretty;
      text-align: center;
    }
    @media (min-width: 641px) {
      .services-lead {
        font-size: 36px;
      }
    }
    .services-grid {
      margin-top: 26px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 26px;
    }
    @media (min-width: 641px) {
      .services-grid {
        grid-template-columns: 1.15fr 1fr;
        gap: 44px;
        margin-top: 30px;
      }
    }
    .services-col-head {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--color-rule);
    }
    .services-domain {
      padding: 11px 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .services-domain-name {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .services-domain-name {
        font-size: 26px;
      }
    }
    .services-domain-initial,
    .services-engage-initial {
      color: var(--color-brick);
    }
    .services-domain-gloss,
    .services-engage-gloss {
      margin-top: 2px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }
    .services-domain--coda {
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 15px;
      color: var(--color-ink-mute);
      border-bottom: none;
      padding: 9px 0;
    }
    .services-engage {
      padding: 11px 0;
      border-bottom: 1px solid var(--color-rule-soft);
    }
    .services-engage-name {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      color: var(--color-ink);
      letter-spacing: -0.01em;
    }
    @media (min-width: 641px) {
      .services-engage-name {
        font-size: 26px;
      }
    }
    /* §01 caption: the editorial bridge between the 2×4 grid and the CTA.
     * Centered. Mono uppercase ink-mute. The pipe sits exactly between the
     * two acrostics (7·4|4·8 letter balance) so the eye reads them as
     * equal weights.
     *
     * Hover/punch hook (scaffold only; Kai tunes):
     * Hovering the card lights AIDE then WAIT in turn via a chained
     * brick pulse. `prefers-reduced-motion: reduce` skips the animation. */
    .services-caption {
      margin: 24px 0 0;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      color: var(--color-ink-mute);
      text-transform: uppercase;
    }
    .services-caption-aide,
    .services-caption-wait {
      color: var(--color-ink);
      transition: color 0.24s ease-out;
    }
    @media (prefers-reduced-motion: no-preference) {
      .services-card:hover .services-caption-aide,
      .services-card:hover .services-caption-wait {
        color: var(--color-brick);
      }
      .services-card:hover .services-caption-wait {
        transition-delay: 0.16s;
      }
    }
    .services-cta-row {
      display: flex;
      justify-content: center;
      margin-top: 18px;
    }
    .services-cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--color-paper);
      background: var(--color-brick);
      padding: 15px 26px;
      text-decoration: none;
    }
    .services-cta:hover {
      background: var(--color-accent-hover);
    }
    @media (min-width: 641px) {
      .services-cta-row {
        margin-top: 22px;
      }
    }

    /* ── §02 author: the timeline ───────────────────────────────────────── */
    .author-lede {
      margin: 18px auto 0;
      max-width: 760px;
      font-family: var(--font-prose);
      font-size: 16px;
      line-height: 1.55;
      color: var(--color-ink);
      text-wrap: pretty;
      text-align: center;
    }
    .brick {
      color: var(--color-brick);
    }
    .arc {
      list-style: none;
      margin: 26px 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      position: relative;
    }
    @media (min-width: 641px) {
      .arc {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 6px;
      }
      .arc::before {
        content: "";
        position: absolute;
        left: 6px;
        right: 6px;
        top: 6px;
        height: 1px;
        background: var(--color-ink);
      }
    }
    .arc-step {
      position: relative;
      padding: 12px 0 12px 20px;
      border-left: 1px solid var(--color-rule);
      margin-left: 5px;
      display: grid;
      grid-template-columns: auto auto 1fr;
      column-gap: 12px;
      align-items: baseline;
    }
    @media (min-width: 641px) {
      .arc-step {
        padding: 0;
        border-left: none;
        margin-left: 0;
        display: block;
      }
    }
    .arc-dot {
      position: absolute;
      left: -6px;
      top: 15px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--color-paper);
      border: 1.5px solid var(--color-ink);
    }
    @media (min-width: 641px) {
      .arc-dot {
        position: static;
        display: block;
        margin-bottom: 8px;
      }
    }
    .arc-step--ai .arc-dot {
      width: 13px;
      height: 13px;
      background: var(--color-brick);
      border: none;
    }
    @media (min-width: 641px) {
      .arc-step--ai .arc-dot {
        margin-bottom: 5px;
      }
    }
    .arc-year {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      color: var(--color-ink-soft);
    }
    @media (min-width: 641px) {
      .arc-year {
        display: block;
        margin-top: 8px;
      }
    }
    .arc-step--ai .arc-year {
      color: var(--color-brick);
      font-weight: 600;
    }
    .arc-co {
      font-family: var(--font-display);
      font-size: 18px;
      line-height: 1.1;
      color: var(--color-ink);
      font-weight: 500;
    }
    @media (min-width: 641px) {
      .arc-co {
        display: block;
        font-size: 17px;
        margin-top: 4px;
      }
    }
    .arc-role {
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 12.5px;
      color: var(--color-ink-soft);
      line-height: 1.35;
    }
    @media (min-width: 641px) {
      .arc-role {
        display: block;
        margin-top: 3px;
      }
    }

    /* ── §03 method & architecture ──────────────────────────────────────── */
    .movements {
      margin-top: 22px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
    }
    @media (min-width: 641px) {
      .movements {
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }
    }
    .movement {
