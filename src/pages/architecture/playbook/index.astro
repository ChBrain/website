---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import JumpDiagram from "../../../components/JumpDiagram.astro";
---

<BaseLayout
  title="Playbook · architecture · kaihacks"
  description="The KAI HACKS AI playbook – the bound specification. Plot, the five elements that Plot casts, and the two substrate files everything rests on."
>
  <div class="playbook">
    <SiteHeader domain="architecture" tld=".kaihacks.ai" basePath="../" version="v0.0.2" />

    <header class="playbook-mast">
      <div class="section-label">§0 · the playbook</div>
      <h1 class="playbook-title">
        Playbook<em>.</em>
      </h1>
      <p class="playbook-subline">The elements of how a world is moved – one file at a time.</p>
    </header>

    <JumpDiagram />

    <SiteFooter />
  </div>

  <style is:global>
    /* The playbook borrows the architecture-home's full-bleed override
     * and snap chassis. JumpDiagram (the diagram component) was built
     * to live on the architecture home; here it sits at /playbook/ as
     * the focused field manual. Future PRs will replace JumpDiagram
     * with the bound 8-spread book (cover + 5 casts + 2 substrate)
     * driven by a rail-overlay + collapsed-strip indicator. */
    body:has(.playbook) {
      padding: 0;
    }
    body:has(.playbook) main {
      max-width: none;
      margin: 0;
    }
    html:has(.playbook) {
      scroll-snap-type: y mandatory;
      scroll-padding-top: 4rem;
      scroll-padding-bottom: 4rem;
      scroll-behavior: smooth;
    }
    @media (max-width: 640px) {
      html:has(.playbook) {
        scroll-snap-type: none;
      }
    }
  </style>

  <style>
    .playbook {
      max-width: var(--width-page);
      margin: 0 auto;
      padding: 0 1.25rem;
      background: var(--color-paper);
      color: var(--color-ink);
      font-family: var(--font-prose);
    }
    @media (min-width: 641px) {
      .playbook {
        padding: 0 3.5rem;
      }
    }

    .playbook-mast {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      padding: 1.875rem 0 1.5rem;
    }
    @media (min-width: 641px) {
      .playbook-mast {
        min-height: calc(100vh - 8rem);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem 0 2.5rem;
      }
    }
    @media (max-width: 640px) {
      .playbook-mast {
        scroll-snap-align: none;
        scroll-snap-stop: normal;
      }
    }

    .section-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.26em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    .playbook-title {
      margin: 1.125rem 0 0;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 64px;
      line-height: 0.94;
      letter-spacing: -0.03em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .playbook-title {
        font-size: 132px;
      }
    }
    .playbook-title em {
      color: var(--color-brick);
      font-style: normal;
    }
    .playbook-subline {
      margin: 1.375rem 0 0;
      max-width: 680px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 17px;
      line-height: 1.4;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .playbook-subline {
        margin-top: 1.75rem;
        font-size: 23px;
      }
    }
  </style>
</BaseLayout>
