---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Book from "../../../components/Book.astro";
import type { BookSpread, BookTocGroup } from "../../../lib/book";
import { loadAllSpecs } from "../../../lib/load-specs";
import { parseSpec, type ParsedSpec } from "../../../lib/parse-spec";
import { playbook } from "@chbrain/khai-arch";
import pkg from "@chbrain/khai-arch/package.json";
import { loadEngines } from "../../../lib/load-engines";

// The canon edition, derived from the installed canon -- one source, no drift.
const edition = `v${pkg.version}`;

const allSpecs = loadAllSpecs();
const bySlug = new Map<string, ParsedSpec | null>();
for (const raw of allSpecs) {
  try {
    bySlug.set(raw.id, parseSpec(raw.text));
  } catch {
    bySlug.set(raw.id, null);
  }
}

// The playbook spine is owned by the canon (@chbrain/khai-arch): each group
// declares its label and its ordered members. We render that and never
// re-declare the order or grouping here -- add a spec to the canon's model and
// it appears, with no edit to this file.
//
// Phase 3: installed engines append to the "enriched by" group as WIRES cards.
// Engines are extensions, not canon, so the canon never names them; we discover
// them from node_modules (alphabetical) and render one card each, after the
// engines type spread.
const engines = loadEngines();
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

// Build the spreads grouped by the canon spine, then flatten. Each group
// becomes a labelled run in the Book's contents overlay.
let idx = 0;
const tocGroups: BookTocGroup[] = [];
const spreads: BookSpread[] = [];

for (const group of playbook) {
  const items: BookTocGroup["items"] = [];

  for (const slug of group.members) {
    const parsed = bySlug.get(slug) ?? null;
    const fm = parsed?.frontmatter;
    const n = idx++;
    const nStr = String(n).padStart(2, "0");
    const name = fm?.id ? cap(fm.id) : slug;
    const written = !!parsed;
    spreads.push({
      slug,
      n: nStr,
      groupLabel: group.label,
      status: fm?.status ?? "draft",
      title: name,
      subtitle: fm?.subtitle ?? null,
      facets: (parsed?.chapters ?? []).map((c) => ({
        letter: c.letter,
        name: c.name,
        body: c.body,
      })),
      coda: parsed?.coda ?? null,
      written,
      // The engines type spread reads the spec; from here you can go take the
      // engines themselves -- the download shelf (../engines/ from the playbook).
      // The express lane out of the book: "Download" the verb, not "Open".
      deepLink:
        slug === "engines"
          ? { href: "../engines/", label: "Download the engines", verb: "Download" }
          : undefined,
    });
    items.push({ slug, idx: n, n: nStr, name, written });
  }

  if (group.id === "enriched-by") {
    for (const card of engines) {
      const n = idx++;
      const nStr = String(n).padStart(2, "0");
      const name = cap(card.id);
      spreads.push({
        slug: card.id,
        n: nStr,
        groupLabel: group.label,
        status: "engine",
        title: name,
        subtitle: null,
        facets: card.chapters.map((cn) => ({
          letter: cn.charAt(0),
          name: cn,
          body: card.sections[cn],
        })),
        coda: null,
        written: true,
        engine: true,
        // The WIRES card is the teaser; click through to the full Enginebook
        // (../enginebooks/<id>/ from /architecture/playbook/).
        deepLink: { href: `../enginebooks/${card.id}/`, label: `Open the ${name} enginebook →` },
      });
      items.push({ slug: card.id, idx: n, n: nStr, name, written: true });
    }
  }

  tocGroups.push({ key: group.id, label: group.label, items });
}
---

<BaseLayout
  title="Playbook · architecture · kaihacks"
  description="The KAI HACKS AI playbook: Plot, the five elements that Plot casts, and the substrate that holds and enriches it."
>
  <Book
    header={{
      domain: "architecture",
      tld: ".kaihacks.ai",
      basePath: "../",
      location: "playbook",
    }}
    cover={{
      overline: "the specification · a field manual",
      title: "Playbook",
      subtitle: "The elements of how a world is moved, <br />one file at a time.",
      edition: `khai · ${edition}`,
      ctaHref: "#plot",
      ctaLabel: "Open the playbook →",
      hint: "or press →",
    }}
    spreads={spreads}
    tocGroups={tocGroups}
    tocEyebrow="The Specification"
  />
</BaseLayout>
