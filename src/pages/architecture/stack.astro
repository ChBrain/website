---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadStack } from "../../lib/load-specs";
import MarkdownIt from "markdown-it";

const stack = loadStack();
const md = new MarkdownIt({ html: false });
const html = stack ? md.render(stack.text) : "<p>No stack defined.</p>";
---

<BaseLayout
  title="Stack - kaihacks architecture"
  description="The kaihacks stack: dependencies and runtime targets."
>
  <article class="stack" set:html={html} />

  <style>
    .stack :global(h1) {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      margin: 0 0 var(--space-6);
    }
    .stack :global(h2) {
      font-size: var(--font-size-xl);
      margin: var(--space-6) 0 var(--space-3);
      padding-bottom: var(--space-2);
      border-bottom: var(--border-thin);
    }
    .stack :global(p) {
      font-size: var(--font-size-base);
      line-height: var(--line-height-loose);
      margin: 0 0 var(--space-4);
    }
  </style>
</BaseLayout>
