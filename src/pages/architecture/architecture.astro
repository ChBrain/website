---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import { loadArchitecture } from "../../lib/load-specs";
import MarkdownIt from "markdown-it";

const architecture = loadArchitecture();
const md = new MarkdownIt({ html: false });
const html = architecture ? md.render(architecture.text) : "<p>No architecture document.</p>";
---

<BaseLayout
  title="Architecture - kaihacks"
  description="The kaihacks architecture: KAI HACKS AI canon, model, type definitions."
>
  <Topbar basePath="../" />

  <article class="doc" set:html={html} />

  <style>
    .doc :global(h1) {
      font-size: var(--font-size-3xl);
      line-height: var(--line-height-tight);
      margin: 0 0 var(--space-6);
    }
    .doc :global(h2) {
      font-size: var(--font-size-xl);
      margin: var(--space-6) 0 var(--space-3);
      padding-bottom: var(--space-2);
      border-bottom: var(--border-thin);
    }
    .doc :global(p) {
      font-size: var(--font-size-base);
      line-height: var(--line-height-loose);
      margin: 0 0 var(--space-4);
    }
    .doc :global(table) {
      border-collapse: collapse;
      margin: 0 0 var(--space-5);
      width: 100%;
    }
    .doc :global(th),
    .doc :global(td) {
      padding: var(--space-2) var(--space-3);
      border-bottom: var(--border-thin);
      text-align: left;
      vertical-align: top;
    }
    .doc :global(pre) {
      font-family: var(--font-mono);
      font-size: var(--font-size-sm);
      line-height: var(--line-height-base);
      background: var(--color-bg-subtle);
      padding: var(--space-4);
      border: var(--border-thin);
      border-radius: var(--radius-md);
      overflow-x: auto;
    }
    .doc :global(ul) {
      padding-left: var(--space-5);
      margin: 0 0 var(--space-4);
    }
    .doc :global(li) {
      margin-bottom: var(--space-2);
      line-height: var(--line-height-loose);
    }
  </style>
</BaseLayout>
