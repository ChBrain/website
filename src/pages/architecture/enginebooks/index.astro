---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Shelf, { type ShelfCard } from "../../../components/Shelf.astro";
import pkg from "@chbrain/khai-arch/package.json";
import { loadEngines } from "../../../lib/load-engines";
import { loadEngineBook } from "../../../lib/load-engine-content";

// The canon edition, derived from the installed canon -- one source, no drift.
const edition = `v${pkg.version}`;
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

// The shelf. loadEngines() discovers every installed @chbrain/khai-engine-*
// (alphabetical, deterministic); loadEngineBook() adds the canon tagline. The
// canon never names engines, so this list is whatever is installed.
const shelf = loadEngines().map((card) => ({ card, book: loadEngineBook(card.id) }));
const cards: ShelfCard[] = shelf.map(({ card, book }) => ({
  href: `./${card.id}/`,
  eyebrow: `architecture.kaihacks.ai/enginebooks/${card.id}`,
  state: `engine · wires at ${card.type ?? "?"}`,
  title: cap(card.id),
  note: book.tagline ?? card.sections[card.chapters[0]],
  cta: "Open the enginebook →",
}));
---

<BaseLayout
  title="Enginebooks · architecture · kaihacks"
  description="The installed khai engines, each as an Enginebook: the extension wired through the canon's seam."
>
  <Shelf
    domain="architecture"
    location="enginebooks"
    sectionLabel="§ · the extensions"
    title="Enginebooks"
    sectionNo="§1"
    sectionTitle="Installed engines"
    sectionNote={`canon ${edition} · enriched by`}
    cards={cards}
    empty="No engines installed."
  >
    <Fragment slot="subline">
      What comes through the canon's seam. Each engine binds at one root and offers its parts as one
      named whole; an Enginebook is that whole, rendered.
    </Fragment>
  </Shelf>
</BaseLayout>
