---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Book from "../../../../components/Book.astro";
import type { BookSpread, BookFacet } from "../../../../lib/book";
import { rewriteMemberLinks } from "../../../../lib/book";
import { loadEngines } from "../../../../lib/load-engines";
import { loadEngineBook, type EngineBook } from "../../../../lib/load-engine-content";
import { parseEngineSpec } from "../../../../lib/parse-engine-spec";
import MarkdownIt from "markdown-it";
import { readFileSync, existsSync } from "node:fs";
import { join } from "node:path";

// One static path per installed engine (today: just gender). The canon never
// names engines; loadEngines() discovers them from node_modules.
export async function getStaticPaths() {
  return loadEngines().map((card) => ({
    params: { engine: card.id },
    props: { book: loadEngineBook(card.id) },
  }));
}

const { book } = Astro.props as { book: EngineBook };
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const md = new MarkdownIt({ html: false, breaks: false, linkify: false });

// The reference warrant AND the facet cards link each source to the member
// FILE it constrains (e.g. [gender](position_gender.md)). Those files are not
// pages -- they are the content snaps further down this same book. Map each
// member file to its in-page anchor (anchor -> #anchor, each expression ->
// #<key>, matching the spread slugs below); rewriteMemberLinks (the shared
// book capability) does the rewrite so the build's internal-link check passes
// and the links actually work.
const fileAnchor = new Map<string, string>([
  [book.anchor.file, "anchor"],
  ...book.expressions.map((e) => [e.file, e.key] as [string, string]),
]);
// Block-level prose for the reference (LORE) snaps: rewrite links, then render.
const mdRef = (text: string) => md.render(rewriteMemberLinks(text, fileAnchor));
// Facet card body: same link rewrite, rendered INLINE (no wrapping <p>) so it
// nests cleanly in the card and so literal markdown (e.g. the "Has" card's
// [gender](position_gender.md)) becomes a working in-page link.
const facetLinks = (f: BookFacet): BookFacet => ({
  ...f,
  bodyHtml: md.renderInline(rewriteMemberLinks(f.body, fileAnchor)),
});
// The corner shows the spread's PARENT -- its `## Taxonomy`, the group it
// reports into -- linked where that parent has its own file. An expression's
// parent is the anchor ([Gender](position_gender.md) -> a link to #anchor); the
// anchor's parent is a concept with no file (Social structure). A bare
// markdown-link taxonomy renders as-is; a prose taxonomy is trimmed to its lead
// name (dropping a trailing "(... no file ...)" qualifier) for the small slot.
const parentHtml = (taxonomy: string | null): string | null => {
  if (!taxonomy) return null;
  const t = taxonomy.trim();
  const isLink = /^\[[^\]]+\]\([^)]+\)$/.test(t);
  const name = isLink ? t : t.replace(/\s*\([^)]*\)\s*\.?$/, "").trim();
  return md.renderInline(rewriteMemberLinks(name, fileAnchor));
};

// A reference snap's slug: lowercase, non-alphanumerics -> "-", collapsed and
// trimmed, prefixed "ref-" so it stays anchor-safe and unique across chapters
// and subchapters (e.g. "ref-origin", "ref-restrictions-intersectionality").
const refSlug = (s: string) =>
  "ref-" +
  s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");

// An Enginebook is the same book as the Playbook -- same chassis (Book.astro),
// only the spreads differ. The v2 sequence leads with the LORE reference
// warrant (cover -> reference -> anchor -> expressions), then closes with the
// wiring card: the canon binding sits LAST, after the content it warrants.
// Engine files parse with parseEngineSpec (position/instance format), NOT the
// canon parseSpec; their substantive H2 sections become the facet cards.
const spreads: BookSpread[] = [];
const n = () => String(spreads.length).padStart(2, "0");

// 1. Reference: the LORE warrant, one snap per chapter -- or per subchapter so
//    a heavy chapter (Restrictions) paginates. Skipped when the engine ships
//    no conforming REFERENCES.md.
if (book.references) {
  const refs = book.references;
  // The reference snaps lead the book, so we push straight into `spreads` and
  // each n() reads the correct, final ordinal at push time.
  const firstRefIdx = spreads.length;
  for (const chapter of refs.chapters) {
    const section = refs.sections[chapter];
    if (section.subchapters.length === 0) {
      // Body-only chapter: one snap carrying its prose (or table / list).
      spreads.push({
        slug: refSlug(chapter),
        n: n(),
        groupLabel: "reference",
        status: refs.mnemonic,
        title: chapter,
        facets: [],
        bodyHtml: mdRef(section.body),
        coda: null,
      });
    } else {
      // Subchaptered chapter: one snap per subchapter. The chapter intro
      // folds into the first subchapter's snap so no prose is dropped.
      section.subchapters.forEach((sub, i) => {
        const lead = i === 0 && section.body ? section.body + "\n\n" : "";
        spreads.push({
          slug: refSlug(chapter + "-" + sub.name),
          n: n(),
          groupLabel: "reference",
          status: chapter,
          title: sub.name,
          facets: [],
          bodyHtml: mdRef(lead + sub.body),
          coda: null,
        });
      });
    }
  }
  // The warrant's coda (e.g. "_Authored by ..._") tails the last reference
  // snap, appended to its prose body.
  if (refs.coda && spreads.length > firstRefIdx) {
    const last = spreads[spreads.length - 1];
    last.bodyHtml = (last.bodyHtml ?? "") + mdRef(refs.coda);
  }
}

// 2. Anchor: the root the engine wires at.
const anchor = parseEngineSpec(book.anchor.text);
spreads.push({
  slug: "anchor",
  n: n(),
  groupLabel: "anchor",
  status: `anchor · ${book.type ?? "?"}`,
  // Corner: the anchor's parent (Taxonomy). The left already says "anchor", so
  // the right carries the parent, not a repeat. Subtitle drops the "the anchor"
  // default -- the role marker already covers it.
  statusHtml: parentHtml(anchor.taxonomy),
  title: cap(book.id),
  subtitle: anchor.subtitle,
  facets: anchor.facets.map(facetLinks),
  coda: null,
});

// 3. Each expression hung beneath the anchor.
for (const expr of book.expressions) {
  const parsed = parseEngineSpec(expr.text);
  spreads.push({
    slug: expr.key,
    n: n(),
    groupLabel: "expression",
    status: "expression",
    // Corner: the expression's parent (Taxonomy) -- the anchor, linked. Kills
    // the "expression x3": left = "expression", right = the parent link, and
    // the subtitle drops its "expression" default.
    statusHtml: parentHtml(parsed.taxonomy),
    title: cap(expr.key),
    subtitle: parsed.subtitle,
    facets: parsed.facets.map(facetLinks),
    coda: null,
  });
}

// 4. Wiring: the WIRES card the canon projects from the manifest. Last in the
//    v2 sequence -- the binding closes the book, after the content.
spreads.push({
  slug: "wiring",
  n: n(),
  groupLabel: "wiring",
  status: book.card.mnemonic,
  title: "Wiring",
  subtitle: "how the engine binds to the canon",
  facets: book.card.chapters.map((name) => ({
    letter: name.charAt(0),
    name,
    body: book.card.sections[name],
  })),
  coda: null,
});

// 5. Download back-cover: the engine zip built at prebuild time by
//    scripts/build-downloads.mjs. Only added when the sidecar is present;
//    CI builds (no @chbrain registry) skip it cleanly.
const dlSidecar = join(process.cwd(), "public", "downloads", "engines", `${book.id}.json`);
if (existsSync(dlSidecar)) {
  const dl = JSON.parse(readFileSync(dlSidecar, "utf8"));
  spreads.push({
    slug: "download",
    n: n(),
    groupLabel: "download",
    status: "download",
    title: "Download",
    subtitle: "the engine, packaged for deployment",
    facets: [],
    download: {
      href: `/downloads/engines/${book.id}.zip`,
      filename: dl.filename,
      size: dl.size,
      sha256: dl.sha256,
      note: `${cap(book.id)} engine: all markdown files and the khai manifest, ready to install in any project.`,
    },
  });
}

const title = `${cap(book.id)} · Enginebook · kaihacks`;
---

<BaseLayout title={title} description={book.tagline ?? `The ${book.id} engine, rendered.`}>
  <Book
    header={{
      domain: "architecture",
      tld: ".kaihacks.ai",
      basePath: "../../",
      location: `enginebook · ${book.id}`,
    }}
    cover={{
      overline: "the extension · an enginebook",
      title: cap(book.id),
      subtitle: book.tagline,
      edition: `khai · ${book.id}`,
      ctaHref: `#${spreads[0].slug}`,
      ctaLabel: "Open the enginebook →",
      backHref: "../",
      backLabel: "← all enginebooks",
    }}
    spreads={spreads}
    tocEyebrow={`enginebook · ${book.id}`}
  />
</BaseLayout>
