---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Book from "../../../components/Book.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import type { BookSpread } from "../../../lib/book";
import { URLS } from "../../../lib/urls";
import { readFileSync, readdirSync, existsSync } from "node:fs";
import { join } from "node:path";

// Skill sidecars are generated at prebuild time by scripts/build-downloads.mjs.
// Each JSON carries: name, slug, title, bodyHtml, filename, size, sha256,
// problem, solution, outcome. When the sidecars are absent (CI build, no
// @chbrain registry) the catalogue renders an empty state; the build stays green.
const skillsDir = join(process.cwd(), "public", "downloads", "skills");
const skills = existsSync(skillsDir)
  ? readdirSync(skillsDir)
      .filter((f) => f.endsWith(".json"))
      .sort()
      .map((f) => JSON.parse(readFileSync(join(skillsDir, f), "utf8")))
  : [];

const spreads: BookSpread[] = skills.map((skill, i) => ({
  slug: skill.slug,
  n: String(i + 1).padStart(2, "0"),
  groupLabel: "skill",
  status: "skill",
  title: skill.title,
  subtitle: null,
  facets: [
    { letter: "P", name: "Problem", body: skill.problem ?? "" },
    { letter: "S", name: "Solution", body: skill.solution ?? "" },
    { letter: "O", name: "Outcome", body: skill.outcome ?? "" },
  ],
  download: {
    href: `${URLS.architecture}downloads/skills/${skill.slug}.zip`,
    filename: skill.filename,
    size: skill.size,
    sha256: skill.sha256,
    note: null,
  },
  coda: null,
}));
---

<BaseLayout
  title="Skillbook · architecture · kaihacks"
  description="khai skills: self-contained agent skill bundles built from the khai-arch canon, ready to drop into any project."
>
  {
    skills.length === 0 ? (
      <div class="arch-page skillbook-empty">
        <SiteHeader domain="architecture" tld=".kaihacks.ai" basePath="../" location="skillbook" />
        <p class="empty-msg">
          No skills loaded. Run <code>npm run prebuild</code> on a machine with the GitHub Packages
          token to generate skill artifacts.
        </p>
        <SiteFooter />
      </div>
    ) : (
      <Book
        header={{
          domain: "architecture",
          tld: ".kaihacks.ai",
          basePath: "../",
          location: "skillbook",
        }}
        cover={{
          overline: "the extension · a skillbook",
          title: "Skills",
          subtitle: "self-contained agent bundles built from the khai-arch canon",
          edition: `khai · skills · ${skills.length} skill${skills.length === 1 ? "" : "s"}`,
          ctaHref: `#${spreads[0].slug}`,
          ctaLabel: "Open the skillbook →",
          backHref: "../",
          backLabel: "← architecture",
        }}
        spreads={spreads}
        tocEyebrow="skillbook"
      />
    )
  }
</BaseLayout>

<style>
  .skillbook-empty {
    padding-bottom: var(--space-9);
  }

  .empty-msg {
    font-family: var(--font-prose);
    font-size: var(--font-size-base);
    color: var(--color-ink-soft);
    margin: var(--space-7) 0;
  }

  .empty-msg code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--color-ink);
  }
</style>
