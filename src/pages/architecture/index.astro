---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import pkg from "@chbrain/khai-arch/package.json";
import * as khaiArch from "@chbrain/khai-arch";
import methodsPkg from "@chbrain/khai-methods/package.json";
import skillsPkg from "@chbrain/khai-skills/package.json";

// The canon edition, derived from the installed canon -- one source, no drift.
const edition = `v${pkg.version}`;

// The three book cards print their owning package's own tagline verbatim. The
// frontend stays dumb on package content: it never composes or derives a
// description, it renders the one the canon hands over -- so the card can never
// drift from the spec. Playbook's tagline is the khai-arch `playbookTagline`
// export; methodbook's and skillbook's are the top-level `tagline` field of
// their package.json. Each falls back to empty (not to hand-written copy) until
// the tagline-bearing package version is installed via deps:sync.
const playbookNote = (khaiArch as { playbookTagline?: string }).playbookTagline ?? "";
const methodbookNote = (methodsPkg as { tagline?: string }).tagline ?? "";
const skillbookNote = (skillsPkg as { tagline?: string }).tagline ?? "";

const movements = [
  {
    n: "I",
    token: "KAI",
    accent: false,
    layer: "the noun",
    sense: "who + what",
    words: ["Kais", "Architecture", "Instructions"],
    livesAs: "authored · architecture.md · instructions.md",
  },
  {
    n: "II",
    token: "HACKS",
    accent: true,
    layer: "the verbs",
    sense: "how it operates",
    words: ["Human", "Agent", "Collaboration", "Knowledge", "System"],
    livesAs: "the five chapters · the method",
  },
  {
    n: "III",
    token: "AI",
    accent: false,
    layer: "the verb",
    sense: "how it is instantiated",
    words: ["Agent", "Implemented"],
    livesAs: "the runtime · cultures.kaihacks.ai",
  },
];
---

<BaseLayout
  title="Architecture · kaihacks"
  description="KAI HACKS AI. The kaihacks specification reads itself: who builds, how it operates, how it runs."
>
  <div class="arch-home">
    <SiteHeader domain="kaihacks" tld=".ai" location="architecture" />

    <section class="masthead">
      <div class="section-label">§0 · the specification</div>
      <h1 class="masthead-title" aria-label="KAI HACKS AI">
        <span>KAI</span>
        <span class="masthead-title-accent">HACKS</span>
        <span>AI</span>
      </h1>
      <p class="masthead-subline">
        One Architecture. Three books. Specified Worlds where AI acts in role.
      </p>
    </section>

    <section class="section reading">
      <h2 class="section-heading">
        <span class="section-no">§1</span>
        <span class="section-title">The reading</span>
        <span class="section-note">how the name decomposes</span>
      </h2>

      <div class="movements">
        {
          movements.map((m) => (
            <article class="movement">
              <div class="movement-meta">
                <div class="movement-label">
                  {m.n} · {m.layer}
                </div>
                <div class={`movement-token ${m.accent ? "movement-token--accent" : ""}`}>
                  {m.token}
                </div>
                <div class="movement-sense">{m.sense}</div>
              </div>
              <div class="movement-body">
                <div class="movement-words">
                  {m.words.map((w) => (
                    <div class="movement-word">{w}</div>
                  ))}
                </div>
                <div class="movement-lives">
                  <span class="movement-lives-rule" aria-hidden="true" />
                  lives as · {m.livesAs}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section playbook-cta">
      <h2 class="section-heading">
        <span class="section-no">§2</span>
        <span class="section-title">Open the playbook</span>
        <span class="section-note">the elements of how a world is moved</span>
      </h2>

      <a href="./playbook/" class="playbook-card">
        <div class="playbook-card-hue" aria-hidden="true"></div>
        <div class="playbook-card-body">
          <div class="playbook-card-row">
            <span class="playbook-card-url">architecture.kaihacks.ai/playbook</span>
            <span class="playbook-card-state">{edition} · live · the field manual</span>
          </div>
          <div class="playbook-card-title">Playbook</div>
          <p class="playbook-card-note">{playbookNote}</p>
          <span class="playbook-card-cta">Open the playbook →</span>
        </div>
      </a>
    </section>

    <section class="section methodbook-cta">
      <h2 class="section-heading">
        <span class="section-no">§3</span>
        <span class="section-title">Open the methodbook</span>
        <span class="section-note">structured process definitions with attribution</span>
      </h2>

      <a href="./methodbook/" class="playbook-card playbook-card--methodbook">
        <div class="playbook-card-hue" aria-hidden="true"></div>
        <div class="playbook-card-body">
          <div class="playbook-card-row">
            <span class="playbook-card-url">architecture.kaihacks.ai/methodbook</span>
            <span class="playbook-card-state">live · the practice</span>
          </div>
          <div class="playbook-card-title">Methodbook</div>
          <p class="playbook-card-note">{methodbookNote}</p>
          <span class="playbook-card-cta">Open the methodbook →</span>
        </div>
      </a>
    </section>

    <section class="section skillbook-cta">
      <h2 class="section-heading">
        <span class="section-no">§4</span>
        <span class="section-title">Open the skillbook</span>
        <span class="section-note">agent skill bundles ready to deploy</span>
      </h2>

      <a href="./skillbook/" class="playbook-card playbook-card--skillbook">
        <div class="playbook-card-hue" aria-hidden="true"></div>
        <div class="playbook-card-body">
          <div class="playbook-card-row">
            <span class="playbook-card-url">architecture.kaihacks.ai/skillbook</span>
            <span class="playbook-card-state">live · the practice</span>
          </div>
          <div class="playbook-card-title">Skillbook</div>
          <p class="playbook-card-note">{skillbookNote}</p>
          <span class="playbook-card-cta">Open the skillbook →</span>
        </div>
      </a>
    </section>

    <SiteFooter />
  </div>

  <style is:global>
    /* Full-bleed override of BaseLayout's prose-width main for this page only.
     * Uses :has() so we don't need to touch BaseLayout. */
    body:has(.arch-home) {
      padding: 0;
    }
    body:has(.arch-home) main {
      max-width: none;
      margin: 0;
    }
    /* Scroll-snap on the document, only when the home is rendered. Pages
     * without .arch-home don't get snap behavior. Scroll-padding leaves
     * room for the sticky topbar (top) and sticky footer (bottom) so
     * snap-aligned content doesn't end up underneath the chrome.
     *
     * §0 masthead, §1 reading, §2 playbook, §3 methodbook, §4 skillbook. */
    html:has(.arch-home) {
      scroll-snap-type: y mandatory;
      scroll-padding-top: 4rem;
      scroll-padding-bottom: 4rem;
      scroll-behavior: smooth;
    }
    @media (max-width: 640px) {
      html:has(.arch-home) {
        scroll-snap-type: none;
      }
    }
  </style>

  <style>
    .arch-home {
      max-width: var(--width-page);
      margin: 0 auto;
      padding: 0 1.25rem;
      background: var(--color-paper);
      color: var(--color-ink);
      font-family: var(--font-prose);
    }
    @media (min-width: 641px) {
      .arch-home {
        padding: 0 3.5rem;
      }
    }

    .arch-home > section {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    @media (min-width: 641px) {
      /* Every snapped section vertical-centers its content. Center-snap
       * is the site standard (matches main + CVI): content arrives at
       * eye-level rather than the viewer scanning downward for the
       * heading. */
      .arch-home > section {
        min-height: calc(100vh - 8rem);
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
    }
    @media (max-width: 640px) {
      .arch-home > section {
        scroll-snap-align: none;
        scroll-snap-stop: normal;
      }
    }

    /* topbar styles live in src/components/SiteHeader.astro */

    /* masthead */
    .masthead {
      padding: 1.875rem 0 1.5rem;
      /* Centered hero, matching the main site's grammar. The masthead's
       * children (label, title, subline, draft marker) stack and center;
       * the wrapped title centers its lines via justify-content below. */
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    @media (min-width: 641px) {
      .masthead {
        padding: 4rem 0 2.5rem;
      }
    }
    .section-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.26em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    .masthead-title {
      margin: 1.125rem 0 0;
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 54px;
      line-height: 0.94;
      letter-spacing: -0.03em;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: center;
      column-gap: 0.26em;
    }
    @media (min-width: 641px) {
      .masthead-title {
        font-size: 132px;
      }
    }
    .masthead-title-accent {
      color: var(--color-brick);
    }
    .masthead-subline {
      margin: 1.375rem 0 0;
      max-width: 680px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 17px;
      line-height: 1.4;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .masthead-subline {
        margin-top: 1.75rem;
        font-size: 23px;
      }
    }
    /* sections shared (used by §1 reading) */
    .section {
      padding: 0.5rem 0 0.75rem;
    }
    .section-heading {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
      border-bottom: 1px solid var(--color-rule);
      padding-bottom: 10px;
      margin: 0;
      font-weight: normal;
    }
    @media (min-width: 641px) {
      .section-heading {
        flex-direction: row;
        align-items: baseline;
        gap: 0;
      }
    }
    .section-no {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-brick);
      text-transform: uppercase;
      margin-right: 14px;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .section-title {
        font-size: 26px;
      }
    }
    .section-note {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
      margin-left: auto;
    }

    /* §1 movements */
    .movements {
      margin-top: 1.375rem;
    }
    .movement {
      display: grid;
      grid-template-columns: 1fr;
      column-gap: 40px;
      row-gap: 10px;
      padding: 1.25rem 0;
      border-top: 1px solid var(--color-rule);
      align-items: start;
    }
    @media (min-width: 641px) {
      .movement {
        grid-template-columns: 200px 1fr;
        row-gap: 0;
        padding: 1.625rem 0;
      }
    }
    .movement-meta {
      display: flex;
      align-items: baseline;
      gap: 14px;
      flex-wrap: wrap;
    }
    @media (min-width: 641px) {
      .movement-meta {
        display: block;
      }
    }
    .movement-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    @media (max-width: 640px) {
      .movement-label {
        width: 100%;
      }
    }
    .movement-token {
      font-family: var(--font-display);
      font-size: 38px;
      line-height: 1;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .movement-token {
        font-size: 46px;
        margin-top: 8px;
      }
    }
    .movement-token--accent {
      color: var(--color-brick);
    }
    .movement-sense {
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 14px;
      color: var(--color-ink-soft);
    }
    @media (min-width: 641px) {
      .movement-sense {
        margin-top: 6px;
      }
    }
    .movement-word {
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 24px;
      line-height: 1.18;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .movement-word {
        font-size: 30px;
      }
    }
    .movement-word::first-letter {
      color: var(--color-brick);
      font-weight: 500;
    }
    .movement-lives {
      margin-top: 14px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .movement-lives-rule {
      display: inline-block;
      width: 16px;
      height: 1px;
      background: var(--color-rule);
    }

    /* §2 playbook CTA card: mirrors the architecture-card on main:
     * sea hue stripe, paper-warm fill, mono URL + state pill, display
     * title, italic note, mono CTA. The card is the doorway into the
     * book; the architecture surface stops here and the reading
     * continues at /playbook/. */
    .playbook-cta {
      padding-top: 1.5rem;
    }
    .playbook-card {
      display: block;
      text-decoration: none;
      color: var(--color-ink);
      margin-top: 24px;
      border: 1px solid var(--color-ink);
      background: var(--color-paper-warm);
      overflow: hidden;
      transition:
        transform 0.16s,
        box-shadow 0.16s;
    }
    .playbook-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px -16px var(--color-ink);
    }
    .playbook-card-hue {
      height: 6px;
      background: var(--color-sea);
    }
    .playbook-card--methodbook .playbook-card-hue {
      background: var(--color-marsh);
    }
    .playbook-card--skillbook .playbook-card-hue {
      background: var(--color-amber);
    }
    .playbook-card-body {
      padding: 18px 20px 20px;
    }
    @media (min-width: 641px) {
      .playbook-card-body {
        padding: 26px 30px;
      }
    }
    .playbook-card-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 12px;
      flex-wrap: wrap;
    }
    .playbook-card-url {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    .playbook-card-state {
      font-family: var(--font-mono);
      font-size: 8.5px;
      letter-spacing: 0.18em;
      color: var(--color-brick);
      text-transform: uppercase;
    }
    .playbook-card-title {
      font-family: var(--font-display);
      font-size: 30px;
      line-height: 1.06;
      margin-top: 8px;
      font-weight: 400;
      letter-spacing: -0.01em;
    }
    @media (min-width: 641px) {
      .playbook-card-title {
        font-size: 38px;
      }
    }
    .playbook-card-note {
      margin: 8px 0 0;
      max-width: 640px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 15px;
      color: var(--color-ink-soft);
      line-height: 1.45;
    }
    @media (min-width: 641px) {
      .playbook-card-note {
        font-size: 16.5px;
      }
    }
    .playbook-card-cta {
      display: inline-block;
      margin-top: 14px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--color-ink);
      padding-bottom: 3px;
      border-bottom: 1px solid var(--color-rule);
    }

    /* footer styles live in src/components/SiteFooter.astro */
  </style>
</BaseLayout>
