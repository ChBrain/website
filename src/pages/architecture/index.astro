---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Topbar from "../../components/Topbar.astro";
import Footer from "../../components/Footer.astro";
import JumpDiagram from "../../components/JumpDiagram.astro";

const movements = [
  {
    n: "I",
    token: "KAI",
    accent: false,
    layer: "the noun",
    sense: "who + what",
    words: ["Kais", "Architecture", "Instructions"],
    livesAs: "authored · architecture.md · instructions.md",
  },
  {
    n: "II",
    token: "HACKS",
    accent: true,
    layer: "the verbs",
    sense: "how it operates",
    words: ["Human", "Agent", "Collaboration", "Knowledge", "System"],
    livesAs: "the five chapters · the method",
  },
  {
    n: "III",
    token: "AI",
    accent: false,
    layer: "the verb",
    sense: "how it is instantiated",
    words: ["Agent", "Implemented"],
    livesAs: "the runtime · cultures.kaihacks.ai",
  },
];
---

<BaseLayout
  title="Architecture · kaihacks"
  description="KAI HACKS AI. The kaihacks specification reads itself: who builds, how it operates, how it runs."
>
  <div class="arch-home">
    <Topbar basePath="./" />

    <section class="masthead">
      <div class="section-label">§0 · the specification</div>
      <h1 class="masthead-title" aria-label="KAI HACKS AI">
        <span>KAI</span>
        <span class="masthead-title-accent">HACKS</span>
        <span>AI</span>
      </h1>
      <p class="masthead-subline">
        Three tokens. One specification. The name is the architecture: it states who builds, how it
        operates, and how it runs, and it reads itself in both directions.
      </p>
      <div class="draft-marker">
        <span class="draft-dot" aria-hidden="true"></span>draft · authored by Kai · your voice
        replaces this line
      </div>
    </section>

    <section class="section reading">
      <h2 class="section-heading">
        <span class="section-no">§1</span>
        <span class="section-title">The reading</span>
        <span class="section-note">how the name decomposes</span>
      </h2>

      <div class="movements">
        {
          movements.map((m) => (
            <article class="movement">
              <div class="movement-meta">
                <div class="movement-label">
                  {m.n} · {m.layer}
                </div>
                <div class={`movement-token ${m.accent ? "movement-token--accent" : ""}`}>
                  {m.token}
                </div>
                <div class="movement-sense">{m.sense}</div>
              </div>
              <div class="movement-body">
                <div class="movement-words">
                  {m.words.map((w) => (
                    <div class="movement-word">{w}</div>
                  ))}
                </div>
                <div class="movement-lives">
                  <span class="movement-lives-rule" aria-hidden="true" />
                  lives as · {m.livesAs}
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="directions">
        <div class="direction">
          <div class="direction-arrow">KAI → HACKS → AI</div>
          <div class="direction-gloss">
            <span class="direction-label">read forward ·</span>
            <em>how you build one.</em>
          </div>
        </div>
        <div class="direction">
          <div class="direction-arrow">AI ← HACKS ← KAI</div>
          <div class="direction-gloss">
            <span class="direction-label">read backward ·</span>
            <em>how you explain one.</em>
          </div>
        </div>
      </div>
    </section>

    <JumpDiagram />

    <Footer />
  </div>

  <style is:global>
    /* Full-bleed override of BaseLayout's prose-width main for this page only.
     * Uses :has() so we don't need to touch BaseLayout. */
    body:has(.arch-home) {
      padding: 0;
    }
    body:has(.arch-home) main {
      max-width: none;
      margin: 0;
    }
    /* Scroll-snap on the document, only when the home is rendered. Pages
     * without .arch-home don't get snap behavior. Scroll-padding leaves
     * room for the sticky topbar (top) and sticky footer (bottom) so
     * snap-aligned content doesn't end up underneath the chrome.
     *
     * After the 3-jump migration the home has three top-level sections
     * (masthead, reading, jump3). The model + types blocks were absorbed
     * into the diagram. */
    html:has(.arch-home) {
      scroll-snap-type: y mandatory;
      scroll-padding-top: 4rem;
      scroll-padding-bottom: 4rem;
      scroll-behavior: smooth;
    }
    @media (max-width: 640px) {
      html:has(.arch-home) {
        scroll-snap-type: none;
      }
    }
  </style>

  <style>
    .arch-home {
      max-width: var(--width-page);
      margin: 0 auto;
      padding: 0 1.25rem;
      background: var(--color-paper);
      color: var(--color-ink);
      font-family: var(--font-prose);
    }
    @media (min-width: 641px) {
      .arch-home {
        padding: 0 3.5rem;
      }
    }

    .arch-home > section {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    @media (min-width: 641px) {
      .arch-home > section {
        min-height: calc(100vh - 8rem);
      }
      /* Only the masthead vertical-centers - it's the hero. The other
       * sections (reading, the 3-jump diagram) start at top, content
       * flows downward as a normal reading column. */
      .arch-home > .masthead {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
    }
    @media (max-width: 640px) {
      .arch-home > section {
        scroll-snap-align: none;
        scroll-snap-stop: normal;
      }
    }

    /* topbar styles live in src/components/Topbar.astro */

    /* masthead */
    .masthead {
      padding: 1.875rem 0 1.5rem;
    }
    @media (min-width: 641px) {
      .masthead {
        padding: 4rem 0 2.5rem;
      }
    }
    .section-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.26em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    .masthead-title {
      margin: 1.125rem 0 0;
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 54px;
      line-height: 0.94;
      letter-spacing: -0.03em;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      column-gap: 0.26em;
    }
    @media (min-width: 641px) {
      .masthead-title {
        font-size: 132px;
      }
    }
    .masthead-title-accent {
      color: var(--color-brick);
    }
    .masthead-subline {
      margin: 1.375rem 0 0;
      max-width: 680px;
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 17px;
      line-height: 1.4;
      color: var(--color-ink-soft);
      text-wrap: pretty;
    }
    @media (min-width: 641px) {
      .masthead-subline {
        margin-top: 1.75rem;
        font-size: 23px;
      }
    }
    .draft-marker {
      margin-top: 0.875rem;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .draft-dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      background: var(--color-amber);
    }

    /* sections shared (used by §1 reading) */
    .section {
      padding: 0.5rem 0 0.75rem;
    }
    .section-heading {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
      border-bottom: 1px solid var(--color-rule);
      padding-bottom: 10px;
      margin: 0;
      font-weight: normal;
    }
    @media (min-width: 641px) {
      .section-heading {
        flex-direction: row;
        align-items: baseline;
        gap: 0;
      }
    }
    .section-no {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-brick);
      text-transform: uppercase;
      margin-right: 14px;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .section-title {
        font-size: 26px;
      }
    }
    .section-note {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
      margin-left: auto;
    }

    /* §1 movements */
    .movements {
      margin-top: 1.375rem;
    }
    .movement {
      display: grid;
      grid-template-columns: 1fr;
      column-gap: 40px;
      row-gap: 10px;
      padding: 1.25rem 0;
      border-top: 1px solid var(--color-rule);
      align-items: start;
    }
    @media (min-width: 641px) {
      .movement {
        grid-template-columns: 200px 1fr;
        row-gap: 0;
        padding: 1.625rem 0;
      }
    }
    .movement-meta {
      display: flex;
      align-items: baseline;
      gap: 14px;
      flex-wrap: wrap;
    }
    @media (min-width: 641px) {
      .movement-meta {
        display: block;
      }
    }
    .movement-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
    }
    @media (max-width: 640px) {
      .movement-label {
        width: 100%;
      }
    }
    .movement-token {
      font-family: var(--font-display);
      font-size: 38px;
      line-height: 1;
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .movement-token {
        font-size: 46px;
        margin-top: 8px;
      }
    }
    .movement-token--accent {
      color: var(--color-brick);
    }
    .movement-sense {
      font-family: var(--font-prose);
      font-style: italic;
      font-size: 14px;
      color: var(--color-ink-soft);
    }
    @media (min-width: 641px) {
      .movement-sense {
        margin-top: 6px;
      }
    }
    .movement-word {
      font-family: var(--font-display);
      font-weight: 350;
      font-size: 24px;
      line-height: 1.18;
      letter-spacing: -0.01em;
      color: var(--color-ink);
    }
    @media (min-width: 641px) {
      .movement-word {
        font-size: 30px;
      }
    }
    .movement-word::first-letter {
      color: var(--color-brick);
      font-weight: 500;
    }
    .movement-lives {
      margin-top: 14px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .movement-lives-rule {
      display: inline-block;
      width: 16px;
      height: 1px;
      background: var(--color-rule);
    }

    /* directions */
    .directions {
      margin-top: 1.125rem;
      border-top: 1px solid var(--color-ink);
      padding-top: 1.125rem;
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }
    @media (min-width: 641px) {
      .directions {
        gap: 36px;
      }
    }
    .direction {
      flex: 1 1 100%;
    }
    @media (min-width: 641px) {
      .direction {
        flex: 1 1 320px;
      }
    }
    .direction-arrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--color-brick);
      text-transform: uppercase;
    }
    .direction-gloss {
      margin-top: 6px;
      font-family: var(--font-prose);
      font-size: 16px;
      color: var(--color-ink);
    }
    .direction-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      color: var(--color-ink-soft);
      text-transform: uppercase;
      margin-right: 8px;
    }

    /* footer styles live in src/components/Footer.astro */
  </style>
</BaseLayout>
