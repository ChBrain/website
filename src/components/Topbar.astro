---
// Shared topbar for every page on the architecture surface.
// - On the home (/architecture/) pass basePath="./".
// - On any subpage (/architecture/<slug>/) pass basePath="../".
// The domain text doubles as a "back to home" link.
//
// The version is display-only.

interface Props {
  basePath?: string;
}

const { basePath = "./" } = Astro.props;
const khaiVersion = "v0.0.2";
---

<header class="topbar">
  <a href={basePath} class="topbar-domain">
    architecture<span class="topbar-domain-tld">.kaihacks.ai</span>
  </a>
  <span class="topbar-version">khai · {khaiVersion}</span>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-paper);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0 0.75rem;
    border-bottom: 1px solid var(--color-ink);
  }
  @media (min-width: 641px) {
    .topbar {
      padding: 1.375rem 0 1rem;
    }
  }
  .topbar-domain {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    color: var(--color-ink-soft);
    text-transform: uppercase;
    text-decoration: none;
  }
  .topbar-domain:hover {
    color: var(--color-ink);
  }
  @media (min-width: 641px) {
    .topbar-domain {
      font-size: 11px;
    }
  }
  .topbar-domain-tld {
    color: var(--color-brick);
  }
  .topbar-version {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--color-ink-soft);
    text-transform: uppercase;
  }
  @media (min-width: 641px) {
    .topbar-version {
      font-size: 11px;
    }
  }
</style>
