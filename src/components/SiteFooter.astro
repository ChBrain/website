---
// SiteFooter — the one global colophon for every surface.
//
// Three-column rhythm (chrome restructure):
//
//   KAI HACKS AI · CVR 41768274        Contact        Privacy · CVI · © 2026
//
// - Left: identity (wordmark linking to URLS.main + CVR). The mailto
//   that used to sit here moves to the dedicated /contact/ surface, so
//   the footer doesn't duplicate it.
// - Center: a single Contact link → URLS.contact. Suppressed on the
//   /contact/ page itself via the hideContact prop (prevents the
//   self-reference).
// - Right: Privacy · CVI · © 2026 (reordered so the legal links lead
//   and the year sits at the closing position).
//
// Class names (.footfed, .footfed-row, .footfed-legal-link) are
// preserved so the design-contract tests (privacy, cvi, main) keep
// passing without modification. New class: .footfed-contact for the
// centered Contact slot.

import { URLS } from "../lib/urls";

interface Props {
  /** True on the /contact/ page itself — suppresses the center Contact link to avoid self-reference. */
  hideContact?: boolean;
}

const { hideContact = false } = Astro.props;
---

<footer class="footfed">
  <div class="footfed-row">
    <div class="footfed-identity">
      <a href={URLS.main}>KAI HACKS AI</a> · CVR 41768274
    </div>
    {
      !hideContact && (
        <div class="footfed-contact">
          <a class="footfed-contact-link" href={URLS.contact}>
            Contact
          </a>
        </div>
      )
    }
    <nav class="footfed-legal" aria-label="Site">
      <a class="footfed-legal-link" href={URLS.privacy}>Privacy</a> ·
      <a class="footfed-legal-link" href={URLS.cvi}>CVI</a> · © 2026
    </nav>
  </div>
</footer>

<style is:global>
  /* On snap-enabled pages the SiteFooter becomes the final snap stop —
   * sticky-bottom fights mandatory snap (the footer pinned to viewport
   * bottom appears to "snap back" out of view because mandatory snap
   * forces the resting scroll position to align with the last
   * section's snap-stop, so the colophon is unreachable as a resting
   * state). Switching to position: relative + scroll-snap-align: start
   * makes the footer the FINAL chapter — one wheel-tick past §N lands
   * the colophon as its own snap-stop, stable at rest. Scoped to the
   * three snap pages so non-snap pages keep their sticky-bottom
   * behaviour. */
  :where(html:has(.arch-home), html:has(.cvi), html:has(.main-home)) .footfed {
    position: relative;
    scroll-snap-align: start;
  }
</style>

<style>
  .footfed {
    position: sticky;
    bottom: 0;
    z-index: 10;
    background: var(--color-paper);
    padding: 1rem 0 1.25rem;
    border-top: 1px solid var(--color-ink);
  }
  /* Three-column rhythm: identity left, contact centered, legal right.
   * Grid (vs flex space-between) so the center column lands at the
   * visual midpoint independent of the left/right column widths. */
  .footfed-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--color-ink-mute);
    text-transform: uppercase;
  }
  @media (min-width: 641px) {
    .footfed-row {
      font-size: 11px;
    }
  }

  .footfed-identity {
    text-align: left;
  }
  .footfed-contact {
    text-align: center;
  }
  .footfed-legal {
    text-align: right;
  }

  .footfed-identity a,
  .footfed-contact-link,
  .footfed-legal-link {
    color: var(--color-ink-mute);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
  }
  .footfed-identity a:hover,
  .footfed-contact-link:hover,
  .footfed-legal-link:hover {
    color: var(--color-ink);
  }

  /* Mobile: collapse the three-column grid into a stack (identity,
   * contact, legal — top to bottom). The center column would otherwise
   * be too squeezed on narrow viewports. */
  @media (max-width: 640px) {
    .footfed {
      position: static;
      padding: 0.75rem 0 1rem;
    }
    .footfed-row {
      grid-template-columns: 1fr;
      row-gap: 8px;
      justify-items: center;
    }
    .footfed-identity,
    .footfed-contact,
    .footfed-legal {
      text-align: center;
    }
  }
</style>
