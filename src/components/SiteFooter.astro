---
// SiteFooter — the one global colophon for every surface.
//
// One editorial line, used identically on every page:
//
//   KAI HACKS AI · CVR 41768274 · info@kaihacks.ai      © 2026 · Privacy · CVI
//
// Identity + contact float left; year + legal links float right. Mono,
// ink-mute, uppercase, letter-spaced — same restraint as CVI's bottom
// block. No props: every page is the same brand entity, so the old
// per-page siteLabel / endLabel / tagline knobs are gone.
//
// Privacy + CVI hrefs go through URLS so a staging build keeps the
// links inside staging.kaihacks.ai rather than jumping out to prod.
// Class names (.footfed, .footfed-row, .footfed-legal-link) are
// preserved so the design-contract tests (privacy, cvi, main) keep
// passing without modification.

import { URLS } from "../lib/urls";
---

<footer class="footfed">
  <div class="footfed-row">
    <div class="footfed-identity">
      KAI HACKS AI · CVR 41768274 ·
      <a href="mailto:info@kaihacks.ai">info@kaihacks.ai</a>
    </div>
    <nav class="footfed-legal" aria-label="Site">
      © 2026 ·
      <a class="footfed-legal-link" href={URLS.privacy}>Privacy</a> ·
      <a class="footfed-legal-link" href={URLS.cvi}>CVI</a>
    </nav>
  </div>
</footer>

<style is:global>
  /* On snap-enabled pages the SiteFooter becomes the final snap stop —
   * sticky-bottom fights mandatory snap (the footer pinned to viewport
   * bottom appears to "snap back" out of view because mandatory snap
   * forces the resting scroll position to align with the last
   * section's snap-stop, so the colophon is unreachable as a resting
   * state). Switching to position: relative + scroll-snap-align: start
   * makes the footer the FINAL chapter — one wheel-tick past §N lands
   * the colophon as its own snap-stop, stable at rest. Scoped to the
   * three snap pages so non-snap pages keep their sticky-bottom
   * behaviour. */
  :where(html:has(.arch-home), html:has(.cvi), html:has(.main-home)) .footfed {
    position: relative;
    scroll-snap-align: start;
  }
</style>

<style>
  .footfed {
    position: sticky;
    bottom: 0;
    z-index: 10;
    background: var(--color-paper);
    padding: 1rem 0 1.25rem;
    border-top: 1px solid var(--color-ink);
  }
  .footfed-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    column-gap: 24px;
    row-gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--color-ink-mute);
    text-transform: uppercase;
  }
  @media (min-width: 641px) {
    .footfed-row {
      font-size: 11px;
    }
  }

  .footfed-identity,
  .footfed-legal {
    display: inline;
  }

  .footfed-identity a,
  .footfed-legal-link {
    color: var(--color-ink-mute);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
  }
  .footfed-identity a:hover,
  .footfed-legal-link:hover {
    color: var(--color-ink);
  }

  /* Mobile: drop sticky behaviour. Sticky chrome on small viewports
   * eats too much of the reading area; on mobile the footer lives
   * inline at the end of the page. The topbar stays sticky as the
   * always-on "where am I" anchor. */
  @media (max-width: 640px) {
    .footfed {
      position: static;
      padding: 0.75rem 0 1rem;
    }
  }
</style>
