---
// Book.astro -- the shared book chassis.
//
// The canon Playbook and every Enginebook are ONE book: same cover, same
// per-spread header, the same brick-dot title, the 2x2 facet grid, the coda,
// the snap-scroll, and the left-edge contents strip + overlay. They differ
// only in WHICH spreads they carry. This component owns the entire chassis;
// callers feed it a cover and an ordered list of spreads.
//
// The CSS below is lifted verbatim from the original playbook page so the
// Playbook renders pixel-identical. Do not "improve" it.
import SiteHeader from "./SiteHeader.astro";
import SiteFooter from "./SiteFooter.astro";
import Mark from "./Mark.astro";
import type { BookCover, BookHeader, BookSpread, BookTocGroup } from "../lib/book";

interface Props {
  /** SiteHeader chrome. */
  header: BookHeader;
  /** Front cover (first snap-stop). */
  cover: BookCover;
  /** Ordered spreads, one snap-stop each. */
  spreads: BookSpread[];
  /**
   * Optional grouped table of contents for the overlay. When omitted, the
   * overlay falls back to a single flat group built from the spreads.
   */
  tocGroups?: BookTocGroup[];
  /** Eyebrow label at the top of the overlay (e.g. "The Specification"). */
  tocEyebrow?: string;
}

const { header, cover, spreads, tocGroups, tocEyebrow = "Contents" } = Astro.props;

const total = spreads.length;

// The overlay groups spreads under their labels. When the caller supplies an
// explicit grouping (the Playbook's canon spine) we honour it; otherwise we
// fall back to one flat group so an Enginebook still gets a usable contents.
const groups: BookTocGroup[] = tocGroups ?? [
  {
    key: "all",
    label: tocEyebrow,
    items: spreads.map((s, i) => ({
      slug: s.slug,
      idx: i,
      n: s.n,
      name: s.title,
      written: s.written ?? true,
    })),
  },
];
---

<div class="playbook">
  <SiteHeader domain={header.domain} tld={header.tld} location={header.location} />

  {
    /* Collapsed-strip indicator on the left edge. Click to expand the
      rail overlay (full contents). Each horizontal bar is one spread;
      the brick one is the current. Hidden on mobile (long scroll). */
  }
  <button class="pb-strip" type="button" aria-label="Open contents" aria-expanded="false">
    <span class="pb-strip-pos"
      ><span class="pb-strip-cur">00</span>/{String(total).padStart(2, "0")}</span
    >
    <span class="pb-strip-bars" aria-hidden="true">
      {spreads.map((_, i) => <span class="pb-strip-bar" data-idx={i} />)}
    </span>
    <span class="pb-strip-label">Contents</span>
  </button>

  {
    /* Rail overlay (TOC). Hidden by default; opens via the strip
      click. Esc closes. Groups by role so the hierarchy reads. */
  }
  <div class="pb-overlay" role="dialog" aria-modal="true" aria-label="Contents" hidden>
    <div class="pb-overlay-card">
      <div class="pb-overlay-head">
        <span class="pb-overlay-eyebrow">{tocEyebrow}</span>
        <button class="pb-overlay-close" type="button" aria-label="Close contents">×</button>
      </div>
      <nav class="pb-toc" aria-label="Spreads">
        {
          groups.map((g) => (
            <div class="pb-toc-group">
              <div class="pb-toc-grouplabel">{g.label}</div>
              {g.items.map((s) => (
                <a
                  href={`#${s.slug}`}
                  class={`pb-toc-link ${s.written ? "" : "pb-toc-link--draft"}`}
                  data-idx={s.idx}
                >
                  <span class="pb-toc-n">{s.n}</span>
                  <span class="pb-toc-name">{s.name ?? s.slug}</span>
                </a>
              ))}
            </div>
          ))
        }
      </nav>
    </div>
  </div>

  {
    /* Front cover. First snap-stop, before the spine. Theatre framing:
      title page of a book. The CTA scrolls into the first spread. */
  }
  <header id="cover" class="pb-cover">
    <div class="pb-cover-mark" aria-hidden="true"><Mark name="khai-mark" width={108} /></div>
    <div class="pb-cover-body">
      <span class="pb-cover-overline">{cover.overline}</span>
      {/* prettier-ignore */}
      <h1 class="pb-cover-title">{cover.title}<em>.</em></h1>
      {cover.subtitle && <p class="pb-cover-sub" set:html={cover.subtitle} />}
      <div class="pb-cover-actions">
        <a href={cover.ctaHref} class="book-cta">{cover.ctaLabel}</a>
        {cover.hint && <span class="pb-cover-hint">{cover.hint}</span>}
        {
          cover.backHref && (
            <a href={cover.backHref} class="pb-cover-back">
              {cover.backLabel}
            </a>
          )
        }
      </div>
    </div>
    {/* Edition stamp, bottom-center of the cover. */}
    <span class="pb-cover-edition">{cover.edition}</span>
  </header>

  {/* The spreads. One snap-stop per spread; mobile scrolls naturally. */}
  <main class="pb-spreads">
    {
      spreads.map((s) => {
        // Every spread is stacked: the numbered running head, then the hero
        // title on its own line (with the optional "Open" CTA pinned right),
        // then the body beneath -- a reference/LORE snap renders its prose
        // full-width, a content snap its 2x2 facet grid. No side-by-side.
        const proseSnap =
          s.written !== false && !!s.bodyHtml && (!s.facets || s.facets.length === 0);
        return (
          <article
            id={s.slug}
            class={`pb-spread ${s.written === false ? "pb-spread--draft" : ""} ${s.engine ? "pb-spread--engine" : ""} ${proseSnap ? "pb-spread--prose" : ""} ${s.download ? "pb-spread--download" : ""} ${s.classModifier ?? ""}`}
          >
            <header class="pb-spread-head">
              <span class="pb-spread-no">
                {s.n} ·{" "}
                {s.groupHref ? (
                  <a class="pb-spread-group-link" href={s.groupHref}>
                    {s.groupLabel}
                  </a>
                ) : (
                  s.groupLabel
                )}
              </span>
              {s.statusHtml ? (
                <span class="pb-spread-state" set:html={s.statusHtml} />
              ) : (
                <span class={`pb-spread-state pb-spread-state--${s.status}`}>{s.status}</span>
              )}
            </header>

            {/* Title row: the hero title stands on its own line; the optional
                "Open" CTA sits right, on the title's baseline (the enriched-by
                card's click-through into its full Enginebook). */}
            <div class="pb-titlerow">
              {/* prettier-ignore */}
              <h2 class="pb-spread-title">{s.title}<em>.</em></h2>
              {s.deepLink && (
                <a class="pb-open" href={s.deepLink.href} aria-label={s.deepLink.label}>
                  {s.deepLink.verb ?? "Open"}{" "}
                  <span class="pb-open-arr" aria-hidden="true">
                    →
                  </span>
                </a>
              )}
            </div>

            {s.subtitle && (
              <p
                class={`pb-spread-sub ${s.subtitle.startsWith("voice:") ? "pb-spread-sub--voice" : ""}`}
              >
                {s.subtitle}
              </p>
            )}

            {/* Body: a reference/LORE snap's prose, full-width beneath the
                title; otherwise the facet grid. */}
            {s.written !== false && s.bodyHtml && (
              <div class="pb-prose-body book-prose" set:html={s.bodyHtml} />
            )}

            {s.written !== false && s.facets && s.facets.length > 0 && (
              <div class="pb-facets">
                {s.facets.map((f) => (
                  <article class="pb-facet">
                    {/* prettier-ignore */}
                    <h3 class="pb-facet-name"><span class="pb-facet-initial">{f.letter}</span>{f.name.slice(1)}</h3>
                    {f.bodyHtml ? (
                      <p class="pb-facet-body" set:html={f.bodyHtml} />
                    ) : (
                      <p class="pb-facet-body">{f.body}</p>
                    )}
                  </article>
                ))}
                {/* When a spread carries both facets and a download, the
                    download becomes the final card in the grid (e.g. the
                    skillbook: Problem · Solution · Outcome · Download). */}
                {s.download && (
                  <article class="pb-facet pb-facet--download">
                    {/* prettier-ignore */}
                    <h3 class="pb-facet-name"><span class="pb-facet-initial">D</span>ownload</h3>
                    <div class="pb-facet-dl">
                      <a
                        class="pb-facet-dl-link"
                        href={s.download.href}
                        download={s.download.filename}
                      >
                        {s.download.filename}
                      </a>
                      <span class="pb-facet-dl-size">{s.download.size}</span>
                    </div>
                  </article>
                )}
              </div>
            )}

            {/* Standalone download section: only when there are no facets
                (the enginebook back-cover, where the download IS the spread
                content). When facets are present the download renders as the
                final card in the grid above. */}
            {s.written !== false && s.download && (!s.facets || s.facets.length === 0) && (
              <div class="pb-download">
                <a
                  class="book-cta pb-download-cta"
                  href={s.download.href}
                  download={s.download.filename}
                >
                  Download {s.download.filename}
                </a>
                <dl class="pb-download-meta">
                  <div class="pb-download-row">
                    <dt>size</dt>
                    <dd>{s.download.size}</dd>
                  </div>
                  <div class="pb-download-row">
                    <dt>sha256</dt>
                    <dd class="pb-download-hash">{s.download.sha256}</dd>
                  </div>
                </dl>
                {s.download.note && <p class="pb-download-note">{s.download.note}</p>}
              </div>
            )}

            {s.written !== false && s.coda && (
              <>
                <span class="pb-spread-rule" aria-hidden="true" />
                <p class="pb-spread-coda">{s.coda}</p>
              </>
            )}

            {s.written === false && (
              <div class="pb-spread-stub">
                <span class="pb-spread-stub-label">coming</span>
              </div>
            )}
          </article>
        );
      })
    }
  </main>

  <SiteFooter />
</div>

<style is:global>
  /* Full-bleed override + snap chassis, scoped to .playbook. */
  body:has(.playbook) {
    padding: 0;
  }
  body:has(.playbook) main {
    max-width: none;
    margin: 0;
  }
  html:has(.playbook) {
    scroll-snap-type: y mandatory;
    scroll-padding-top: 4rem;
    scroll-padding-bottom: 4rem;
    scroll-behavior: smooth;
  }
  @media (max-width: 640px) {
    html:has(.playbook) {
      scroll-snap-type: none;
    }
  }
  /* Lock body scroll when the overlay is open. */
  body:has(.pb-overlay:not([hidden])) {
    overflow: hidden;
  }
</style>

<style>
  .playbook {
    max-width: var(--width-page);
    margin: 0 auto;
    padding: 0 1.25rem;
    background: var(--color-paper);
    color: var(--color-ink);
    font-family: var(--font-prose);
  }
  @media (min-width: 641px) {
    .playbook {
      padding: 0 3.5rem;
    }
  }

  /* ── strip indicator (left edge, always visible on desktop) ──────────── */
  .pb-strip {
    position: fixed;
    top: 50%;
    left: 14px;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    background: transparent;
    border: none;
    padding: 14px 4px;
    cursor: pointer;
    z-index: 40;
    font-family: var(--font-mono);
    color: var(--color-ink-mute);
  }
  .pb-strip:focus-visible {
    outline: 2px solid var(--color-brick);
    outline-offset: 4px;
  }
  .pb-strip-pos {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .pb-strip-cur {
    color: var(--color-brick);
    font-weight: 600;
  }
  .pb-strip-bars {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pb-strip-bar {
    width: 18px;
    height: 2px;
    background: var(--color-rule);
    transition: background 0.16s;
  }
  .pb-strip-bar.is-current {
    background: var(--color-brick);
  }
  .pb-strip-label {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 9.5px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-top: 6px;
  }
  @media (max-width: 760px) {
    .pb-strip {
      display: none;
    }
  }

  /* ── overlay (TOC) ───────────────────────────────────────────────────── */
  .pb-overlay {
    position: fixed;
    inset: 0;
    background: rgba(22, 19, 15, 0.32);
    z-index: 50;
    display: flex;
    align-items: stretch;
  }
  .pb-overlay[hidden] {
    display: none;
  }
  .pb-overlay-card {
    background: var(--color-paper);
    border-right: 1px solid var(--color-ink);
    width: min(420px, 86vw);
    padding: 28px 32px 36px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .pb-overlay-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .pb-overlay-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brick);
  }
  .pb-overlay-close {
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-ink);
    font-size: 24px;
    line-height: 1;
    padding: 0 4px;
  }
  .pb-toc {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .pb-toc-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .pb-toc-grouplabel {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-rule-soft);
    margin-bottom: 4px;
  }
  .pb-toc-link {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 6px 0;
    text-decoration: none;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: -0.005em;
    transition: color 0.12s;
  }
  .pb-toc-link:hover {
    color: var(--color-brick);
  }
  .pb-toc-n {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--color-ink-mute);
    flex: 0 0 30px;
  }
  .pb-toc-link--draft {
    color: var(--color-ink-mute);
  }
  .pb-toc-link.is-current .pb-toc-name {
    font-weight: 500;
    color: var(--color-brick);
  }

  /* ── cover (front matter, first snap-stop) ──────────────────────────── */
  /* khai mark sits top-left as the brand presence; the editorial hero
   * (overline · title · subline · CTA) is centred in the viewport.
   * Mark + hero are deliberately independent layout elements so the
   * mark doesn't push the hero off-centre. */
  .pb-cover {
    position: relative;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    padding: 1.75rem 0 1.5rem;
  }
  @media (min-width: 641px) {
    .pb-cover {
      min-height: calc(100vh - 8rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 2.25rem 0;
    }
    /* Optical nudge: a centered hero reads slightly high in a tall
     * viewport, so bias it toward the lower third to balance the
     * empty band below. The mark (absolute, top-left) is untouched. */
    .pb-cover-body {
      transform: translateY(10vh);
    }
  }
  @media (max-width: 640px) {
    .pb-cover {
      scroll-snap-align: none;
      scroll-snap-stop: normal;
    }
  }
  .pb-cover-mark {
    position: absolute;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
  }
  @media (max-width: 640px) {
    .pb-cover-mark {
      position: static;
      transform: none;
      text-align: center;
      margin-bottom: 28px;
    }
  }
  /* Edition stamp: bottom-center of the cover, small. A colophon, not a
   * heading; centered to sit under the title column. */
  .pb-cover-edition {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  @media (max-width: 640px) {
    .pb-cover-edition {
      position: static;
      transform: none;
      display: block;
      text-align: center;
      margin-top: 24px;
    }
  }
  .pb-cover-body {
    max-width: 760px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pb-cover-overline {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.26em;
    color: var(--color-brick);
    text-transform: uppercase;
  }
  .pb-cover-title {
    margin: 22px 0 0;
    font-family: var(--font-display);
    font-weight: 380;
    font-size: 96px;
    line-height: 0.94;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }
  @media (min-width: 641px) {
    .pb-cover-title {
      font-size: 168px;
    }
  }
  .pb-cover-title em {
    color: var(--color-brick);
    font-style: normal;
    font-family: Georgia, serif;
  }
  .pb-cover-sub {
    margin: 22px 0 0;
    max-width: 540px;
    font-family: var(--font-prose);
    font-style: italic;
    font-size: 18px;
    line-height: 1.4;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }
  @media (min-width: 641px) {
    .pb-cover-sub {
      font-size: 24px;
    }
  }
  .pb-cover-actions {
    margin-top: 36px;
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    justify-content: center;
  }
  /* The cover CTA uses the shared `.book-cta` (see book.css). */
  .pb-cover-hint {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
  }
  /* Secondary back link in the cover actions (Enginebook: "<- all
   * enginebooks"). Sits beside the CTA, lighter weight. */
  .pb-cover-back {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
    text-decoration: none;
  }
  .pb-cover-back:hover {
    color: var(--color-brick);
  }

  /* ── spreads ─────────────────────────────────────────────────────────── */
  .pb-spreads {
    display: flex;
    flex-direction: column;
  }
  .pb-spread {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    padding: 1.75rem 0 1.5rem;
    border-bottom: 1px solid var(--color-rule-soft);
  }
  @media (min-width: 641px) {
    .pb-spread {
      min-height: calc(100vh - 8rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 2.25rem 0;
    }
  }
  @media (max-width: 640px) {
    .pb-spread {
      scroll-snap-align: none;
      scroll-snap-stop: normal;
    }
  }
  .pb-spread:last-child {
    border-bottom: none;
  }

  .pb-spread-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-rule);
  }
  .pb-spread-no {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-brick);
    text-transform: uppercase;
  }
  /* A linked group label (an engine spread's khai type, linked to its canon
   * type page). Inherits the brick badge colour; underlines on hover. */
  .pb-spread-group-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.12s;
  }
  .pb-spread-group-link:hover {
    border-bottom-color: var(--color-brick);
  }
  .pb-spread-state {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.22em;
    color: var(--color-ink-mute);
    text-transform: uppercase;
  }
  .pb-spread-state--published {
    color: var(--color-brick);
  }
  /* Engine cards (installed extensions) read in brick, like published, so an
   * instance wired through the seam stands apart from a draft canon spec. */
  .pb-spread-state--engine {
    color: var(--color-brick);
  }
  /* A linked status corner (an engine spread's parent / Taxonomy, linked to
   * the anchor snap). Brick, underlined on hover -- subtle in the mono slot. */
  .pb-spread-state :global(a) {
    color: var(--color-brick);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.12s;
  }
  .pb-spread-state :global(a:hover) {
    border-bottom-color: var(--color-brick);
  }

  /* Title row: the hero title and, when present, the "open" CTA pinned to
   * the right on the title's baseline (the enriched-by card -> Enginebook). */
  .pb-titlerow {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 28px;
    flex-wrap: wrap;
    margin-top: 22px;
  }
  .pb-titlerow .pb-spread-title {
    margin: 0;
  }
  /* The "Open" CTA: a smaller display sibling of the hero title -- ink, no
   * brick dot, brick on hover, the arrow nudging right. Larger than the
   * running head, well below the title (CVI: one resting accent per surface,
   * already spent on the title dot; the CTA earns brick on interaction). */
  .pb-open {
    flex: 0 0 auto;
    font-family: var(--font-display);
    font-weight: 380;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.14s;
  }
  @media (min-width: 641px) {
    .pb-open {
      font-size: 40px;
    }
  }
  .pb-open:hover {
    color: var(--color-brick);
  }
  .pb-open-arr {
    display: inline-block;
    transition:
      transform 0.14s,
      color 0.14s;
  }
  .pb-open:hover .pb-open-arr {
    transform: translateX(5px);
    color: var(--color-brick);
  }
  .pb-spread-title {
    font-family: var(--font-display);
    font-weight: 380;
    font-size: 64px;
    line-height: 0.94;
    letter-spacing: -0.02em;
    margin: 22px 0 0;
    color: var(--color-ink);
  }
  @media (min-width: 641px) {
    .pb-spread-title {
      font-size: 84px;
    }
  }
  .pb-spread-title em {
    color: var(--color-brick);
    font-style: normal;
    font-family: Georgia, serif;
  }
  .pb-spread-sub {
    margin: 14px 0 0;
    max-width: 720px;
    font-family: var(--font-prose);
    font-style: italic;
    font-size: 17px;
    line-height: 1.4;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }
  @media (min-width: 641px) {
    .pb-spread-sub {
      font-size: 21px;
    }
  }
  .pb-spread-sub--voice {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  @media (min-width: 641px) {
    .pb-spread-sub--voice {
      font-size: 12px;
    }
  }

  /* facets grid: 2x2 by default, 2x3 for instructions later */
  .pb-facets {
    margin-top: 30px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 641px) {
    .pb-facets {
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }
    /* Odd count: the last card spans both columns, so the grid never ends on
     * a lonely half-row (WIRES = 5, HACKS = 5, any odd spec). */
    .pb-facet:last-child:nth-child(odd) {
      grid-column: 1 / -1;
    }
  }

  /* Download card (when inside the facets grid) */
  .pb-facet-dl {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pb-facet-dl-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--color-brick);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    display: inline-block;
    word-break: break-all;
  }
  .pb-facet-dl-link:hover {
    color: var(--color-ink);
    border-bottom-color: var(--color-ink);
  }
  .pb-facet-dl-size {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-ink-mute);
  }
  .pb-facet {
    background: var(--color-paper-warm);
    border: 1px solid var(--color-rule-soft);
    border-radius: 3px;
    padding: 18px 22px 20px;
  }
  .pb-facet-name {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-weight: 420;
    font-size: 22px;
    letter-spacing: -0.005em;
    color: var(--color-ink);
  }
  .pb-facet-initial {
    color: var(--color-brick);
  }
  .pb-facet-body {
    margin: 0;
    font-family: var(--font-prose);
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  /* ── prose body (reference / LORE snaps) ─────────────────────────────────
   * A reference snap is stacked like every other: the hero title stands on
   * its own line above (the running head + .pb-titlerow), and the prose runs
   * full-width beneath it on a generous measure -- not a side column. The
   * reading voice itself (paragraphs, table, lists, links) is the shared
   * `.book-prose` (book.css); this only sets the body's lead and measure. */
  .pb-prose-body {
    margin-top: 30px;
    max-width: 880px;
  }

  /* ── download back-cover ─────────────────────────────────────────────────
   * The last snap of a book that ships an artifact (the engine zip, the skill
   * zip). The brick CTA leads; the provenance (size + content-hash) sits under
   * it in mono, quiet — there to be trusted, not read aloud. */
  .pb-download {
    margin-top: 34px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }
  .pb-download-meta {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pb-download-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .pb-download-row dt {
    flex: 0 0 64px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
  }
  .pb-download-row dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-soft);
  }
  /* The hash is long; let it wrap on its own rather than push the row wide. */
  .pb-download-hash {
    word-break: break-all;
    max-width: 52ch;
  }
  .pb-download-note {
    margin: 0;
    max-width: 720px;
    font-family: var(--font-prose);
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  .pb-spread-rule {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--color-rule-soft);
    margin: 26px 0 16px;
  }
  .pb-spread-coda {
    margin: 0;
    font-family: var(--font-prose);
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  /* The spread's click-through CTA (enriched-by engine card -> its
   * Enginebook) now sits in the title row and uses the shared `.book-cta`
   * (see book.css); no foot variant. */

  /* draft stub: spec exists in the spine but hasn't been authored yet */
  .pb-spread--draft .pb-spread-title {
    color: var(--color-ink-mute);
  }
  .pb-spread-stub {
    margin-top: 30px;
    padding: 22px 26px;
    border: 1px dashed var(--color-rule);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pb-spread-stub-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
  }
</style>

<script>
  // Keep the cover title and spread titles on one line. At the CSS size a short
  // title fits; a long one would wrap to two lines, so the shared helper steps
  // the font-size down until it fits. Same helper drives the Shelf masthead.
  import { fitOneLine } from "../lib/fit-one-line";
  fitOneLine(".pb-cover-title");
  fitOneLine(".pb-spread-title");
</script>

<script>
  (function () {
    const strip = document.querySelector(".pb-strip") as HTMLButtonElement | null;
    const overlay = document.querySelector(".pb-overlay") as HTMLElement | null;
    const closeBtn = document.querySelector(".pb-overlay-close") as HTMLButtonElement | null;
    const bars = Array.from(document.querySelectorAll(".pb-strip-bar")) as HTMLElement[];
    const tocLinks = Array.from(document.querySelectorAll(".pb-toc-link")) as HTMLAnchorElement[];
    const cover = document.querySelector(".pb-cover") as HTMLElement | null;
    const spreads = Array.from(document.querySelectorAll(".pb-spread")) as HTMLElement[];
    const curEl = document.querySelector(".pb-strip-cur") as HTMLElement | null;

    // All navigable stops in document order: cover first, then the
    // spreads. Index 0 = cover (no spec bar lit, counter "00");
    // index 1..N = spreads (bar[idx-1] lit, counter "0idx").
    const stops: HTMLElement[] = cover ? [cover, ...spreads] : [...spreads];
    let curIdx = 0;

    function setCurrent(idx: number) {
      curIdx = idx;
      const barIdx = idx - 1;
      bars.forEach((b, i) => b.classList.toggle("is-current", i === barIdx));
      tocLinks.forEach((l, i) => l.classList.toggle("is-current", i === barIdx));
      if (curEl) curEl.textContent = String(Math.max(0, idx)).padStart(2, "0");
    }

    function openOverlay() {
      if (!overlay || !strip) return;
      overlay.hidden = false;
      strip.setAttribute("aria-expanded", "true");
    }
    function closeOverlay() {
      if (!overlay || !strip) return;
      overlay.hidden = true;
      strip.setAttribute("aria-expanded", "false");
    }

    if (strip) strip.addEventListener("click", openOverlay);
    if (closeBtn) closeBtn.addEventListener("click", closeOverlay);
    if (overlay) {
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) closeOverlay();
      });
    }
    tocLinks.forEach((link) => {
      link.addEventListener("click", () => {
        // Let the hash navigation run, then collapse the overlay.
        setTimeout(closeOverlay, 0);
      });
    });

    // Keyboard navigation: ←/→ and ↑/↓ step between stops. Skipped
    // when the overlay is open (Esc closes that instead) and when
    // focus is in a form field. The hash CTAs on cover + TOC handle
    // direct jumps; this gives the book a one-keystroke turn.
    document.addEventListener("keydown", (e) => {
      if (overlay && !overlay.hidden) {
        if (e.key === "Escape") closeOverlay();
        return;
      }
      const active = document.activeElement as HTMLElement | null;
      if (active && (active.tagName === "INPUT" || active.tagName === "TEXTAREA")) return;

      if (e.key === "ArrowDown" || e.key === "ArrowRight") {
        const next = stops[Math.min(curIdx + 1, stops.length - 1)];
        if (next) next.scrollIntoView({ behavior: "smooth", block: "start" });
        e.preventDefault();
      } else if (e.key === "ArrowUp" || e.key === "ArrowLeft") {
        const prev = stops[Math.max(curIdx - 1, 0)];
        if (prev) prev.scrollIntoView({ behavior: "smooth", block: "start" });
        e.preventDefault();
      }
    });

    // IntersectionObserver: track the most-visible stop, update strip.
    if ("IntersectionObserver" in window && stops.length) {
      const obs = new IntersectionObserver(
        (entries) => {
          let best: IntersectionObserverEntry | null = null;
          for (const e of entries) {
            if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) {
              best = e;
            }
          }
          if (best) {
            const idx = stops.indexOf(best.target as HTMLElement);
            if (idx >= 0) setCurrent(idx);
          }
        },
        { threshold: [0.5, 0.75] },
      );
      stops.forEach((s) => obs.observe(s));
    }
  })();
</script>
