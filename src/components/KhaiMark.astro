---
// The kaihacks lockup mark — kh over ai with a brick dot crowning
// the k as the i's tittle. Single source for the SVG; the CVI
// colophon, the main surface, and any future subdomain page that
// needs to render the mark inline all go through this component.
//
// Props:
//   size:   width in px (height auto-scales at 2.27x)
//   letter: fill for k, a, i, and the rule (default BRAND.ink)
//   ghost:  fill for the silent h behind the k (default BRAND.ghost)
//   dot:    fill for the brick dot above the k (default BRAND.brick)
//
// The component emits a bare SVG; wrap it in a stage / card / tile
// container for layout. For the dark-ground reverse variant, pass
// letter=BRAND.paper with a translucent ghost.

import { BRAND } from "../lib/brand";

interface Props {
  size: number;
  letter?: string;
  ghost?: string;
  dot?: string;
}

const { size, letter = BRAND.ink, ghost = BRAND.ghost, dot = BRAND.brick } = Astro.props;
const height = size * 2.27;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="-30 -34 290 660"
  width={size}
  height={height}
  style="font-family: 'Newsreader', serif; font-weight: 540;"
>
  <text x="60" y="280" font-size="280" fill={ghost}>h</text>
  <text x="0" y="280" font-size="280" fill={letter}>k</text>
  <circle cx="189.4" cy="93.5" r="21" fill={dot}></circle>
  <rect x="0" y="330" width="232.6" height="12.6" rx="6.3" fill={letter}></rect>
  <text x="0" y="592.2" font-size="280" fill={letter}>a</text>
  <text x="149.4" y="592.2" font-size="280" fill={letter}>i</text>
</svg>
