#!/usr/bin/env sh
# KHAI-Guard: block a push that would mix source and test changes in one
# PR range (the branch tip against its merge-base with origin/main).
npx khai-guard

# KHAI-Guard branch-scope: the branch NAME must classify into a website lane
# (see docs/BRANCHING.md), and the branch's diff range must stay inside that
# lane's owned paths. ADVISORY for now (--warn prints violations but exits 0)
# while the live claude/* branches are renamed to the lane scheme. Same engine
# as khai; this repo's policy lives in khai-guard.config.json (branchScope).
# To enforce: drop --warn (see docs/BRANCHING.md "flip to hard-fail").
npx khai-guard branch-check --warn
