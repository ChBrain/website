#!/usr/bin/env sh
# KHAI-Guard: block a push that would mix source and test changes in one
# PR range (the branch tip against its merge-base with origin/main).
npx khai-guard

# KHAI-Guard branch-scope: the branch NAME must classify into a website lane
# (see docs/BRANCHING.md), and the branch's diff range must stay inside that
# lane's owned paths. ENFORCED: a violation exits non-zero and blocks the push.
# Same engine as khai; this repo's policy lives in khai-guard.config.json
# (branchScope). Name the branch for its subject before you start.
npx khai-guard branch-check
