#!/usr/bin/env sh

# Source/test separation (formerly an inline META-2 block here) now lives in
# KHAI-Guard at pre-push, where it sees the whole PR range rather than a
# single commit. See khai-guard.config.json for this repo's buckets.

# Prettier enforcement: mirrors CI's format:check.
# What passes here passes CI; nothing slips through.
if ! npm run --silent format:check; then
  echo
  echo "Prettier formatting failed. Run: npm run format"
  exit 1
fi

exit 0
