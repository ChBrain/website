#!/usr/bin/env sh
# Auto-format staged files so prettier never fails CI on a forgotten --write.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -n "$STAGED" ]; then
  echo "$STAGED" | xargs npx prettier --write --ignore-unknown 2>/dev/null || true
  echo "$STAGED" | xargs git add
fi

# Source/test separation (formerly an inline META-2 block here) now lives in
# KHAI-Guard at pre-push, where it sees the whole PR range rather than a
# single commit. See khai-guard.config.json for this repo's buckets.

# Guard: reject any staged tarballs (should never be committed)
if git diff --cached --name-only | grep -E '\.(tgz|tar\.gz)$'; then
  echo "❌ Error: Tarball files (.tgz/.tar.gz) should not be committed. Use a registry instead."
  exit 1
fi

exit 0
