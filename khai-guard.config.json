{
  "source": ["src/**", "public/**", "astro.config.*"],
  "test": ["tests/**", ".github/workflows/**", ".husky/**"],
  "exemptRenames": true,
  "branchScope": {
    "shared": [],
    "lanes": [
      {
        "pattern": "chassis/*",
        "layer": "architecture",
        "allow": [
          "src/components/**",
          "src/lib/**",
          "src/layouts/**",
          "src/styles/**",
          "src/marks/**"
        ]
      },
      {
        "pattern": "governance/*",
        "layer": "governance",
        "allow": [".github/**", ".husky/**", "khai-guard.config.json"]
      },
      {
        "pattern": "surface/architecture/*",
        "layer": "solution",
        "allow": [
          "src/pages/index.astro",
          "src/pages/architecture/index.astro",
          "src/pages/architecture/[slug].astro"
        ]
      },
      {
        "pattern": "surface/*/*",
        "layer": "solution",
        "unit": 1,
        "allow": ["src/pages/**/{name}/**"]
      },
      {
        "pattern": "repo/*",
        "layer": "infra",
        "allow": []
      },
      {
        "pattern": "chore/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "fix/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "docs/*",
        "layer": "general",
        "allow": []
      }
    ]
  }
}
