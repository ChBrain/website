{
  "source": ["src/**", "public/**", "astro.config.*"],
  "test": ["tests/**", ".github/workflows/**", ".husky/**"],
  "exemptRenames": true,
  "branchScope": {
    "shared": [
      ".changeset/**",
      "package.json",
      "package-lock.json",
      "CHANGELOG.md",
      ".prettierrc",
      ".gitignore",
      ".npmrc",
      ".nvmrc",
      "LICENSE",
      "LICENSE-CODE",
      "SECURITY.md"
    ],
    "lanes": [
      {
        "pattern": "chassis/*",
        "layer": "architecture",
        "allow": [
          "src/components/**",
          "src/lib/**",
          "src/layouts/**",
          "src/styles/**",
          "src/marks/**",
          "smoke/**"
        ]
      },
      {
        "pattern": "governance/*",
        "layer": "governance",
        "allow": [
          ".github/**",
          ".husky/**",
          "khai-guard.config.json",
          "tests/**",
          "scripts/**",
          "staging/**",
          "GEMINI.md",
          "CLAUDE.md",
          "README.md",
          "docs/**",
          "management/**",
          "vitest.config.ts"
        ]
      },
      {
        "pattern": "surface/pages/*",
        "layer": "solution",
        "allow": ["src/pages/*.astro", "src/pages/*/*.astro"]
      },
      {
        "pattern": "surface/enginebooks/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/enginebooks/**"]
      },
      {
        "pattern": "surface/engines/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/engines/**"]
      },
      {
        "pattern": "surface/skills/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/skills/**"]
      },
      {
        "pattern": "surface/plays/*",
        "layer": "solution",
        "allow": ["src/pages/plays/**"]
      },
      {
        "pattern": "surface/playbook/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/playbook/**"]
      },
      {
        "pattern": "surface/skillbook/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/skillbook/**"]
      },
      {
        "pattern": "surface/methodbook/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/methodbook/**"]
      },
      {
        "pattern": "surface/writing/*",
        "layer": "solution",
        "allow": ["src/pages/writing/**"]
      },
      {
        "pattern": "surface/cultures/*",
        "layer": "solution",
        "allow": ["src/pages/cultures/**"]
      },
      {
        "pattern": "surface/cvi/*",
        "layer": "solution",
        "allow": ["src/pages/main/cvi/**"]
      },
      {
        "pattern": "surface/privacy/*",
        "layer": "solution",
        "allow": ["src/pages/main/privacy/**"]
      },
      {
        "pattern": "surface/contact/*",
        "layer": "solution",
        "allow": ["src/pages/main/contact/**"]
      },
      {
        "pattern": "deps/*",
        "layer": "deps",
        "allow": ["**/package.json", "**/package-lock.json"]
      },
      {
        "pattern": "dependabot/*",
        "layer": "deps",
        "allow": ["**/package.json", "**/package-lock.json", ".github/workflows/**"]
      },
      {
        "pattern": "repo/*",
        "layer": "infra",
        "allow": []
      },
      {
        "pattern": "chore/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "fix/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "docs/*",
        "layer": "general",
        "allow": []
      }
    ]
  }
}
