{
  "source": ["src/**", "public/**", "astro.config.*"],
  "test": ["tests/**", ".github/workflows/**", ".husky/**"],
  "exemptRenames": true,
  "branchScope": {
    "shared": [],
    "lanes": [
      {
        "pattern": "chassis/*",
        "layer": "architecture",
        "allow": [
          "src/components/**",
          "src/lib/**",
          "src/layouts/**",
          "src/styles/**",
          "src/marks/**"
        ]
      },
      {
        "pattern": "governance/*",
        "layer": "governance",
        "allow": [".github/**", ".husky/**", "khai-guard.config.json", "tests/**"]
      },
      {
        "pattern": "surface/pages/*",
        "layer": "solution",
        "allow": ["src/pages/*.astro", "src/pages/*/*.astro"]
      },
      {
        "pattern": "surface/enginebooks/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/enginebooks/**"]
      },
      {
        "pattern": "surface/playbook/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/playbook/**"]
      },
      {
        "pattern": "surface/skillbook/*",
        "layer": "solution",
        "allow": ["src/pages/architecture/skillbook/**"]
      },
      {
        "pattern": "surface/cvi/*",
        "layer": "solution",
        "allow": ["src/pages/main/cvi/**"]
      },
      {
        "pattern": "surface/privacy/*",
        "layer": "solution",
        "allow": ["src/pages/main/privacy/**"]
      },
      {
        "pattern": "surface/contact/*",
        "layer": "solution",
        "allow": ["src/pages/main/contact/**"]
      },
      {
        "pattern": "repo/*",
        "layer": "infra",
        "allow": []
      },
      {
        "pattern": "chore/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "fix/*",
        "layer": "general",
        "allow": []
      },
      {
        "pattern": "docs/*",
        "layer": "general",
        "allow": []
      }
    ]
  }
}
